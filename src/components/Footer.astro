---
const socials = [
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/calculations.tools',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0.908 0.908 18 18" width="18" height="18"><path d="M5.78 1.651h8.257a4.13 4.13 0 0 1 4.128 4.129v8.257a4.13 4.13 0 0 1-4.128 4.128H5.78a4.13 4.13 0 0 1-4.129-4.128V5.78A4.13 4.13 0 0 1 5.78 1.651"/><path d="M13.211 9.388a3.303 3.303 0 1 1-2.783-2.782 3.3 3.3 0 0 1 2.783 2.782m1.239-4.021h.008"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/company/calculations-tools/',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 18" width="18" height="18"><path fill="currentColor" d="M15.32 15.32h-2.68v-4.16c0-1-.04-2.28-1.4-2.28-1.4 0-1.6 1.08-1.6 2.2v4.24H7V6.76h2.56v1.16h.04a2.8 2.8 0 0 1 2.52-1.4c2.72 0 3.2 1.76 3.2 4.08zM4 5.56c-.84 0-1.56-.68-1.56-1.56S3.12 2.44 4 2.44a1.56 1.56 0 0 1 0 3.08m1.32 9.76H2.64V6.76h2.68zM16.68 0H1.32A1.32 1.32 0 0 0 0 1.28v15.4C0 17.4.6 18 1.32 18h15.32a1.2 1.2 0 0 0 1.32-1.28V1.28C18 .6 17.4 0 16.68 0"/></svg>`,
  },
];
---
<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <p>&copy; <span id="footer-year"></span> calculations.tools. All rights reserved. | <a href="/privacy-policy">Privacy Policy</a></p>
      <i>Built to help by <a href="https://www.linkedin.com/in/jesperpallesen20/" target="_blank">Jesper Pallesen</a> and <a href="https://gamesevenmarketing.com/" target="_blank">Game Seven Marketing</a></i>
      {socials.length > 0 && (
        <div class="footer-socials">
          {socials.map(s => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="footer-social-link" set:html={s.svg} />
          ))}
        </div>
      )}
    </div>
  </div>
</footer>

<style>
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }
  .footer-socials {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .footer-social-link {
    color: rgba(255,255,255,0.3);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }
  .footer-social-link:hover {
    color: rgba(255,255,255,0.7);
  }
</style>
