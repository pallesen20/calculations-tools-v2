---
import { GLOSSARY_TERMS } from '../data/glossary';

const { pathname } = Astro.url;

const GLOSSARY_NAME_MAP = Object.fromEntries(GLOSSARY_TERMS.map(t => [t.slug, t.term]));

const NAME_MAP: Record<string, string> = {
  ...GLOSSARY_NAME_MAP,
  'percentage-calculator': 'Percentage Calculator',
  'compare-text': 'Compare Text',
  'compare-excel': 'Compare Excel',
  'word-counter': 'Word Counter',
  'week-number': 'Week Number',
  'date-calculator': 'Date Calculator',
  'about-us': 'About Us',
  'privacy-policy': 'Privacy Policy',
  'conversion': 'Conversion',
  'length-converter': 'Length Converter',
  'weight-converter': 'Weight Converter',
  'temperature-converter': 'Temperature Converter',
  'case-converter': 'Case Converter',
  'currency-converter': 'Currency Converter',
  'height-converter': 'Height Converter',
  'health': 'Health',
  'bmi-calculator': 'BMI Calculator',
  'men': 'BMI Calculator for Men',
  'women': 'BMI Calculator for Women',
  'kids': 'BMI Calculator for Kids',
  'teens': 'BMI Calculator for Teens',
  'pregnancy': 'BMI Calculator During Pregnancy',
  'weight-loss': 'BMI Weight Loss Calculator',
  'seniors': 'BMI Calculator for Seniors',
  'ffmi-calculator': 'FFMI Calculator',
  'fraction-calculator': 'Fraction Calculator',
  'lcd': 'LCD Calculator',
  '/math/fraction-calculator/compare': 'Compare Fractions',
  'decimal-to-fraction': 'Decimal to Fraction',
  'equivalent': 'Equivalent Calculator',
  'exponent': 'Fraction Exponent',
  'fraction-to-decimal': 'Fraction to Decimal',
  'improper-to-mixed': 'Improper to Mixed Number',
  'mixed-number': 'Mixed Number Calculator',
  'mixed-to-improper': 'Mixed to Improper Fraction',
  'ratio-calculator': 'Ratio Calculator',
  'proportion': 'Proportion Calculator',
  'unit-rate': 'Unit Rate Calculator',
  'golden-ratio': 'Golden Ratio Calculator',
  'aspect-ratio': 'Aspect Ratio Calculator',
  'scale': 'Scale Calculator',
  'ratio-to-percentage': 'Ratio to Percentage',
  'three-way': '3-Part Ratio Calculator',
  'progress-tracker': 'Progress Tracker',
  'finance': 'Finance',
  'ebitda-calculator': 'EBITDA Calculator',
  'ebit-calculator': 'EBIT Calculator',
  'ebt-calculator': 'EBT Calculator',
  'ebitda-margin-calculator': 'EBITDA Margin Calculator',
  'gross-profit-margin-calculator': 'Gross Profit Margin Calculator',
  'net-profit-margin-calculator': 'Net Profit Margin Calculator',
  'operating-profit-margin-calculator': 'Operating Profit Margin Calculator',
  'glossary': 'Glossary',
  'pdf': 'PDF',
  'csv': 'CSV',
  'css': 'CSS',
  'html': 'HTML',
  'javascript': 'JavaScript',
  'mph-to-kmh': 'MPH to KMH'
};

function slugToName(slug: string) {
  if (pathname.includes('/currency-converter/')) {
  return NAME_MAP[slug] ?? slug.replace(/-/g, ' ').toUpperCase().replace(/\b\w/g, c => c.toUpperCase());
  } else {
  return NAME_MAP[slug] ?? slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  }
}

const segments = pathname.replace(/\/$/, '').split('/').filter(Boolean);
if (segments.length === 0) return;

const crumbs = [
  { name: 'Home', url: '/' },
  ...segments.map((seg, i) => ({
    name: slugToName(seg),
    url: i < segments.length - 1 ? '/' + segments.slice(0, i + 1).join('/') : null,
  }))
];

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": crumbs.map((c, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": c.name,
    "item": { "@type": "Thing", "@id": `https://calculations.tools${c.url ?? pathname}` }
  }))
};
---

{segments.length > 0 && (
  <>
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <ol class="breadcrumb-list">
        {crumbs.map((crumb, i) => (
          <>
            <li>
              {crumb.url
                ? <a href={crumb.url} class="breadcrumb-link">{crumb.name}</a>
                : <span class="breadcrumb-current">{crumb.name}</span>
              }
            </li>
            {i < crumbs.length - 1 && <span class="breadcrumb-separator">›</span>}
          </>
        ))}
      </ol>
    </nav>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </>
)}