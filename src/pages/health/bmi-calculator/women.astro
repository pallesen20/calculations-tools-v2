    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is a healthy BMI for women?", "acceptedAnswer": { "@type": "Answer", "text": "A healthy BMI for women is 18.5 to 24.9 - the same range used for all adults under WHO guidelines. However, because women naturally carry 3 to 5 percentage points more body fat than men at the same BMI, interpreting the number requires understanding female physiology. The average BMI of American women is approximately 29.6, placing the average US woman in the Overweight category." } },
      { "@type": "Question", "name": "What is the average BMI for an American woman?", "acceptedAnswer": { "@type": "Answer", "text": "The average BMI for American women is approximately 29.6, according to CDC National Health and Nutrition Examination Survey data. This places the average US woman in the Overweight category. The average American woman weighs approximately 77 kg (170 lbs) and stands approximately 162 cm (5 foot 4 inches) tall." } },
      { "@type": "Question", "name": "Is BMI calculated differently for women?", "acceptedAnswer": { "@type": "Answer", "text": "No. The BMI formula is identical for men and women: weight (kg) divided by height (m) squared. The same WHO category thresholds (18.5, 25, 30) apply to both sexes. However, the same BMI number implies more body fat in women than in men, because women have less muscle mass and more essential fat. Some researchers have proposed sex-specific thresholds, but standard clinical guidelines use the same cutoffs." } },
      { "@type": "Question", "name": "Why does BMI not account for menopause?", "acceptedAnswer": { "@type": "Answer", "text": "BMI uses only weight and height and cannot account for the hormonal changes of menopause. After menopause, falling oestrogen levels cause fat to redistribute from the hips and thighs to the abdomen, increasing visceral fat even when BMI stays constant. A postmenopausal woman can have a Normal BMI but carry substantially more metabolically dangerous abdominal fat than she did before menopause. Waist circumference is a better companion measure in this group." } },
