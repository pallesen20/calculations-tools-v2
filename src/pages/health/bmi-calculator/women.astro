    "@type": "WebApplication",
    "name": "BMI Calculator for Women",
    "url": "https://calculations.tools/health/bmi-calculator/women",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Any",
    "description": "Free BMI calculator for women with metric and imperial support. Shows BMI value, category, healthy weight range for your height, and how far you are from the Normal weight range.",
