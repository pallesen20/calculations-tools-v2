<CalculatorLayout
  title="BMI Calculator During Pregnancy"
  metaTitle="BMI Calculator During Pregnancy | Gestational Weight Gain by BMI ᐅ"
  description="Calculate your pre-pregnancy BMI and get recommended gestational weight gain targets based on IOM 2009 guidelines. Covers weight gain by trimester, complications by BMI, and pre-conception guidance."
  canonical="https://calculations.tools/health/bmi-calculator/pregnancy"
  embedSlug="bmi-calculator"
  tocItems={tocItems}
  sources={sources}
  schema={schema}
  ogFormula="Pre-pregnancy BMI = weight (kg) / height² (m²)"
  ogExample="65 kg at 1.68 m: 65 / 2.8224 = 23.0 -> gain 11.5-16 kg"
>
  <div slot="calculator">
    <div class="calculator-container bmi-container">

      <div class="calculator-header">
        <h2>BMI Calculator for Pregnant Women</h2>
        <p>Enter your <strong>pre-pregnancy</strong> weight and height</p>
      </div>
      <div class="bmi-unit-toggle">
        <button class="bmi-unit-btn active" data-unit="metric">Metric</button>
        <button class="bmi-unit-btn" data-unit="imperial">Imperial</button>
      </div>
      <div id="bmi-metric" class="bmi-inputs active">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-kg">Weight</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-weight-kg" class="bmi-input" min="1" max="500" step="0.1" placeholder="65" />
            <span class="bmi-unit-tag">kg</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-height-cm">Height</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-height-cm" class="bmi-input" min="50" max="280" step="1" placeholder="163" />
            <span class="bmi-unit-tag">cm</span>
          </div>
        </div>
      </div>
      <div id="bmi-imperial" class="bmi-inputs">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-lb">Weight</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-weight-lb" class="bmi-input" min="1" max="1100" step="0.5" placeholder="143" />
            <span class="bmi-unit-tag">lbs</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label">Height</label>
          <div class="bmi-ftin">
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="bmi-height-ft" class="bmi-input" min="1" max="9" step="1" placeholder="5" />
              <span class="bmi-unit-tag">ft</span>
            </div>
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="bmi-height-in" class="bmi-input" min="0" max="11" step="1" placeholder="4" />
              <span class="bmi-unit-tag">in</span>
            </div>
          </div>
        </div>
      </div>
      <div id="bmi-result" class="bmi-result hidden">
        <div class="bmi-value-row">
          <div class="bmi-value" id="bmi-value">—</div>
          <div class="bmi-category-badge" id="bmi-category-badge">—</div>
        </div>
        <div class="bmi-scale">
          <div class="bmi-scale-bar">
            <div class="bmi-seg bmi-seg-underweight"></div>
            <div class="bmi-seg bmi-seg-normal"></div>
            <div class="bmi-seg bmi-seg-overweight"></div>
            <div class="bmi-seg bmi-seg-obese"></div>
            <div class="bmi-indicator" id="bmi-indicator"></div>
          </div>
          <div class="bmi-scale-labels">
            <span style="left:0%">10</span>
            <span style="left:28.3%">18.5</span>
            <span style="left:50%">25</span>
            <span style="left:66.7%">30</span>
            <span style="left:100%">40+</span>
          </div>
        </div>
