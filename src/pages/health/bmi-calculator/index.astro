const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "BMI Calculator by Age and Sex",
    "url": "https://calculations.tools/health/bmi-calculator",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Any",
    "description": "Calculate BMI by age and sex. Returns BMI category, estimated body fat %, healthy weight range, and age- and sex-specific interpretation in metric or imperial units.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to calculate your BMI",
    "description": "Use this BMI calculator to find your Body Mass Index, estimated body fat %, and personalised context in four steps.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Choose your unit system", "text": "Select Metric (kg and cm) or Imperial (lbs, feet, and inches) using the toggle at the top of the calculator." },
      { "@type": "HowToStep", "position": 2, "name": "Select your sex", "text": "Choose Male or Female. Sex is used to estimate body fat percentage and provide context relevant to your biology." },
      { "@type": "HowToStep", "position": 3, "name": "Enter your age", "text": "Type your age in years. Age is used to estimate body fat percentage and apply age-appropriate interpretation (e.g. adjusted thresholds for adults 65 and over). If you are under 20, the calculator will link you to the appropriate age-specific tool." },
      { "@type": "HowToStep", "position": 4, "name": "Enter your weight and height", "text": "Type your weight and height. Your BMI, estimated body fat %, healthy weight range, and a personalised context note appear instantly." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is a healthy BMI?", "acceptedAnswer": { "@type": "Answer", "text": "A healthy (Normal) BMI is between 18.5 and 24.9. Below 18.5 is Underweight; 25.0 to 29.9 is Overweight; 30.0 and above is Obese (Class I: 30-34.9, Class II: 35-39.9, Class III: 40+). These thresholds are set by the World Health Organization for adults aged 18 and over." } },
      { "@type": "Question", "name": "What does BMI stand for?", "acceptedAnswer": { "@type": "Answer", "text": "BMI stands for Body Mass Index. It is a number calculated from a person's weight and height used as a screening tool to identify whether a person is Underweight, Normal weight, Overweight, or Obese." } },
      { "@type": "Question", "name": "What is the BMI formula?", "acceptedAnswer": { "@type": "Answer", "text": "In metric units: BMI = weight (kg) / height (m)². In imperial units: BMI = 703 × weight (lb) / height (in)². For example, a person who weighs 70 kg and is 1.75 m tall has a BMI of 70 / 1.75² = 22.9." } },
      { "@type": "Question", "name": "What BMI is considered overweight?", "acceptedAnswer": { "@type": "Answer", "text": "A BMI of 25.0 to 29.9 is classified as Overweight. A BMI of 30.0 or above is classified as Obese (Class I, II, or III). These categories are based on associations with health risks in large population studies." } },
      { "@type": "Question", "name": "Is BMI accurate?", "acceptedAnswer": { "@type": "Answer", "text": "BMI is a useful population-level screening tool but has well-documented limitations for individuals. It cannot distinguish between muscle and fat, and does not account for age, sex, or ethnicity differences in body composition. This calculator adds age and sex to estimate body fat percentage (Deurenberg formula) and provide more context, but a doctor should interpret results alongside other health measures." } },
