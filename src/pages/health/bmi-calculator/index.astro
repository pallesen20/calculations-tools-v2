---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';
import RelatedTools from '../../../components/RelatedTools.astro';
import RelatedGlossaryTerms from '../../../components/RelatedGlossaryTerms.astro';
import type { Source } from '../../../components/Sources.astro';

const f = {
  metric:    "$$\\text{BMI} = \\frac{\\text{weight (kg)}}{\\text{height (m)}^2}$$",
  imperial:  "$$\\text{BMI} = \\frac{703 \\times \\text{weight (lb)}}{\\text{height (in)}^2}$$",
  example:   "$$\\text{BMI} = \\frac{70}{1.75^2} = \\frac{70}{3.0625} = 22.9$$",
  bfGeneral: "$$\\text{BF\\%} = 1.20 \\times \\text{BMI} + 0.23 \\times \\text{Age} - 10.8 \\times S - 5.4$$",
};

const tocItems = [
  { id: 'how-to-use',        label: 'How to use' },
  { id: 'what-is-bmi',       label: 'What is BMI?' },
  { id: 'bmi-categories',    label: 'BMI categories' },
  { id: 'bmi-by-age-sex',    label: 'BMI by age and sex' },
  { id: 'body-fat-estimate', label: 'Estimated body fat %' },
  { id: 'bmi-limitations',   label: 'Limitations of BMI' },
  { id: 'healthy-weight',    label: 'Healthy weight by height' },
  { id: 'how-to-calculate',  label: 'How to calculate BMI' },
  { id: 'common-mistakes',   label: 'Common mistakes' },
  { id: 'faq',               label: 'FAQs' },
  { id: 'related-tools',     label: 'Related tools' },
];

const sources: Source[] = [
  {
    author: 'World Health Organization',
    title: 'Body mass index - BMI',
    journal: 'WHO Regional Office for Europe',
    year: 2024,
    url: 'https://www.euro.who.int/en/health-topics/disease-prevention/nutrition/a-healthy-lifestyle/body-mass-index-bmi',
  },
  {
    author: 'Centers for Disease Control and Prevention',
    title: 'About Adult BMI',
    journal: 'CDC',
    year: 2023,
    url: 'https://www.cdc.gov/bmi/about/index.html',
  },
  {
    author: 'Nuttall FQ',
    title: 'Body Mass Index: Obesity, BMI, and Health - A Critical Review',
    journal: 'Nutrition Today',
    year: 2015,
    url: 'https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4890841/',
  },
  {
    author: 'Deurenberg P, Weststrate JA, Seidell JC',
    title: 'Body mass index as a measure of body fatness: age- and sex-specific prediction formulas',
    journal: 'British Journal of Nutrition',
    year: 1991,
    url: 'https://doi.org/10.1079/bjn19910073',
  },
  {
    author: 'Aune D, Sen A, Prasad M, Norat T, Janszky I, Tonstad S, Romundstad P, Vatten LJ',
    title: 'BMI and all cause mortality: systematic review and non-linear dose-response meta-analysis of 230 cohort studies',
    journal: 'BMJ',
    year: 2016,
    url: 'https://www.bmj.com/content/353/bmj.i2156',
  },
  {
    author: 'Flegal KM, Shepherd JA, Looker AC, Graubard BI, Borrud LG, Ogden CL',
    title: 'Comparisons of percentage body fat, body mass index, waist circumference, and waist-stature ratio in adults',
