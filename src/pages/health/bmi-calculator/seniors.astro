const f = {
  metric:    "$$\\text{BMI} = \\frac{\\text{weight (kg)}}{\\text{height (m)}^2}$$",
  imperial:  "$$\\text{BMI} = \\frac{703 \\times \\text{weight (lb)}}{\\text{height (in)}^2}$$",
  bfGeneral: "$$\\text{BF\\%} = 1.20 \\times \\text{BMI} + 0.23 \\times \\text{Age} - 10.8 \\times S - 5.4$$",
};

const tocItems = [
  { id: 'how-to-use',          label: 'How to use' },
  { id: 'why-different',       label: 'Why BMI is different at 65+' },
  { id: 'senior-range',        label: 'The 23–27.5 senior optimal range' },
  { id: 'sarcopenia',          label: 'Sarcopenia: muscle loss with age' },
  { id: 'frailty',             label: 'Frailty risk and BMI' },
  { id: 'underweight-risk',    label: 'Underweight risk in older adults' },
  { id: 'obesity-seniors',     label: 'Obesity in older adults' },
  { id: 'body-fat-estimate',   label: 'Estimated body fat %' },
  { id: 'when-to-see-doctor',  label: 'When to see your doctor' },
  { id: 'faq',                 label: 'FAQs' },
  { id: 'related-tools',       label: 'Related tools' },
];

const sources: Source[] = [
  {
    author: 'World Health Organization',
    title: 'Body mass index - BMI',
    journal: 'WHO Regional Office for Europe',
    year: 2024,
    url: 'https://www.euro.who.int/en/health-topics/disease-prevention/nutrition/a-healthy-lifestyle/body-mass-index-bmi',
  },
  {
    author: 'Volkert D, Beck AM, Cederholm T, et al.',
    title: 'ESPEN practical guideline: Clinical nutrition and hydration in geriatrics',
    journal: 'Clinical Nutrition',
    year: 2022,
    url: 'https://doi.org/10.1016/j.clnu.2021.12.026',
  },
  {
    author: 'Cruz-Jentoft AJ, Bahat G, Bauer J, et al.',
    title: 'Sarcopenia: revised European consensus on definition and diagnosis (EWGSOP2)',
    journal: 'Age and Ageing',
    year: 2019,
    url: 'https://doi.org/10.1093/ageing/afy169',
  },
  {
    author: 'Cederholm T, Jensen GL, Correia MITD, et al.',
