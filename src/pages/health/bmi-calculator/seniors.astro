    url: 'https://doi.org/10.1079/bjn19910073',
  },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "BMI Calculator for Seniors",
    "url": "https://calculations.tools/health/bmi-calculator/seniors",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Any",
    "description": "BMI calculator for adults 65 and over. Shows standard BMI category plus the 23–27.5 senior optimal range, estimated body fat %, and frailty risk guidance.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to use the senior BMI calculator",
    "description": "Calculate BMI with senior-specific interpretation in three steps.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Choose your unit system and sex", "text": "Select Metric or Imperial and then choose Male or Female. Sex is used for the estimated body fat percentage." },
      { "@type": "HowToStep", "position": 2, "name": "Enter your age", "text": "Enter your age in years. This calculator is designed for adults 65 and over. If you are under 65, you will be directed to the standard BMI calculator." },
      { "@type": "HowToStep", "position": 3, "name": "Enter your weight and height", "text": "Your BMI, senior optimal range indicator, estimated body fat %, and the senior optimal weight for your height all appear instantly." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is a healthy BMI for seniors over 65?", "acceptedAnswer": { "@type": "Answer", "text": "Most geriatric guidelines recommend a BMI of 23 to 27.5 as the optimal range for adults aged 65 and over. This is higher than the standard adult range of 18.5–24.9. A BMI below 23 in older adults is associated with increased frailty risk, malnutrition, and higher mortality. A BMI slightly above 25 does not carry the same risk in older adults as it does in younger adults." } },
      { "@type": "Question", "name": "Why is the healthy BMI range different for older adults?", "acceptedAnswer": { "@type": "Answer", "text": "As people age, they lose muscle mass (sarcopenia) and gain fat mass, often without a change in BMI. This means a BMI that looks normal may hide a poor body composition in an older person. Additionally, low body weight in older adults is associated with immune suppression, poor wound healing, falls, and frailty — risks that are less prominent at younger ages. For these reasons, geriatric guidelines recommend maintaining a slightly higher BMI in older adults." } },
      { "@type": "Question", "name": "What is sarcopenia?", "acceptedAnswer": { "@type": "Answer", "text": "Sarcopenia is the age-related loss of muscle mass, strength, and function. It typically begins after age 40 and accelerates after 65. Adults can lose 3–8% of muscle mass per decade; after 70, this rate increases. Sarcopenia increases the risk of falls, fractures, and functional decline. It can occur at any BMI, including normal weight, which is why BMI alone is insufficient for assessing health in older adults." } },
      { "@type": "Question", "name": "What BMI is considered underweight for a 70-year-old?", "acceptedAnswer": { "@type": "Answer", "text": "For adults aged 70 and over, ESPEN guidelines define a BMI below 22 as a risk factor for malnutrition. More broadly, a BMI below 23 in this age group is considered below the senior optimal range and is associated with frailty risk. Unintentional weight loss of 5% or more in 6 months is a red flag regardless of starting BMI." } },
      { "@type": "Question", "name": "Is it dangerous to lose weight after 65?", "acceptedAnswer": { "@type": "Answer", "text": "Intentional, gradual weight loss in older adults with obesity is generally safe when combined with resistance exercise to preserve muscle. Unintentional weight loss — losing weight without trying — is a clinical warning sign associated with malignancy, depression, medication side effects, malabsorption, and accelerated frailty. Any unintentional weight loss of 5% or more in 6 months in an older adult warrants medical evaluation." } },
      { "@type": "Question", "name": "Why does BMI become less accurate in older adults?", "acceptedAnswer": { "@type": "Answer", "text": "BMI becomes less accurate in older adults for several reasons: height decreases with age due to spinal compression (making BMI appear higher than it is), muscle is replaced by fat without changing weight (making BMI look normal when body composition is poor), and excess fluid from conditions like oedema can inflate weight. These factors make waist circumference and muscle strength tests better indicators of health risk in people over 65." } }
    ]
