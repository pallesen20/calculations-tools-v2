---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';
import RelatedTools from '../../../components/RelatedTools.astro';
import RelatedGlossaryTerms from '../../../components/RelatedGlossaryTerms.astro';
import type { Source } from '../../../components/Sources.astro';

const f = {
  metric:   "$$\\text{BMI} = \\frac{\\text{weight (kg)}}{\\text{height (m)}^2}$$",
  imperial: "$$\\text{BMI} = \\frac{703 \\times \\text{weight (lb)}}{\\text{height (in)}^2}$$",
  ffmi:     "$$\\text{FFMI} = \\frac{\\text{lean mass (kg)}}{\\text{height (m)}^2}$$",
  leanmass: "$$\\text{Lean mass (kg)} = \\text{weight (kg)} \\times (1 - \\text{body fat fraction})$$",
};

const tocItems = [
  { id: 'how-to-use',        label: 'How to use' },
  { id: 'normal-bmi-men',    label: 'What is a normal BMI for men?' },
  { id: 'bmi-chart',         label: 'BMI chart for men' },
  { id: 'bmi-by-age',        label: 'BMI by age for men' },
  { id: 'men-vs-women',      label: 'Why BMI reads differently for men' },
  { id: 'muscle-problem',    label: 'The muscle problem' },
  { id: 'waist-circumference', label: 'Waist circumference for men' },
  { id: 'testosterone',      label: 'The testosterone connection' },
  { id: 'better-metrics',    label: 'Better metrics for men' },
  { id: 'faq',               label: 'FAQs' },
  { id: 'related-tools',     label: 'Related tools' },
];

const sources: Source[] = [
  {
    author: 'Centers for Disease Control and Prevention (NCHS)',
    title: 'FastStats: Body Measurements',
    journal: 'CDC National Center for Health Statistics',
    year: 2024,
    url: 'https://www.cdc.gov/nchs/fastats/body-measurements.htm',
  },
  {
