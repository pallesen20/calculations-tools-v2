    journal: 'BJC',
    year: 2021,
    url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC9666096/',
  },
  {
    author: 'Flegal KM, Kit BK, Orpana H, Graubard BI',
    title: 'Association of all-cause mortality with overweight and obesity using standard body mass index categories',
