    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "BMI Calculator for Men",
    "url": "https://calculations.tools/health/bmi-calculator/men",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Any",
    "description": "Free BMI calculator for men with metric and imperial support. Shows BMI value, category, healthy weight range for your height, and how far you are from the Normal weight range.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
