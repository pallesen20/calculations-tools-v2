    title: 'Low testosterone in men with type 2 diabetes: significance and treatment',
    journal: 'Journal of Clinical Endocrinology & Metabolism',
    year: 2011,
    url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC3255339/',
  },
  {
    author: 'Bhasin S, Travison TG, Storer TW, et al.',
    title: 'Effect of testosterone supplementation with and without a dual 5alpha-reductase inhibitor on fat-free mass in men with suppressed testosterone production',
    journal: 'JAMA',
