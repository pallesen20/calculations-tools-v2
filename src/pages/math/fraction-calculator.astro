---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import Formula from '../../components/Formula.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const f = {
  add:        "$$\\frac{a}{b} + \\frac{c}{d} = \\frac{a \\times d + c \\times b}{b \\times d}$$",
  addEx:      "$$\\frac{3}{4} + \\frac{1}{2} = \\frac{3 \\times 2 + 1 \\times 4}{4 \\times 2} = \\frac{6 + 4}{8} = \\frac{10}{8} = \\frac{5}{4}$$",
  sub:        "$$\\frac{a}{b} - \\frac{c}{d} = \\frac{a \\times d - c \\times b}{b \\times d}$$",
  subEx:      "$$\\frac{5}{6} - \\frac{1}{4} = \\frac{5 \\times 4 - 1 \\times 6}{6 \\times 4} = \\frac{20 - 6}{24} = \\frac{14}{24} = \\frac{7}{12}$$",
  mul:        "$$\\frac{a}{b} \\times \\frac{c}{d} = \\frac{a \\times c}{b \\times d}$$",
  mulEx:      "$$\\frac{2}{3} \\times \\frac{3}{5} = \\frac{2 \\times 3}{3 \\times 5} = \\frac{6}{15} = \\frac{2}{5}$$",
  div:        "$$\\frac{a}{b} \\div \\frac{c}{d} = \\frac{a}{b} \\times \\frac{d}{c} = \\frac{a \\times d}{b \\times c}$$",
  divEx:      "$$\\frac{3}{4} \\div \\frac{2}{5} = \\frac{3}{4} \\times \\frac{5}{2} = \\frac{3 \\times 5}{4 \\times 2} = \\frac{15}{8}$$",
  simplify:   "$$\\frac{a}{b} \\div \\gcd(a,b) = \\frac{a / \\gcd(a,b)}{b / \\gcd(a,b)}$$",
  simplifyEx: "$$\\frac{18}{24}: \\gcd(18,24) = 6 \\implies \\frac{18 \\div 6}{24 \\div 6} = \\frac{3}{4}$$",
  toDec:      "$$\\text{Decimal} = \\frac{\\text{Numerator}}{\\text{Denominator}}$$",
  toPct:      "$$\\text{Percentage} = \\frac{\\text{Numerator}}{\\text{Denominator}} \\times 100$$",
};

const tocItems = [
  { id: 'how-to-use',   label: 'How to use this calculator' },
  { id: 'adding',       label: 'Adding fractions' },
  { id: 'subtracting',  label: 'Subtracting fractions' },
  { id: 'multiplying',  label: 'Multiplying fractions' },
  { id: 'dividing',     label: 'Dividing fractions' },
  { id: 'simplifying',  label: 'Simplifying fractions' },
  { id: 'converting',   label: 'Converting to decimal & percent' },
  { id: 'mixed',        label: 'Mixed numbers' },
  { id: 'common-mistakes', label: 'Common mistakes' },
  { id: 'faq',          label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Fraction Calculator",
    "url": "https://calculations.tools/math/fraction-calculator",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "description": "Add, subtract, multiply, or divide any two fractions. Also simplifies fractions and converts to decimal and percentage with step-by-step workings.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to add fractions",
    "description": "Add two fractions with unlike denominators in three steps.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Find a common denominator", "text": "Multiply the two denominators together (or find their LCM) to get a common denominator." },
      { "@type": "HowToStep", "position": 2, "name": "Convert both fractions", "text": "Multiply each numerator by the factor that makes its denominator equal to the common denominator." },
      { "@type": "HowToStep", "position": 3, "name": "Add the numerators and simplify", "text": "Add the two new numerators, keep the common denominator, then simplify by dividing both by their GCD." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you add fractions with different denominators?",
        "acceptedAnswer": { "@type": "Answer", "text": "Find a common denominator (the LCM of both denominators), convert each fraction, then add the numerators. For example: 1/3 + 1/4 = 4/12 + 3/12 = 7/12." }
      },
      {
        "@type": "Question",
        "name": "How do you multiply fractions?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply the numerators together and multiply the denominators together, then simplify. For example: 2/3 × 3/5 = 6/15 = 2/5." }
      },
      {
        "@type": "Question",
        "name": "How do you divide fractions?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply the first fraction by the reciprocal of the second fraction. Flip the second fraction (swap numerator and denominator), then multiply. For example: 3/4 ÷ 2/5 = 3/4 × 5/2 = 15/8." }
      },
      {
        "@type": "Question",
        "name": "How do you simplify a fraction?",
        "acceptedAnswer": { "@type": "Answer", "text": "Find the greatest common divisor (GCD) of the numerator and denominator, then divide both by it. For example: 18/24 → GCD(18,24) = 6 → 18÷6 / 24÷6 = 3/4." }
      },
      {
        "@type": "Question",
        "name": "How do you convert a fraction to a decimal?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide the numerator by the denominator. For example: 3/4 = 3 ÷ 4 = 0.75." }
      },
      {
        "@type": "Question",
        "name": "How do you convert a fraction to a percentage?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide the numerator by the denominator, then multiply by 100. For example: 3/4 = 0.75 × 100 = 75%." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Fraction Calculator"
  metaTitle="Fraction Calculator | Add, Subtract, Multiply & Divide ᐅ"
  description="Add, subtract, multiply, or divide any two fractions instantly. Also simplifies fractions and converts to decimal and percentage. Step-by-step workings shown."
  canonical="https://calculations.tools/math/fraction-calculator"
  tocItems={tocItems}
  schema={schema}
  embedSlug="fraction-calculator"
>
  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container bmi-container">
        <div class="calculator-header">
          <h2>Fraction Calculator</h2>
          <p>Add, subtract, multiply, divide, or simplify</p>
        </div>

        <div class="fc-ops">
          <button class="fc-op-btn active" data-op="add">+ Add</button>
          <button class="fc-op-btn" data-op="subtract">− Subtract</button>
          <button class="fc-op-btn" data-op="multiply">× Multiply</button>
          <button class="fc-op-btn" data-op="divide">÷ Divide</button>
          <button class="fc-op-btn" data-op="simplify">Simplify</button>
        </div>

        <div class="fc-inputs">
          <div class="fc-fraction">
            <input type="text" inputmode="decimal" id="fc-n1" class="fc-frac-input" placeholder="3" />
            <div class="fc-bar"></div>
            <input type="text" inputmode="decimal" id="fc-d1" class="fc-frac-input" placeholder="4" />
          </div>
          <div class="fc-op-symbol" id="fc-op-symbol">+</div>
          <div class="fc-fraction" id="fc-fraction2">
            <input type="text" inputmode="decimal" id="fc-n2" class="fc-frac-input" placeholder="1" />
            <div class="fc-bar"></div>
            <input type="text" inputmode="decimal" id="fc-d2" class="fc-frac-input" placeholder="2" />
          </div>
        </div>

        <div id="fc-result" class="lbm-result hidden">
          <div class="fc-result-fraction">
            <span id="fc-res-n" class="fc-res-num">—</span>
            <div class="fc-res-bar" id="fc-res-bar"></div>
            <span id="fc-res-d" class="fc-res-den">—</span>
          </div>
          <div class="lbm-primary-lbl">Result (simplified)</div>

          <div class="lbm-cards">
            <div class="lbm-card hidden" id="fc-mixed-card">
              <div class="lbm-card-val" id="fc-mixed">—</div>
              <div class="lbm-card-lbl">Mixed number</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="fc-decimal">—</div>
              <div class="lbm-card-lbl">Decimal</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="fc-percent">—</div>
              <div class="lbm-card-lbl">Percentage</div>
            </div>
          </div>

          <div class="pi-steps">
            <div class="pi-steps-title">Step-by-step</div>
            <div class="pi-step hidden" id="fc-step1-row">
              <span class="pi-step-label"></span>
              <span class="pi-step-val"></span>
            </div>
            <div class="pi-step hidden" id="fc-step2-row">
              <span class="pi-step-label"></span>
              <span class="pi-step-val"></span>
            </div>
            <div class="pi-step hidden" id="fc-step3-row">
              <span class="pi-step-label"></span>
              <span class="pi-step-val"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script src="/js/fraction-calculator.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <p class="answer-box-label">Quick rules</p>
        <p><strong>Add/subtract:</strong> find a common denominator, convert, then add/subtract numerators. <strong>Multiply:</strong> numerator × numerator over denominator × denominator. <strong>Divide:</strong> multiply by the reciprocal. <strong>Simplify:</strong> divide both parts by their GCD.</p>
      </div>

      <h2 id="how-to-use">How to use this calculator</h2>
      <p>Select an operation using the buttons at the top, then enter the numerator and denominator for each fraction. Results appear instantly: the simplified fraction, mixed number (when applicable), decimal equivalent, and percentage. The step-by-step panel shows how the result was reached. For <strong>Simplify</strong>, only one fraction is needed.</p>

      <h2 id="adding">Adding fractions</h2>
      <p>To add two fractions, both must share a common denominator. The standard approach is to cross-multiply to create equivalent fractions with the same denominator, then add the numerators:</p>

      <Formula expr={f.add} />

      <h3>Example</h3>
      <p>Add ¾ and ½:</p>
      <Formula expr={f.addEx} />
      <p>The result 10/8 simplifies to <strong>5/4</strong> (or 1¼ as a mixed number) because GCD(10, 8) = 2.</p>

      <p>The calculator uses the <strong>least common multiple (LCM)</strong> of the two denominators as the common denominator, which produces smaller intermediate numbers and avoids unnecessary simplification steps.</p>

      <h2 id="subtracting">Subtracting fractions</h2>
      <p>Subtraction follows the same common-denominator logic as addition — only the sign between the numerators changes:</p>

      <Formula expr={f.sub} />

      <h3>Example</h3>
      <p>Subtract ¼ from 5/6:</p>
      <Formula expr={f.subEx} />
      <p>GCD(14, 24) = 2, so 14/24 simplifies to <strong>7/12</strong>.</p>

      <h2 id="multiplying">Multiplying fractions</h2>
      <p>Multiplication is the most straightforward fraction operation — no common denominator is required. Multiply numerators together and denominators together, then simplify:</p>

      <Formula expr={f.mul} />

      <h3>Example</h3>
      <p>Multiply ⅔ by 3/5:</p>
      <Formula expr={f.mulEx} />
      <p>GCD(6, 15) = 3, so 6/15 simplifies to <strong>2/5</strong>.</p>

      <p>A useful shortcut when multiplying is to <strong>cross-cancel</strong> before multiplying: if a numerator and a different denominator share a common factor, divide both by that factor first. In the example above, the 3 in the numerator and the 3 in the denominator cancel to give 2/5 directly.</p>

      <h2 id="dividing">Dividing fractions</h2>
      <p>Dividing by a fraction is the same as multiplying by its reciprocal — flip the second fraction and multiply:</p>

      <Formula expr={f.div} />

      <h3>Example</h3>
      <p>Divide ¾ by 2/5:</p>
      <Formula expr={f.divEx} />
      <p>The result <strong>15/8</strong> is already fully simplified (GCD = 1), and as a mixed number it is 1⅞.</p>

      <h2 id="simplifying">Simplifying (reducing) fractions</h2>
      <p>A fraction is in its simplest form when the numerator and denominator share no common factor other than 1. The standard method uses the <strong>greatest common divisor (GCD)</strong>:</p>

      <Formula expr={f.simplify} />

      <h3>Example</h3>
      <Formula expr={f.simplifyEx} />

      <p>The GCD can be found using the Euclidean algorithm: divide the larger number by the smaller, then replace the larger with the smaller and the smaller with the remainder, repeating until the remainder is zero. The last non-zero remainder is the GCD.</p>

      <h3>Simplification reference</h3>
      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Fraction</th><th>GCD</th><th>Simplified</th><th>Decimal</th></tr>
          </thead>
          <tbody>
            <tr><td>2/4</td><td>2</td><td>1/2</td><td>0.5</td></tr>
            <tr><td>4/8</td><td>4</td><td>1/2</td><td>0.5</td></tr>
            <tr><td>6/9</td><td>3</td><td>2/3</td><td>0.6667</td></tr>
            <tr><td>12/16</td><td>4</td><td>3/4</td><td>0.75</td></tr>
            <tr><td>15/20</td><td>5</td><td>3/4</td><td>0.75</td></tr>
            <tr><td>18/24</td><td>6</td><td>3/4</td><td>0.75</td></tr>
            <tr><td>20/30</td><td>10</td><td>2/3</td><td>0.6667</td></tr>
            <tr><td>36/48</td><td>12</td><td>3/4</td><td>0.75</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="converting">Converting fractions to decimal and percentage</h2>
      <p>Every fraction represents a division. Converting is straightforward:</p>

      <Formula expr={f.toDec} />
      <Formula expr={f.toPct} />

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Fraction</th><th>Decimal</th><th>Percentage</th></tr>
          </thead>
          <tbody>
            <tr><td>1/2</td><td>0.5</td><td>50%</td></tr>
            <tr><td>1/3</td><td>0.3333…</td><td>33.33…%</td></tr>
            <tr><td>1/4</td><td>0.25</td><td>25%</td></tr>
            <tr><td>1/5</td><td>0.2</td><td>20%</td></tr>
            <tr><td>2/3</td><td>0.6667…</td><td>66.67…%</td></tr>
            <tr><td>3/4</td><td>0.75</td><td>75%</td></tr>
            <tr><td>3/5</td><td>0.6</td><td>60%</td></tr>
            <tr><td>7/8</td><td>0.875</td><td>87.5%</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="mixed">Mixed numbers</h2>
      <p>A mixed number combines a whole number and a proper fraction — for example, 1¾ means 1 + ¾ = 7/4 as an improper fraction. The calculator shows the mixed-number form whenever the result is an improper fraction (numerator greater than denominator).</p>

      <p>To convert a mixed number to an improper fraction before entering it into the calculator: multiply the whole number by the denominator and add the numerator. For 2⅗: (2 × 5) + 3 = 13, so 2⅗ = 13/5.</p>

      <h2 id="common-mistakes">Common mistakes</h2>

      <h3>Adding denominators instead of finding a common one</h3>
      <p>A very common error: ½ + ⅓ ≠ 2/5. You cannot add ½ and ⅓ by adding 1+1=2 and 2+3=5. The correct answer is 3/6 + 2/6 = 5/6.</p>

      <h3>Forgetting to simplify</h3>
      <p>An unsimplified fraction like 6/8 is not wrong, but it is not in its standard form. Always check whether GCD(numerator, denominator) > 1 and divide both by it. 6/8 → GCD = 2 → 3/4.</p>

      <h3>Dividing incorrectly — not flipping the second fraction</h3>
      <p>To divide, flip the <em>second</em> fraction (not the first) and multiply. ¾ ÷ ⅖ becomes ¾ × 5/2 = 15/8. A common error is to flip the first fraction instead.</p>

      <h3>Not applying sign rules to negative fractions</h3>
      <p>A negative fraction can be written three ways: −a/b = a/(−b) = −(a/b). When multiplying or dividing negative fractions, count the total number of negative signs — an odd count gives a negative result, even gives a positive.</p>

      <h2 id="faq">Frequently asked questions</h2>

      <h3>How do you add fractions with different denominators?</h3>
      <p>Find the least common multiple (LCM) of both denominators. Convert each fraction so both have that denominator, then add the numerators. Example: 1/3 + 1/4 → LCM = 12 → 4/12 + 3/12 = 7/12.</p>

      <h3>How do you multiply fractions?</h3>
      <p>Multiply numerator × numerator and denominator × denominator, then simplify. No common denominator is needed. Example: 2/3 × 3/5 = 6/15 = 2/5.</p>

      <h3>How do you divide fractions?</h3>
      <p>Multiply the first fraction by the reciprocal of the second: a/b ÷ c/d = a/b × d/c. Example: 3/4 ÷ 2/5 = 3/4 × 5/2 = 15/8.</p>

      <h3>How do you simplify a fraction?</h3>
      <p>Divide both numerator and denominator by their greatest common divisor (GCD). Example: 18/24 → GCD = 6 → 3/4.</p>

      <h3>How do you convert a fraction to a decimal?</h3>
      <p>Divide the numerator by the denominator. Example: 3/4 = 3 ÷ 4 = 0.75.</p>

      <h3>How do you convert a fraction to a percentage?</h3>
      <p>Divide the numerator by the denominator, then multiply by 100. Example: 3/4 = 0.75 × 100 = 75%.</p>

      <h3>What is an improper fraction?</h3>
      <p>An improper fraction has a numerator larger than (or equal to) its denominator — for example, 7/4. It is equivalent to a mixed number: 7/4 = 1¾. Both forms are mathematically correct; improper fractions are often easier to work with in calculations.</p>

      <h2 id="related-tools">Related tools</h2>
      <RelatedTools tools={[
        { path: '/math/percentage-calculator',                      blurb: 'Calculate percentages, percentage increases, decreases, and more.' },
        { path: '/math/percentage-calculator/fraction-to-percent',  blurb: 'Convert any fraction to a percentage — shows the decimal and step-by-step workings.' },
        { path: '/math/percentage-calculator/decimal-to-percent',   blurb: 'Convert any decimal to a percentage — multiply by 100.' },
        { path: '/math/percentage-calculator/change',               blurb: 'Percentage change calculator — covers both increases and decreases.' },
        { path: '/date-calculator',                                 blurb: 'Calculate the number of days or months between two dates.' },
      ]} />

    </div>
  </div>

</CalculatorLayout>
