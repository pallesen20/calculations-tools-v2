---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

const f = {
  def:      "$$\\text{LCD}(b, d) = \\text{LCM}(b, d) = \\frac{|b \\times d|}{\\gcd(b, d)}$$",
  ex1:      "$$\\text{LCD}(4, 6) = \\frac{4 \\times 6}{\\gcd(4,6)} = \\frac{24}{2} = 12$$",
  ex2:      "$$\\text{LCD}(3, 4) = \\frac{3 \\times 4}{\\gcd(3,4)} = \\frac{12}{1} = 12$$",
  prime:    "$$\\text{LCD}(12, 18): \\quad 12 = 2^2 \\times 3, \\quad 18 = 2 \\times 3^2 \\implies \\text{LCD} = 2^2 \\times 3^2 = 36$$",
  three:    "$$\\text{LCD}(4, 6, 10) = \\text{LCM}(4, \\text{LCM}(6, 10)) = \\text{LCM}(4, 30) = 60$$",
};

const tocItems = [
  { id: 'how-to-use',   label: 'How to use' },
  { id: 'definition',   label: 'What is the LCD?' },
  { id: 'formula',      label: 'LCD formula' },
  { id: 'prime-method', label: 'Prime factorisation method' },
  { id: 'three-denom',  label: 'Three or more denominators' },
  { id: 'examples',     label: 'Worked examples' },
  { id: 'why-use',      label: 'Why LCD matters' },
  { id: 'common-mistakes', label: 'Common mistakes' },
  { id: 'faq',          label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "LCD Calculator — Least Common Denominator",
    "url": "https://calculations.tools/math/fraction-calculator/lcd",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "description": "Find the Least Common Denominator of two or three fractions. Uses the LCM formula, shows prime factorisation, and converts each fraction to the LCD.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the LCD (Least Common Denominator)?",
        "acceptedAnswer": { "@type": "Answer", "text": "The LCD is the smallest number that all the denominators of a set of fractions divide into evenly. It equals the LCM (Lowest Common Multiple) of those denominators. Using the LCD to add or subtract fractions keeps numbers smaller than using the product of denominators." }
      },
      {
        "@type": "Question",
        "name": "How do you find the LCD?",
        "acceptedAnswer": { "@type": "Answer", "text": "Find the GCD of the denominators, then divide the product of the denominators by the GCD: LCD = (a × b) / GCD(a, b). Alternatively, find the prime factorisation of each denominator and take the highest power of each prime factor." }
      },
      {
        "@type": "Question",
        "name": "What is the LCD of 1/4 and 1/6?",
        "acceptedAnswer": { "@type": "Answer", "text": "The LCD of 4 and 6 is 12. GCD(4,6) = 2, so LCD = (4 × 6) / 2 = 12. Convert: 1/4 → 3/12 and 1/6 → 2/12." }
      },
      {
        "@type": "Question",
        "name": "Is the LCD the same as the LCM?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. The LCD of a set of fractions is the LCM of their denominators. The terms are used interchangeably — LCD specifically applies to fractions, LCM to integers." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="LCD Calculator - Least Common Denominator"
  metaTitle="LCD Calculator | Least Common Denominator of Fractions"
  description="Find the Least Common Denominator (LCD) of two or three fractions instantly. Shows prime factorisation, the LCM formula, and each fraction converted to the LCD."
  canonical="https://calculations.tools/math/fraction-calculator/lcd"
  tocItems={tocItems}
  schema={schema}
  embedSlug="lcd-calculator"
  ogFormula="LCD = LCM of all denominators (via prime factorization)"
  ogExample="LCD of 1/4 and 1/6: LCM(4, 6) = 12"
>
  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container bmi-container">
        <div class="calculator-header">
          <h2>Calculate Least Common Denominator</h2>
          <p>Find the Least Common Denominator of 2–3 fractions</p>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="lcd-d1">First denominator</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="lcd-d1" class="bmi-input" placeholder="e.g. 4" />
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="lcd-d2">Second denominator</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="lcd-d2" class="bmi-input" placeholder="e.g. 6" />
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="lcd-d3">Third denominator (optional)</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="lcd-d3" class="bmi-input" placeholder="optional" />
          </div>
        </div>

        <div id="lcd-result" class="lbm-result hidden">
          <div class="lbm-primary">
            <span class="lbm-primary-val" id="lcd-value">—</span>
          </div>
          <div class="lbm-primary-lbl">Least Common Denominator (LCD)</div>

          <div class="pi-steps">
            <div class="pi-steps-title">Prime factorisation & equivalent fractions</div>
            <div class="pi-step">
              <span class="pi-step-label">Denominator 1 factors</span>
              <span class="pi-step-val" id="lcd-f1">—</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">Denominator 2 factors</span>
              <span class="pi-step-val" id="lcd-f2">—</span>
            </div>
            <div class="pi-step hidden" id="lcd-third-row">
              <span class="pi-step-label">Denominator 3 factors</span>
              <span class="pi-step-val" id="lcd-f3">—</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">Fraction 1 → LCD form</span>
              <span class="pi-step-val" id="lcd-eq1">—</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">Fraction 2 → LCD form</span>
              <span class="pi-step-val" id="lcd-eq2">—</span>
            </div>
            <div class="pi-step hidden" id="lcd-eq3-row">
              <span class="pi-step-label">Fraction 3 → LCD form</span>
              <span class="pi-step-val" id="lcd-eq3">—</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script src="/js/lcd-calculator.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <p class="answer-box-label">Quick answer</p>
        <p>The LCD (Least Common Denominator) is the <strong>smallest number all denominators divide into evenly</strong> — the LCM of the denominators. For 1/4 and 1/6: LCD(4,6) = 12. Formula: LCD = (a × b) ÷ GCD(a, b).</p>
      </div>

      <h2 id="how-to-use">How to use this calculator</h2>
      <p>Enter the denominators of two or three fractions (the denominator values only — not the full fractions). The calculator returns the LCD, the prime factorisation of each denominator, and shows each denominator scaled to an equivalent fraction with the LCD.</p>

      <h2 id="definition">What is the LCD?</h2>
      <p>The Least Common Denominator (LCD) is the smallest positive integer that each of the given denominators divides into without a remainder. It is identical to the LCM (Lowest Common Multiple) of those denominators. The LCD is used to convert fractions to a common denominator so they can be added, subtracted, or compared directly.</p>

      <h2 id="formula">LCD formula</h2>
      <p>The fastest two-denominator method uses the GCD:</p>
      <Formula expr={f.def} />
      <Formula expr={f.ex1} />
      <p>GCD(4,6) = 2. LCD = (4 × 6) ÷ 2 = 12. Verify: 4 divides 12 (12/4 = 3 ✓) and 6 divides 12 (12/6 = 2 ✓).</p>
      <Formula expr={f.ex2} />
      <p>GCD(3,4) = 1 (coprime), so LCD = 3 × 4 = 12.</p>

      <h2 id="prime-method">Prime factorisation method</h2>
      <p>Factorise each denominator, then take the highest power of each prime factor across all factorisations:</p>
      <Formula expr={f.prime} />
      <p>12 = 2² × 3 and 18 = 2 × 3². Highest powers: 2² and 3². LCD = 4 × 9 = 36. Verify: 12 | 36 ✓ and 18 | 36 ✓.</p>

      <h2 id="three-denom">Three or more denominators</h2>
      <p>Extend by computing LCM pairwise:</p>
      <Formula expr={f.three} />
      <p>First, LCM(6,10): GCD(6,10) = 2, LCM = 60/2 = 30. Then LCM(4,30): GCD(4,30) = 2, LCM = 120/2 = 60. LCD = 60.</p>

      <div class="responsive-table">
        <table>
          <thead><tr><th>Denominators</th><th>GCD</th><th>LCD</th><th>Equivalent fractions</th></tr></thead>
          <tbody>
            <tr><td>2, 3</td><td>1</td><td>6</td><td>1/2 → 3/6, 1/3 → 2/6</td></tr>
            <tr><td>4, 6</td><td>2</td><td>12</td><td>1/4 → 3/12, 1/6 → 2/12</td></tr>
            <tr><td>3, 5</td><td>1</td><td>15</td><td>2/3 → 10/15, 3/5 → 9/15</td></tr>
            <tr><td>8, 12</td><td>4</td><td>24</td><td>5/8 → 15/24, 7/12 → 14/24</td></tr>
            <tr><td>6, 9</td><td>3</td><td>18</td><td>5/6 → 15/18, 4/9 → 8/18</td></tr>
            <tr><td>4, 5, 6</td><td>—</td><td>60</td><td>1/4→15/60, 1/5→12/60, 1/6→10/60</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="why-use">Why the LCD matters</h2>
      <p>Adding 1/4 + 1/6 without a common denominator is impossible directly. Using the product (24) also works: 6/24 + 4/24 = 10/24 = 5/12. But using the LCD (12) keeps numbers smaller: 3/12 + 2/12 = 5/12 — no simplification needed. The LCD minimises the arithmetic involved and reduces the chance of error.</p>
      <p>The LCD is also the right denominator to use when <strong>comparing fractions</strong>: converting all fractions to the LCD makes comparison by numerator immediate.</p>

      <h2 id="common-mistakes">Common mistakes</h2>

      <h3>Using the product instead of the LCD</h3>
      <p>For 3/4 + 1/6, using 4 × 6 = 24 gives 18/24 + 4/24 = 22/24, which simplifies to 11/12. Correct, but more work. LCD = 12 gives 9/12 + 2/12 = 11/12 directly — no simplification needed.</p>

      <h3>Confusing LCD with GCD</h3>
      <p>GCD is the largest number that divides both values. LCD is the smallest number that both values divide into. GCD × LCM = product of the two numbers. They are related but opposite concepts.</p>

      <h2 id="faq">Frequently asked questions</h2>

      <h3>What is the LCD (Least Common Denominator)?</h3>
      <p>The smallest number that all denominators divide into evenly. It equals the LCM of the denominators.</p>

      <h3>How do you find the LCD?</h3>
      <p>Use LCD = (a × b) ÷ GCD(a, b), or factorise each denominator and take the highest power of each prime.</p>

      <h3>What is the LCD of 1/4 and 1/6?</h3>
      <p>12. GCD(4,6) = 2, so LCD = (4×6)/2 = 12. Convert: 3/12 and 2/12.</p>

      <h3>Is the LCD the same as the LCM?</h3>
      <p>Yes. LCD of fractions = LCM of their denominators. The terms are used interchangeably.</p>

      <h2 id="related-tools">Related tools</h2>
      <RelatedTools tools={[
        { path: '/math/fraction-calculator/add',       blurb: 'Add fractions using the LCD method — calculated automatically.' },
        { path: '/math/fraction-calculator/subtract',  blurb: 'Subtract fractions with full LCD workings.' },
        { path: '/math/fraction-calculator/compare',   blurb: 'Compare two fractions — uses LCD to convert to a common base.' },
        { path: '/math/fraction-calculator/equivalent', blurb: 'Generate equivalent fractions for any denominator.' },
        { path: '/math/fraction-calculator/simplify',  blurb: 'Reduce any fraction to lowest terms using the GCD.' },
        { path: '/math/fraction-calculator',           blurb: 'The main fraction calculator — add, subtract, multiply, divide.' },
      ]} />

    </div>
  </div>

</CalculatorLayout>
