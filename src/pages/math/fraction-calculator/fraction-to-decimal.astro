---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

const f = {
  formula:    "$$\\text{Decimal} = \\frac{\\text{Numerator}}{\\text{Denominator}}$$",
  termEx:     "$$\\frac{3}{4} = 3 \\div 4 = 0.75$$",
  repEx:      "$$\\frac{1}{3} = 0.\\overline{3} = 0.333\\ldots$$",
  repRule:    "$$\\frac{p}{q} \\text{ terminates} \\iff q \\text{ has only factors of 2 and 5 after simplification}$$",
  longDiv:    "$$\\frac{7}{12}: \\quad 7 \\div 12 = 0.58\\overline{3}$$",
  pct:        "$$\\text{Percentage} = \\frac{\\text{Numerator}}{\\text{Denominator}} \\times 100$$",
};

const tocItems = [
  { id: 'how-to-use',    label: 'How to use' },
  { id: 'formula',       label: 'Fraction to decimal formula' },
  { id: 'terminating',   label: 'Terminating decimals' },
  { id: 'repeating',     label: 'Repeating decimals' },
  { id: 'long-division', label: 'Long division method' },
  { id: 'examples',      label: 'Worked examples' },
  { id: 'reference',     label: 'Common fraction–decimal table' },
  { id: 'common-mistakes', label: 'Common mistakes' },
  { id: 'faq',           label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Fraction to Decimal Calculator",
    "url": "https://calculations.tools/math/fraction-calculator/fraction-to-decimal",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "description": "Convert any fraction to its decimal equivalent. Identifies terminating and repeating decimals, shows the repeating block, and converts to percentage.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you convert a fraction to a decimal?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide the numerator by the denominator. For example, 3/4 = 3 ÷ 4 = 0.75. If the division terminates, the decimal is exact. If it repeats, use bar notation to indicate the repeating block." }
      },
      {
        "@type": "Question",
        "name": "What is 1/3 as a decimal?",
        "acceptedAnswer": { "@type": "Answer", "text": "1/3 = 0.333… = 0.3̄. The digit 3 repeats infinitely. This is a repeating decimal, not a rounding — 1/3 cannot be expressed as a finite decimal." }
      },
      {
        "@type": "Question",
        "name": "How do you know if a fraction gives a terminating or repeating decimal?",
        "acceptedAnswer": { "@type": "Answer", "text": "Simplify the fraction first. If the denominator's only prime factors are 2 and 5, the decimal terminates. If the denominator has any other prime factor, the decimal repeats. For example, 3/8 terminates (8 = 2³), but 1/6 repeats (6 = 2 × 3)." }
      },
      {
        "@type": "Question",
        "name": "What is 5/8 as a decimal?",
        "acceptedAnswer": { "@type": "Answer", "text": "5/8 = 0.625. Since 8 = 2³ has only the factor 2, the decimal terminates. Long division: 5.000 ÷ 8 = 0.625." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Fraction to Decimal Calculator"
  metaTitle="Fraction to Decimal Calculator | Terminating & Repeating"
  description="Convert any fraction to its decimal equivalent. Identifies terminating and repeating decimals, shows the repeating block notation, percentage, and step-by-step workings."
  canonical="https://calculations.tools/math/fraction-calculator/fraction-to-decimal"
  tocItems={tocItems}
  schema={schema}
  embedSlug="fraction-to-decimal-calculator"
>
  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container bmi-container">
        <div class="calculator-header">
          <h2>Calculate Fraction to Decimal</h2>
          <p>Enter a fraction to convert it to a decimal</p>
        </div>

        <div class="fc-inputs" style="justify-content:center;">
          <div class="fc-fraction">
            <input type="text" inputmode="decimal" id="ftd-n" class="fc-frac-input" placeholder="1" />
            <div class="fc-bar"></div>
            <input type="text" inputmode="decimal" id="ftd-d" class="fc-frac-input" placeholder="3" />
          </div>
        </div>

        <div id="ftd-result" class="lbm-result hidden">
          <div class="lbm-primary">
            <span class="lbm-primary-val" id="ftd-decimal">—</span>
          </div>
          <div class="lbm-primary-lbl" id="ftd-type">—</div>

          <div class="lbm-cards">
            <div class="lbm-card">
              <div class="lbm-card-val" id="ftd-percent">—</div>
              <div class="lbm-card-lbl">Percentage</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="ftd-simplified">—</div>
              <div class="lbm-card-lbl">Simplified fraction</div>
            </div>
          </div>

          <div class="pi-steps">
            <div class="pi-steps-title">Step-by-step</div>
            <div class="pi-step">
              <span class="pi-step-label">Division</span>
              <span class="pi-step-val" id="ftd-step1">—</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">Result</span>
              <span class="pi-step-val" id="ftd-step2">—</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script src="/js/fraction-to-decimal-calculator.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <p class="answer-box-label">Quick answer</p>
        <p>To convert a fraction to a decimal: <strong>divide the numerator by the denominator</strong>. 3/4 = 3 ÷ 4 = 0.75. If division ends, the decimal terminates. If a remainder repeats, the decimal is repeating (e.g. 1/3 = 0.333…).</p>
      </div>

      <h2 id="how-to-use">How to use this calculator</h2>
      <p>Enter the numerator and denominator of any fraction. The calculator performs the division, identifies whether the result is terminating or repeating, shows the repeating block (if any), the percentage equivalent, and the simplified fraction.</p>

      <h2 id="formula">Fraction to decimal formula</h2>
      <p>The conversion is simply division:</p>
      <Formula expr={f.formula} />
      <Formula expr={f.termEx} />
      <p>Divide 3 by 4 using long division or a calculator. The quotient is the decimal equivalent.</p>

      <h2 id="terminating">Terminating decimals</h2>
      <p>A fraction produces a terminating decimal when — after simplifying to lowest terms — the denominator has <strong>only 2 and 5 as prime factors</strong>:</p>
      <Formula expr={f.repRule} />

      <div class="responsive-table">
        <table>
          <thead><tr><th>Denominator</th><th>Prime factors</th><th>Terminates?</th><th>Example</th></tr></thead>
          <tbody>
            <tr><td>2</td><td>2</td><td>Yes</td><td>1/2 = 0.5</td></tr>
            <tr><td>4</td><td>2²</td><td>Yes</td><td>3/4 = 0.75</td></tr>
            <tr><td>5</td><td>5</td><td>Yes</td><td>2/5 = 0.4</td></tr>
            <tr><td>8</td><td>2³</td><td>Yes</td><td>5/8 = 0.625</td></tr>
            <tr><td>20</td><td>2² × 5</td><td>Yes</td><td>7/20 = 0.35</td></tr>
            <tr><td>25</td><td>5²</td><td>Yes</td><td>3/25 = 0.12</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="repeating">Repeating decimals</h2>
      <p>When the denominator (in lowest terms) contains a prime factor other than 2 or 5, the decimal repeats:</p>
      <Formula expr={f.repEx} />
      <div class="responsive-table">
        <table>
          <thead><tr><th>Denominator</th><th>Other prime factors</th><th>Example</th><th>Repeating block</th></tr></thead>
          <tbody>
            <tr><td>3</td><td>3</td><td>1/3 = 0.333…</td><td>3</td></tr>
            <tr><td>6</td><td>3</td><td>1/6 = 0.1666…</td><td>6</td></tr>
            <tr><td>7</td><td>7</td><td>1/7 = 0.142857142857…</td><td>142857</td></tr>
            <tr><td>9</td><td>3</td><td>1/9 = 0.111…</td><td>1</td></tr>
            <tr><td>11</td><td>11</td><td>1/11 = 0.0909…</td><td>09</td></tr>
            <tr><td>12</td><td>3</td><td>7/12 = 0.5833…</td><td>3</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="long-division">Long division method</h2>
      <p>Long division traces the exact decimal digit by digit — and identifies repeating blocks when a remainder appears twice:</p>
      <Formula expr={f.longDiv} />
      <p>7 ÷ 12: 7.000000 ÷ 12. Steps: 70 ÷ 12 = 5 rem 10 → 100 ÷ 12 = 8 rem 4 → 40 ÷ 12 = 3 rem 4 → remainder 4 repeats. Result: 0.583333… = 0.58̄3̄.</p>

      <h2 id="examples">Worked examples</h2>

      <h3>Example 1: 5/8 (terminating)</h3>
      <p>5 ÷ 8 = 0.625. GCD(5,8) = 1 — already simplified. Denominator 8 = 2³ → terminates. Percentage: 62.5%.</p>

      <h3>Example 2: 2/3 (repeating)</h3>
      <p>2 ÷ 3 = 0.666… = 0.6̄. Repeating block "6". Percentage: 66.666…% ≈ 66.67%.</p>

      <h3>Example 3: 7/6 (improper, mixed repeating)</h3>
      <p>7 ÷ 6 = 1.1666… = 1.16̄. Non-repeating part after decimal: "1"; repeating block: "6". As percentage: 116.67%.</p>

      <h2 id="reference">Common fraction–decimal reference table</h2>
      <div class="responsive-table">
        <table>
          <thead><tr><th>Fraction</th><th>Decimal</th><th>Type</th><th>%</th></tr></thead>
          <tbody>
            <tr><td>1/2</td><td>0.5</td><td>Terminating</td><td>50%</td></tr>
            <tr><td>1/3</td><td>0.333…</td><td>Repeating</td><td>33.3%</td></tr>
            <tr><td>1/4</td><td>0.25</td><td>Terminating</td><td>25%</td></tr>
            <tr><td>1/5</td><td>0.2</td><td>Terminating</td><td>20%</td></tr>
            <tr><td>1/6</td><td>0.1666…</td><td>Repeating</td><td>16.7%</td></tr>
            <tr><td>1/7</td><td>0.142857…</td><td>Repeating (6-digit)</td><td>14.29%</td></tr>
            <tr><td>1/8</td><td>0.125</td><td>Terminating</td><td>12.5%</td></tr>
            <tr><td>2/3</td><td>0.666…</td><td>Repeating</td><td>66.7%</td></tr>
            <tr><td>3/4</td><td>0.75</td><td>Terminating</td><td>75%</td></tr>
            <tr><td>5/6</td><td>0.8333…</td><td>Repeating</td><td>83.3%</td></tr>
            <tr><td>7/8</td><td>0.875</td><td>Terminating</td><td>87.5%</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="common-mistakes">Common mistakes</h2>

      <h3>Rounding a repeating decimal</h3>
      <p>1/3 ≈ 0.33 is an approximation. The exact value is 0.333… If you need an exact result in calculations, keep it as a fraction.</p>

      <h3>Thinking all decimals terminate</h3>
      <p>Only fractions whose denominator (in lowest terms) has no prime factors other than 2 and 5 will produce a terminating decimal. 1/3, 1/6, 1/7 are all repeating.</p>

      <h2 id="faq">Frequently asked questions</h2>

      <h3>How do you convert a fraction to a decimal?</h3>
      <p>Divide the numerator by the denominator. The quotient is the decimal. If a remainder repeats, the decimal is repeating.</p>

      <h3>What is 1/3 as a decimal?</h3>
      <p>0.333… = 0.3̄ (repeating). It is not possible to express 1/3 as a finite decimal.</p>

      <h3>How do you know if a fraction gives a terminating or repeating decimal?</h3>
      <p>Simplify the fraction. If the denominator's prime factors are only 2 and 5, it terminates. Any other prime factor (3, 7, 11…) causes repetition.</p>

      <h3>What is 5/8 as a decimal?</h3>
      <p>0.625. Since 8 = 2³, the decimal terminates exactly.</p>

      <h2 id="related-tools">Related tools</h2>
      <RelatedTools tools={[
        { path: '/math/fraction-calculator/decimal-to-fraction',           blurb: 'Reverse: convert a decimal back to a fraction in lowest terms.' },
        { path: '/math/percentage-calculator/fraction-to-percent',         blurb: 'Convert any fraction directly to a percentage.' },
        { path: '/math/fraction-calculator/simplify',                      blurb: 'Reduce any fraction to its lowest terms using the GCD.' },
        { path: '/math/fraction-calculator',                               blurb: 'The main fraction calculator — add, subtract, multiply, divide.' },
        { path: '/math/fraction-calculator/compare',                       blurb: 'Compare two fractions to determine which is larger.' },
      ]} />

    </div>
  </div>

</CalculatorLayout>
