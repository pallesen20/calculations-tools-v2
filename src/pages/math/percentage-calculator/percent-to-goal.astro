---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

const f = {
  main:  "$$\\text{Percent to Goal} = \\frac{\\text{Current Value}}{\\text{Goal}} \\times 100$$",
  ex1:   "$$\\frac{750}{1{,}000} \\times 100 = 75\\%$$",
  ex2:   "$$\\frac{37{,}500}{50{,}000} \\times 100 = 75\\%$$",
  ex3:   "$$\\frac{8{,}234}{10{,}000} \\times 100 = 82.34\\%$$",
  over:  "$$\\frac{1{,}200}{1{,}000} \\times 100 = 120\\%$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use' },
  { id: 'formula',         label: 'Percent to goal formula' },
  { id: 'examples',        label: 'Worked examples' },
  { id: 'over-100',        label: 'When you exceed 100%' },
  { id: 'multiple-goals',  label: 'Tracking multiple goals' },
  { id: 'vs-pct-change',   label: 'Percent to goal vs percent change' },
  { id: 'common-mistakes', label: 'Common mistakes' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Percent to Goal Calculator",
    "url": "https://calculations.tools/math/percentage-calculator/percent-to-goal",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "description": "Calculate what percentage of a goal you have reached. Enter your current value and target to instantly see percent complete, remaining amount, and step-by-step workings.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to calculate percent to goal",
    "description": "Calculate what percentage of a target you have reached in two steps.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Divide", "text": "Divide the current value by the goal: Current ÷ Goal." },
      { "@type": "HowToStep", "position": 2, "name": "Multiply by 100", "text": "Multiply the result by 100 to express it as a percentage." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does percent to goal mean?",
        "acceptedAnswer": { "@type": "Answer", "text": "Percent to goal (also called percent of target or goal attainment %) shows what fraction of a target value you have achieved, expressed as a percentage. Formula: (Current ÷ Goal) × 100. If you have reached 750 out of a goal of 1,000, you are 75% of the way to your goal." }
      },
      {
        "@type": "Question",
        "name": "Can percent to goal exceed 100%?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. If the current value exceeds the goal, the result is above 100%, indicating over-achievement. For example, closing 1,200 deals against a target of 1,000 gives 120% of goal — a 20% over-attainment. Values above 100% are valid and desirable in sales and fundraising contexts." }
      },
      {
        "@type": "Question",
        "name": "How is percent to goal different from percent change?",
        "acceptedAnswer": { "@type": "Answer", "text": "Percent to goal measures how much of a target you have reached: Current ÷ Goal × 100. Percent change measures how much a value has grown from a starting point: (New − Old) ÷ Old × 100. Percent to goal uses the goal as the denominator; percent change uses the original value. A sales rep at 75% of goal is not the same as a 75% increase in sales." }
      },
      {
        "@type": "Question",
        "name": "How do I track progress across multiple goals?",
        "acceptedAnswer": { "@type": "Answer", "text": "For equal-weight goals, average the individual percent-to-goal values. For weighted goals, multiply each goal's attainment by its weight and sum: Weighted progress = Σ (weight_i × attainment_i). For example, if Goal A (weight 60%) is at 80% and Goal B (weight 40%) is at 50%, weighted progress = 0.60 × 80 + 0.40 × 50 = 48 + 20 = 68%." }
      },
      {
        "@type": "Question",
        "name": "What if my goal is a reduction (e.g. reducing costs)?",
        "acceptedAnswer": { "@type": "Answer", "text": "For reduction goals, reframe the current value as progress made: if you want to cut costs from $100,000 to $80,000 and you are currently at $88,000, the reduction achieved is $12,000 out of a $20,000 target — 60% of goal. Enter 12000 as current and 20000 as goal." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Percent to Goal Calculator"
  metaTitle="Percent to Goal Calculator | Track Progress %"
  description="Calculate what percentage of your goal you have reached. Enter a current value and target to see percent complete, remaining amount, and step-by-step workings."
  canonical="https://calculations.tools/math/percentage-calculator/percent-to-goal"
  tocItems={tocItems}
  schema={schema}
  embedSlug="percent-to-goal-calculator"
>
  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container bmi-container">
        <div class="calculator-header">
          <h2>Calculate Progress in Percentage</h2>
          <p>Enter your current value and goal to track progress</p>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="ptg-current">Current Value</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="ptg-current" class="bmi-input" placeholder="e.g. 750" />
          </div>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="ptg-goal">Goal</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="ptg-goal" class="bmi-input" placeholder="e.g. 1000" />
          </div>
        </div>

        <div id="ptg-result" class="lbm-result hidden">
          <div class="lbm-primary">
            <span class="lbm-primary-val" id="ptg-pct">—</span>
          </div>
          <div class="lbm-primary-lbl">Percent to Goal</div>

          <div class="lbm-cards">
            <div class="lbm-card">
              <div class="lbm-card-val" id="ptg-remaining">—</div>
              <div class="lbm-card-lbl">Progress status</div>
            </div>
          </div>

          <div class="pi-steps">
            <div class="pi-steps-title">How it was calculated</div>
            <div class="pi-step">
              <span class="pi-step-label">Step 1 — Divide</span>
              <span id="ptg-step1" class="pi-step-val">—</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">Step 2 — Multiply by 100</span>
              <span id="ptg-step2" class="pi-step-val">—</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script src="/js/percent-to-goal-calculator.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <p class="answer-box-label">Formula</p>
        <p>Percent to goal = <strong>(Current Value ÷ Goal) × 100</strong>. Divide what you have achieved by the target and multiply by 100. Results above 100% mean you have exceeded the goal.</p>
      </div>

      <h2 id="how-to-use">How to use this calculator</h2>
      <p>Enter your <strong>current value</strong> — the progress achieved so far — and your <strong>goal</strong> — the target to reach. The calculator returns the percent to goal, the amount remaining (or over-attainment), and a two-step breakdown.</p>
      <p>Use this calculator for any goal tracked as a number: sales quotas, fundraising targets, fitness goals, project milestones, or any scenario where you want to express progress as a percentage of a target. For a goal progress visualizer, see our <a href="/math/percentage-calculator/progress-tracker">progress tracker</a>.</p>

      <h2 id="formula">Percent to goal formula</h2>
      <p>The formula is a simple ratio expressed as a percentage:</p>
      <Formula expr={f.main} />
      <p>The denominator is always the <em>goal</em> (the target), not the starting point. This is what distinguishes percent to goal from percent change — there is no "starting point" in this calculation, only a current value relative to a fixed target.</p>

      <h2 id="examples">Worked examples</h2>

      <h3>Example 1: sales quota</h3>
      <p>A sales rep has closed 750 deals against a quarterly target of 1,000.</p>
      <Formula expr={f.ex1} />
      <p>They are at <strong>75% of goal</strong> with 250 deals remaining to reach 100%.</p>

      <h3>Example 2: fundraising campaign</h3>
      <p>A charity has raised $37,500 toward a $50,000 campaign target.</p>
      <Formula expr={f.ex2} />
      <p>The campaign is <strong>75% funded</strong>, with $12,500 still to raise.</p>

      <h3>Example 3: daily step goal</h3>
      <p>You have walked 8,234 steps toward a 10,000-step daily goal.</p>
      <Formula expr={f.ex3} />
      <p>You are at <strong>82.34% of goal</strong>, with 1,766 steps remaining.</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Current</th><th>Goal</th><th>% to Goal</th><th>Remaining</th></tr>
          </thead>
          <tbody>
            <tr><td>750</td><td>1,000</td><td>75%</td><td>250</td></tr>
            <tr><td>37,500</td><td>50,000</td><td>75%</td><td>12,500</td></tr>
            <tr><td>8,234</td><td>10,000</td><td>82.34%</td><td>1,766</td></tr>
            <tr><td>1,200</td><td>1,000</td><td>120%</td><td>−200 (over goal)</td></tr>
            <tr><td>500</td><td>500</td><td>100%</td><td>Goal reached</td></tr>
            <tr><td>0</td><td>1,000</td><td>0%</td><td>1,000</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="over-100">When you exceed 100%</h2>
      <p>A result above 100% is valid and means you have <strong>exceeded your goal</strong>. If a rep closes 1,200 deals against a 1,000-unit target:</p>
      <Formula expr={f.over} />
      <p>This represents <strong>120% attainment</strong> — 20% over the target. In sales compensation, over-attainment is often rewarded with accelerated commission rates. The formula handles any positive current value, including those above the goal.</p>
      <p>Note: if your goal itself is zero or negative, the formula breaks down mathematically (division by zero or inverted sign). In those cases, reframe the goal as a positive number representing the magnitude of the desired change.</p>

      <h2 id="multiple-goals">Tracking multiple goals</h2>
      <p>When you have several goals to track simultaneously, there are two approaches:</p>

      <h3>Simple average (equal-weight goals)</h3>
      <p>Calculate percent to goal for each metric separately, then take the arithmetic mean. Three goals at 60%, 80%, and 100% average to (60 + 80 + 100) / 3 = <strong>80% overall</strong>.</p>

      <h3>Weighted average (unequal-weight goals)</h3>
      <p>Multiply each goal's attainment by its assigned weight, then sum:</p>
      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Goal</th><th>Weight</th><th>Attainment</th><th>Contribution</th></tr>
          </thead>
          <tbody>
            <tr><td>Revenue</td><td>60%</td><td>80%</td><td>48%</td></tr>
            <tr><td>New customers</td><td>40%</td><td>50%</td><td>20%</td></tr>
            <tr><td><strong>Weighted total</strong></td><td><strong>100%</strong></td><td>—</td><td><strong>68%</strong></td></tr>
          </tbody>
        </table>
      </div>
      <p>OKR frameworks typically use a weighted or un-weighted average across key results. A common rule of thumb: achieving 70–80% of a stretch OKR is considered a good result.</p>

      <h2 id="vs-pct-change">Percent to goal vs percent change</h2>
      <p>These two calculations look similar but answer different questions:</p>
      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Metric</th><th>Formula</th><th>Denominator</th><th>Use case</th></tr>
          </thead>
          <tbody>
            <tr><td>Percent to goal</td><td>(Current ÷ Goal) × 100</td><td>The goal (target)</td><td>How far along toward a fixed target</td></tr>
            <tr><td>Percent change</td><td>((New − Old) ÷ Old) × 100</td><td>The original (starting) value</td><td>How much a value has grown or fallen</td></tr>
          </tbody>
        </table>
      </div>
      <p>Example: a sales rep started the quarter at 0 deals and reached 750 against a 1,000-unit goal. Percent to goal is 75%. Percent change from the previous quarter (when they had 500 deals) is (750 − 500) / 500 × 100 = +50%. Both are useful but answer different questions — progress toward a target vs. growth over time.</p>

      <h2 id="common-mistakes">Common mistakes</h2>

      <h3>Using the remaining amount instead of the current value</h3>
      <p>If your goal is 1,000 and you have reached 750, enter <strong>750</strong> (what you have), not 250 (what remains). Entering the remainder gives 250 / 1,000 = 25%, the inverse of the correct 75%.</p>

      <h3>Dividing by the remaining amount instead of the goal</h3>
      <p>The denominator is always the <em>goal</em>, not how much is left. 750 / 250 = 3.0 (300%), which is not meaningful here.</p>

      <h3>Confusing percent to goal with percent change</h3>
      <p>If you started the year at $200,000 revenue and the goal is $400,000, a current value of $300,000 is <strong>75% to goal</strong> — not a 50% increase (which would be the growth from $200,000 to $300,000).</p>

      <h3>Setting the goal to zero</h3>
      <p>Division by zero is undefined. A goal must be a non-zero number. If you are reducing something to zero (e.g. eliminating backlog), reframe: set the goal as the magnitude of the reduction you want to achieve, and the current value as how much of that reduction you have already made.</p>

      <h2 id="faq">Frequently asked questions</h2>

      <h3>What does percent to goal mean?</h3>
      <p>It expresses how much of a target you have achieved as a percentage: (Current ÷ Goal) × 100. It is also called "goal attainment rate," "percent of target," or "percent of quota."</p>

      <h3>Can percent to goal exceed 100%?</h3>
      <p>Yes. A value above 100% means over-achievement. Entering 1,200 against a goal of 1,000 gives 120% — 20% above the target.</p>

      <h3>How do I track progress across multiple goals?</h3>
      <p>For equal goals, average the individual attainment percentages. For weighted goals, multiply each attainment by its weight and sum. This is the weighted average method used in OKR and sales compensation frameworks.</p>

      <h3>How is percent to goal different from percent change?</h3>
      <p>Percent to goal divides by the target (goal). Percent change divides by the starting value (old value). They answer different questions: progress toward a fixed target vs. growth over a period.</p>

      <h3>What if my goal is a reduction (e.g. reducing defects)?</h3>
      <p>Reframe the goal as a positive magnitude. If you want to cut defects from 500 to 300 (a 200-unit reduction) and you are currently at 380 defects, you have reduced by 120 units out of a 200-unit goal — enter 120 as current and 200 as goal to get 60% of goal.</p>

      <h2 id="related-tools">Related tools</h2>
      <RelatedTools tools={[
        { path: '/math/percentage-calculator',                    blurb: 'The main percentage calculator — percentage of a number, increase, decrease, and more.' },
        { path: '/math/percentage-calculator/change',             blurb: 'Percent change calculator — measures relative change from a starting value over time.' },
        { path: '/math/percentage-calculator/increase',           blurb: 'Percent increase calculator — dedicated tool for positive percentage changes.' },
        { path: '/math/percentage-calculator/percentage-point',   blurb: 'Percentage point calculator — find the pp difference between two percentage values.' },
        { path: '/math/percentage-calculator/percent-error',      blurb: 'Percent error calculator — compare a measured value to a known theoretical standard.' },
        { path: '/math/percentage-calculator/average',            blurb: 'Average percentage calculator — arithmetic mean and weighted average of percentages.' },
      ]} />

    </div>
  </div>

</CalculatorLayout>
