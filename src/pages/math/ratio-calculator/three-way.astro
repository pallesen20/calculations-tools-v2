---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

const f = {
  share:  "$$\\text{Share of A} = \\frac{a}{a+b+c} \\times \\text{Total}$$",
  pct:    "$$\\%A = \\frac{a}{a+b+c} \\times 100$$",
  ex1:    "$$2{:}3{:}5 \\implies \\frac{2}{10} = 20\\%,\\;\\frac{3}{10} = 30\\%,\\;\\frac{5}{10} = 50\\%$$",
  ex2:    "$$\\$1000 \\text{ split } 2{:}3{:}5 \\implies \\$200,\\;\\$300,\\;\\$500$$",
};

const tocItems = [
  { id: 'how-to-use',   label: 'How to use' },
  { id: 'what-is',      label: 'What is a 3-part ratio?' },
  { id: 'formula',      label: 'Formula & method' },
  { id: 'examples',     label: 'Worked examples' },
  { id: 'applications', label: 'Real-world applications' },
  { id: 'faq',          label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "3-Part Ratio Calculator",
    "url": "https://calculations.tools/math/ratio-calculator/three-way",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "description": "Split any quantity in a three-part ratio (a:b:c). Enter the ratio parts and an optional total to find each share and percentage. Ideal for dividing profits, mixing materials, or allocating resources.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you divide a quantity in a 3-part ratio?",
        "acceptedAnswer": { "@type": "Answer", "text": "Add all three parts (a + b + c) to find the total number of shares. Divide the quantity by the total shares. Multiply each part by that unit share. For £600 split 1:2:3: total shares = 6; unit share = £100. Shares are £100, £200, £300." }
      },
      {
        "@type": "Question",
        "name": "What is a 2:3:5 ratio as a percentage?",
        "acceptedAnswer": { "@type": "Answer", "text": "Total parts = 10. A = 2/10 = 20%, B = 3/10 = 30%, C = 5/10 = 50%." }
      },
      {
        "@type": "Question",
        "name": "How do you split 100 in a ratio of 1:2:2?",
        "acceptedAnswer": { "@type": "Answer", "text": "Total parts = 5. Each part = 100/5 = 20. Shares: A = 1×20 = 20, B = 2×20 = 40, C = 2×20 = 40." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="3-Part Ratio Calculator"
  metaTitle="3-Part Ratio Calculator | Split in a:b:c Ratio"
  description="Split any quantity in a three-part ratio (a:b:c). Enter the ratio parts and an optional total to find each share and percentage, with step-by-step workings."
  canonical="https://calculations.tools/math/ratio-calculator/three-way"
  tocItems={tocItems}
  schema={schema}
  embedSlug="three-way-ratio-calculator"
  ogFormula="Each part % = (part / total parts) × 100"
  ogExample="2:3:5 -> 20%, 30%, 50% of any total"
>
  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container bmi-container">
        <div class="calculator-header">
          <h2>Calculate Three-Part Ratio</h2>
          <p>Find percentages and split any total in an a:b:c ratio</p>
        </div>

        <div class="tw-ratio-row">
          <div class="bmi-field" style="flex:1;">
            <label class="bmi-label" for="tw-a">Part A</label>
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="tw-a" class="bmi-input" placeholder="e.g. 2" />
            </div>
          </div>
          <div class="tw-colon">:</div>
          <div class="bmi-field" style="flex:1;">
            <label class="bmi-label" for="tw-b">Part B</label>
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="tw-b" class="bmi-input" placeholder="e.g. 3" />
            </div>
          </div>
          <div class="tw-colon">:</div>
          <div class="bmi-field" style="flex:1;">
            <label class="bmi-label" for="tw-c">Part C</label>
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="tw-c" class="bmi-input" placeholder="e.g. 5" />
            </div>
          </div>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="tw-total">Total to split (optional)</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="tw-total" class="bmi-input" placeholder="e.g. 1000" />
          </div>
        </div>

        <div id="tw-result" class="lbm-result hidden">
          <div class="lbm-cards">
            <div class="lbm-card">
              <div class="lbm-card-val" id="tw-pct-a">—</div>
              <div class="lbm-card-lbl">Part A (%)</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="tw-pct-b">—</div>
              <div class="lbm-card-lbl">Part B (%)</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="tw-pct-c">—</div>
              <div class="lbm-card-lbl">Part C (%)</div>
            </div>
          </div>

          <div id="tw-split-cards" class="lbm-cards hidden" style="margin-top:0.5rem;">
            <div class="lbm-card">
              <div class="lbm-card-val" id="tw-share-a">—</div>
              <div class="lbm-card-lbl">A's share</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="tw-share-b">—</div>
              <div class="lbm-card-lbl">B's share</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="tw-share-c">—</div>
              <div class="lbm-card-lbl">C's share</div>
            </div>
          </div>

          <div class="pi-steps" style="margin-top:0.75rem;">
            <div class="pi-steps-title">Step-by-step</div>
            <div class="pi-step">
              <span class="pi-step-label">Total parts</span>
              <span class="pi-step-val" id="tw-step1">—</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">Percentages</span>
              <span class="pi-step-val" id="tw-step2">—</span>
            </div>
            <div class="pi-step hidden" id="tw-split-row">
              <span class="pi-step-label">Shares</span>
              <span class="pi-step-val" id="tw-step3">—</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <style is:global>
      .tw-ratio-row { display:flex; align-items:flex-end; gap:0.4rem; margin-bottom:0.75rem; }
      .tw-colon { font-size:1.5rem; font-weight:700; color:rgba(255,255,255,0.6); padding-bottom:0.75rem; }
    </style>

    <script src="/js/three-way-ratio-calculator.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <p class="answer-box-label">Quick answer</p>
        <p>Add all three parts to get the total number of shares. Divide the quantity by total shares (unit share), then multiply each part by the unit share. For £600 in ratio 1:2:3: unit share = 600÷6 = £100. Shares: <strong>£100 : £200 : £300</strong>.</p>
      </div>

      <h2 id="how-to-use">How to use this calculator</h2>
      <p>Enter the three ratio parts (a, b, c). The calculator immediately shows the percentage each part represents of the whole. Optionally enter a total quantity to find the exact share for each part. All three percentages will always sum to 100%.</p>

      <h2 id="what-is">What is a 3-part ratio?</h2>
      <p>A three-part ratio (a:b:c) describes how a whole is divided into three proportional groups. Unlike a two-part ratio, it requires three values to define the proportional relationship. The ratio 2:3:5 means the whole is divided into 10 parts, with the three groups receiving 2, 3, and 5 parts respectively.</p>

      <h2 id="formula">Formula and method</h2>
      <p>To find the percentage each part represents:</p>
      <Formula expr={f.pct} />
      <p>To find each group's share of a total quantity:</p>
      <Formula expr={f.share} />
      <p>Example — 2:3:5 as percentages:</p>
      <Formula expr={f.ex1} />
      <p>Example — £1000 split in ratio 2:3:5:</p>
      <Formula expr={f.ex2} />

      <h2 id="examples">Worked examples</h2>
      <div class="responsive-table">
        <table>
          <thead><tr><th>Ratio</th><th>Total</th><th>Share A</th><th>Share B</th><th>Share C</th></tr></thead>
          <tbody>
            <tr><td>1:1:1</td><td>300</td><td>100 (33.3%)</td><td>100 (33.3%)</td><td>100 (33.3%)</td></tr>
            <tr><td>1:2:3</td><td>600</td><td>100 (16.7%)</td><td>200 (33.3%)</td><td>300 (50%)</td></tr>
            <tr><td>2:3:5</td><td>1000</td><td>200 (20%)</td><td>300 (30%)</td><td>500 (50%)</td></tr>
            <tr><td>1:2:2</td><td>100</td><td>20 (20%)</td><td>40 (40%)</td><td>40 (40%)</td></tr>
            <tr><td>3:3:4</td><td>500</td><td>150 (30%)</td><td>150 (30%)</td><td>200 (40%)</td></tr>
            <tr><td>1:3:6</td><td>2000</td><td>200 (10%)</td><td>600 (30%)</td><td>1200 (60%)</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="applications">Real-world applications</h2>
      <p><strong>Business profit sharing</strong> — three partners in a 2:3:5 profit split on £80,000 annual profit receive £16,000, £24,000, and £40,000 respectively. The ratio reflects their investment, hours worked, or agreed contribution.</p>
      <p><strong>Inheritance and estate division</strong> — estates divided among three beneficiaries in specified proportions. A ratio ensures a fair and legally clear allocation without ambiguity.</p>
      <p><strong>Concrete and construction mixing</strong> — standard concrete mix ratios by volume: cement:sand:aggregate = 1:2:3 (general purpose) or 1:1.5:3 (structural). Converting to percentages helps when calculating bag quantities.</p>
      <p><strong>Investment portfolio allocation</strong> — allocating capital across three asset classes (e.g. equities:bonds:cash = 6:3:1) means 60%, 30%, and 10% of the portfolio respectively.</p>
      <p><strong>Cooking and chemistry</strong> — cocktail ratios, fertiliser NPK ratios, and chemical solution ratios all use three-part splits where precision matters.</p>

      <h2 id="faq">Frequently asked questions</h2>

      <h3>How do you divide a quantity in a 3-part ratio?</h3>
      <p>Add the three ratio parts to get total shares. Divide the quantity by total shares (unit share). Multiply each part by the unit share. For 600 in ratio 1:2:3: unit = 100; shares = 100, 200, 300.</p>

      <h3>What is a 2:3:5 ratio as a percentage?</h3>
      <p>Total = 10 parts. A = 20%, B = 30%, C = 50%.</p>

      <h3>How do you split 100 in a ratio of 1:2:2?</h3>
      <p>Total = 5. Unit share = 20. Shares: 20, 40, 40.</p>

      <h3>Do all three percentages add to 100%?</h3>
      <p>Yes — by definition the three parts together form the whole (100%).</p>

      <h2 id="related-tools">Related tools</h2>
      <RelatedTools tools={[
        { path: '/math/ratio-calculator',                     blurb: 'Simplify and scale any ratio with step-by-step GCD workings.' },
        { path: '/math/ratio-calculator/ratio-to-percentage', blurb: 'Convert a two-part ratio to percentages.' },
        { path: '/math/ratio-calculator/proportion',          blurb: 'Solve a:b = c:d for the missing value.' },
        { path: '/math/percentage-calculator',                blurb: 'Percentage calculator — percentage of a number, increase, decrease.' },
        { path: '/math/ratio-calculator/unit-rate',           blurb: 'Calculate the rate per single unit.' },
      ]} />

    </div>
  </div>

</CalculatorLayout>
