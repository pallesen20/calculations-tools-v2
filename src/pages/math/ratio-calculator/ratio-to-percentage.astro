---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

const f = {
  pctA:  "$$\\%A = \\frac{a}{a + b} \\times 100$$",
  pctB:  "$$\\%B = \\frac{b}{a + b} \\times 100$$",
  ex1:   "$$3{:}5 \\implies \\frac{3}{8} \\times 100 = 37.5\\%\\quad\\text{and}\\quad\\frac{5}{8} \\times 100 = 62.5\\%$$",
  ex2:   "$$1{:}3 \\implies \\frac{1}{4} \\times 100 = 25\\%\\quad\\text{and}\\quad\\frac{3}{4} \\times 100 = 75\\%$$",
};

const tocItems = [
  { id: 'how-to-use',   label: 'How to use' },
  { id: 'what-is',      label: 'What is ratio to percentage?' },
  { id: 'formula',      label: 'Formula & method' },
  { id: 'examples',     label: 'Worked examples' },
  { id: 'reference',    label: 'Reference table' },
  { id: 'applications', label: 'When to use this conversion' },
  { id: 'faq',          label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Ratio to Percentage Calculator",
    "url": "https://calculations.tools/math/ratio-calculator/ratio-to-percentage",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "description": "Convert any ratio (a:b) to percentages. Enter both parts and get the percentage each part represents of the whole, with step-by-step workings.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you convert a ratio to a percentage?",
        "acceptedAnswer": { "@type": "Answer", "text": "Add both parts of the ratio to get the total. Divide each part by the total and multiply by 100. For 3:5, total = 8; A = 3/8 × 100 = 37.5%, B = 5/8 × 100 = 62.5%." }
      },
      {
        "@type": "Question",
        "name": "What percentage is a 1:3 ratio?",
        "acceptedAnswer": { "@type": "Answer", "text": "Total parts = 4. A = 1/4 × 100 = 25%, B = 3/4 × 100 = 75%." }
      },
      {
        "@type": "Question",
        "name": "What percentage is a 2:1 ratio?",
        "acceptedAnswer": { "@type": "Answer", "text": "Total parts = 3. A = 2/3 × 100 ≈ 66.67%, B = 1/3 × 100 ≈ 33.33%." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Ratio to Percentage Calculator"
  metaTitle="Ratio to Percentage Calculator | Convert a:b to %"
  description="Convert any ratio (a:b) to percentages. Enter both parts to get the percentage each represents of the whole, with step-by-step workings."
  canonical="https://calculations.tools/math/ratio-calculator/ratio-to-percentage"
  tocItems={tocItems}
  schema={schema}
  embedSlug="ratio-to-percentage-calculator"
>
  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container bmi-container">
        <div class="calculator-header">
          <h2>Calculate Ratio to Percentage</h2>
          <p>Convert a:b to the percentage each part represents</p>
        </div>

        <div class="ratio-row">
          <div class="bmi-field" style="flex:1;">
            <label class="bmi-label" for="rp-a">Part A</label>
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="rp-a" class="bmi-input" placeholder="e.g. 3" />
            </div>
          </div>
          <div class="ratio-colon">:</div>
          <div class="bmi-field" style="flex:1;">
            <label class="bmi-label" for="rp-b">Part B</label>
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="rp-b" class="bmi-input" placeholder="e.g. 5" />
            </div>
          </div>
        </div>

        <div id="rp-result" class="lbm-result hidden">
          <div class="lbm-cards">
            <div class="lbm-card">
              <div class="lbm-card-val" id="rp-pct-a">—</div>
              <div class="lbm-card-lbl">Part A (%)</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="rp-pct-b">—</div>
              <div class="lbm-card-lbl">Part B (%)</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="rp-dec-a">—</div>
              <div class="lbm-card-lbl">Part A (decimal)</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="rp-dec-b">—</div>
              <div class="lbm-card-lbl">Part B (decimal)</div>
            </div>
          </div>

          <div class="pi-steps" style="margin-top:0.75rem;">
            <div class="pi-steps-title">Step-by-step</div>
            <div class="pi-step">
              <span class="pi-step-label">Total parts</span>
              <span class="pi-step-val" id="rp-step1">—</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">Part A %</span>
              <span class="pi-step-val" id="rp-step2">—</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">Part B %</span>
              <span class="pi-step-val" id="rp-step3">—</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script src="/js/ratio-to-percentage-calculator.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <p class="answer-box-label">Quick answer</p>
        <p>Add both parts (a + b = total), then divide each by the total and multiply by 100. For <strong>3:5</strong>: total = 8; A = 3/8 × 100 = <strong>37.5%</strong>; B = 5/8 × 100 = <strong>62.5%</strong>.</p>
      </div>

      <h2 id="how-to-use">How to use this calculator</h2>
      <p>Enter the two parts of the ratio (a and b). The calculator returns the percentage each part represents of the whole (a + b), along with decimal equivalents and the full step-by-step workings.</p>

      <h2 id="what-is">What is a ratio-to-percentage conversion?</h2>
      <p>A ratio describes how two quantities relate to each other in parts (e.g. 3:5 — three parts to five parts). A percentage expresses each part's share of the total as a value out of 100. Converting a ratio to percentages is the process of determining what fraction of the whole each part represents.</p>
      <p>The two percentages always sum to exactly 100%. The conversion treats the ratio as a part-to-part relationship and implicitly calculates the whole (a + b).</p>

      <h2 id="formula">Formula and method</h2>
      <p>For a ratio a:b, the percentage of each part is:</p>
      <Formula expr={f.pctA} />
      <Formula expr={f.pctB} />
      <p>Example with 3:5:</p>
      <Formula expr={f.ex1} />
      <p>Example with 1:3:</p>
      <Formula expr={f.ex2} />

      <h2 id="examples">Worked examples</h2>
      <div class="responsive-table">
        <table>
          <thead><tr><th>Ratio</th><th>Total parts</th><th>Part A %</th><th>Part B %</th></tr></thead>
          <tbody>
            <tr><td>1:1</td><td>2</td><td>50%</td><td>50%</td></tr>
            <tr><td>1:3</td><td>4</td><td>25%</td><td>75%</td></tr>
            <tr><td>1:4</td><td>5</td><td>20%</td><td>80%</td></tr>
            <tr><td>2:3</td><td>5</td><td>40%</td><td>60%</td></tr>
            <tr><td>3:5</td><td>8</td><td>37.5%</td><td>62.5%</td></tr>
            <tr><td>2:1</td><td>3</td><td>66.67%</td><td>33.33%</td></tr>
            <tr><td>3:1</td><td>4</td><td>75%</td><td>25%</td></tr>
            <tr><td>4:1</td><td>5</td><td>80%</td><td>20%</td></tr>
            <tr><td>9:1</td><td>10</td><td>90%</td><td>10%</td></tr>
            <tr><td>19:1</td><td>20</td><td>95%</td><td>5%</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="reference">Common ratio reference table</h2>
      <div class="responsive-table">
        <table>
          <thead><tr><th>Ratio</th><th>Part A %</th><th>Part B %</th><th>Typical context</th></tr></thead>
          <tbody>
            <tr><td>1:1</td><td>50%</td><td>50%</td><td>Equal split, 50/50 partnership</td></tr>
            <tr><td>2:1</td><td>66.67%</td><td>33.33%</td><td>Two-thirds majority</td></tr>
            <tr><td>3:1</td><td>75%</td><td>25%</td><td>Three-quarters allocation</td></tr>
            <tr><td>3:2</td><td>60%</td><td>40%</td><td>Macronutrient split, investment allocation</td></tr>
            <tr><td>4:1</td><td>80%</td><td>20%</td><td>Pareto principle (80/20 rule)</td></tr>
            <tr><td>2:3</td><td>40%</td><td>60%</td><td>Debt:equity ratio</td></tr>
            <tr><td>1:9</td><td>10%</td><td>90%</td><td>Tax rate (10% VAT)</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="applications">When to use this conversion</h2>
      <p><strong>Finance and investment</strong> — a 60:40 portfolio (stocks:bonds) means 60% stocks and 40% bonds. Converting the ratio to percentages makes it clear what proportion of capital is allocated to each asset class.</p>
      <p><strong>Mixing and recipes</strong> — a cement:sand ratio of 1:3 means cement is 25% of the mix by volume. Understanding percentages is often more practical than ratios when measuring total quantities.</p>
      <p><strong>Statistics and surveys</strong> — survey results are often reported as ratios (3 in 5 support X). Converting to a percentage (60%) communicates the result more intuitively.</p>
      <p><strong>Nutrition</strong> — macronutrient ratios (protein:carbs:fat) are often converted to percentage shares for dietary planning (e.g. 30% protein, 40% carbs, 30% fat).</p>

      <h2 id="faq">Frequently asked questions</h2>

      <h3>How do you convert a ratio to a percentage?</h3>
      <p>Add both parts to get the total. Divide each part by the total and multiply by 100. For 3:5: total = 8; A = 37.5%, B = 62.5%.</p>

      <h3>What percentage is a 1:3 ratio?</h3>
      <p>Total = 4. A = 1/4 × 100 = 25%, B = 3/4 × 100 = 75%.</p>

      <h3>What percentage is a 2:1 ratio?</h3>
      <p>Total = 3. A = 2/3 × 100 ≈ 66.67%, B = 1/3 × 100 ≈ 33.33%.</p>

      <h3>Do the two percentages always add to 100%?</h3>
      <p>Yes — by definition, the two parts together form the whole (100%).</p>

      <h3>Can I use this for 3-part ratios?</h3>
      <p>This calculator handles 2-part ratios. For three-part splits (a:b:c) use the 3-part ratio calculator.</p>

      <h2 id="related-tools">Related tools</h2>
      <RelatedTools tools={[
        { path: '/math/ratio-calculator',              blurb: 'Simplify and scale any ratio with step-by-step GCD workings.' },
        { path: '/math/ratio-calculator/three-way',    blurb: 'Split a quantity in a three-part ratio (a:b:c).' },
        { path: '/math/percentage-calculator',         blurb: 'Percentage calculator — percentage of a number, increase, decrease.' },
        { path: '/math/ratio-calculator/proportion',   blurb: 'Solve a:b = c:d for the missing value.' },
        { path: '/math/fraction-calculator/fraction-to-decimal', blurb: 'Convert any fraction to its decimal equivalent.' },
      ]} />

    </div>
  </div>

</CalculatorLayout>
