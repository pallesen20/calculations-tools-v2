---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{lb} = \\text{kg} \\times 2.20462$$",
  rev: "$$\\text{kg} = \\text{lb} \\div 2.20462$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert kg to lbs' },
  { id: 'reverse',         label: 'How to convert lbs to kg' },
  { id: 'reference-table', label: 'kg to lbs reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kilograms to Pounds Converter",
    "url": "https://calculations.tools/conversion/weight-converter/kg-to-lb",
    "description": "Convert kilograms to pounds instantly. Formula: lb = kg × 2.20462. Includes reverse lbs to kg conversion and a body weight reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert kilograms to pounds",
    "description": "Convert kilograms to pounds using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter kg value", "text": "Type your kilograms value in the kg field. The pounds result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted lbs value appears immediately. For 70 kg, the result is 154.32 lbs." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the lbs field to convert back to kg. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many pounds is 70 kg?",
        "acceptedAnswer": { "@type": "Answer", "text": "70 kg equals 154.32 pounds. Multiply 70 by 2.20462: 70 × 2.20462 = 154.323 lbs." }
      },
      {
        "@type": "Question",
        "name": "How do you convert kg to pounds?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply kilograms by 2.20462. For a quick mental estimate, multiply by 2.2 (0.2% low). Example: 80 kg × 2.20462 = 176.37 lbs." }
      },
      {
        "@type": "Question",
        "name": "How many pounds is 100 kg?",
        "acceptedAnswer": { "@type": "Answer", "text": "100 kg equals 220.462 pounds. Multiply 100 by 2.20462: 100 × 2.20462 = 220.46 lbs." }
      },
      {
        "@type": "Question",
        "name": "How many kg is 1 pound?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 pound equals 0.453592 kg. This is the exact international definition: 1 lb = 0.45359237 kg, fixed in 1959." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Kilograms to Pounds Converter"
  metaTitle="Kilograms to Pounds Converter | kg to lbs ᐅ"
  description="Convert kilograms to pounds instantly. Formula: lb = kg × 2.20462. Body weight reference table included - 50 kg, 70 kg, 100 kg in lbs and more."
  canonical="https://calculations.tools/conversion/weight-converter/kg-to-lb"
  tocItems={tocItems}
  embedSlug="kg-to-lb"
  schema={schema}
  ogFormula="lb = kg × 2.20462"
  ogExample="70 kg = 154.32 lb"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Kilogram to Pound (kg to lb) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Kilograms (kg)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 70" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Pounds (lb)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 154.32" />
          </div>
        </div>

        <div class="pair-formula-note">1 kg = 2.20462 lb &nbsp;·&nbsp; 1 lb = 0.453592 kg</div>

      </div>
    </section>

    <script src="/js/kg-to-lb.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert kilograms to pounds, multiply by <strong>2.20462</strong>. So 70 kg = 154.32 lb and 100 kg = 220.46 lb. The factor comes from the exact definition: 1 lb = 0.45359237 kg, set in the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 kg = 2.20462262... lb (derived from the 1959 definition of the pound).</li>
          <li>70 kg = 154.32 lb. 80 kg = 176.37 lb. 100 kg = 220.46 lb.</li>
          <li>Quick mental estimate: multiply by 2.2 - result is 0.2% low.</li>
          <li>For body weight in the US, lbs is standard; most other countries use kg.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any kg value in the kg field and the pounds result appears instantly. You can also type in the lbs field to convert back to kg - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Kilograms to Pounds?</h2>
      <p>Multiply kilograms by 2.20462. The underlying definition is that one pound equals exactly 0.45359237 kilograms (set in 1959), so 1 kg = 1 ÷ 0.45359237 = 2.20462262... lbs.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 50 kg = 110.23 lb. 60 kg = 132.28 lb. 70 kg = 154.32 lb. 80 kg = 176.37 lb. 90 kg = 198.42 lb. 100 kg = 220.46 lb.</p>

      <p>Mental shortcut: multiply by 2.2 for a quick estimate. For 75 kg: 75 × 2.2 = 165 lb (actual: 165.35 lb). The error is under 0.2%.</p>

      <h2 id="reverse">How Do You Convert Pounds to Kilograms?</h2>
      <p>Divide pounds by 2.20462, or multiply by 0.453592. See the dedicated <a href="/conversion/weight-converter/lb-to-kg">pounds to kilograms converter</a> for a pounds-first reference table.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 100 lb = 45.36 kg. 150 lb = 68.04 kg. 200 lb = 90.72 kg.</p>

      <h2 id="reference-table">Kilograms to Pounds Reference Table</h2>
      <p>Common body weight and general weight values converted using the exact factor 2.20462 lb/kg:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Kilograms (kg)</th><th>Pounds (lb)</th><th>Context</th></tr>
          </thead>
          <tbody>
            <tr><td>45 kg</td><td>99.21 lb</td><td>Lower adult body weight</td></tr>
            <tr><td>50 kg</td><td>110.23 lb</td><td>Light adult body weight</td></tr>
            <tr><td>55 kg</td><td>121.25 lb</td><td>-</td></tr>
            <tr><td>60 kg</td><td>132.28 lb</td><td>Average female body weight (many countries)</td></tr>
            <tr><td>65 kg</td><td>143.30 lb</td><td>-</td></tr>
            <tr><td>70 kg</td><td>154.32 lb</td><td>Average adult body weight</td></tr>
            <tr><td>75 kg</td><td>165.35 lb</td><td>-</td></tr>
            <tr><td>80 kg</td><td>176.37 lb</td><td>Average male body weight (many countries)</td></tr>
            <tr><td>90 kg</td><td>198.42 lb</td><td>-</td></tr>
            <tr><td>100 kg</td><td>220.46 lb</td><td>Heavy adult weight / barbell load</td></tr>
            <tr><td>120 kg</td><td>264.55 lb</td><td>-</td></tr>
            <tr><td>1000 kg</td><td>2,204.62 lb</td><td>1 metric ton</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert kg to lbs?</h2>
      <p>The kg-to-lbs conversion is driven almost entirely by body weight. The US uses pounds for body weight while most of the world uses kilograms. Common use cases:</p>
      <ul>
        <li><strong>Health and fitness</strong> - reading US-format BMI charts, gym equipment labels, and fitness app logs that default to lbs.</li>
        <li><strong>Medical</strong> - international patient records, drug dosing (many US protocols specify mg/lb), and clinical research papers.</li>
        <li><strong>Shipping</strong> - international parcels often require weight in both units; many carriers use lb for US destinations.</li>
        <li><strong>Sport</strong> - boxing, wrestling, and powerlifting weight classes are published in both kg and lbs depending on the federation.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many pounds is 70 kg?</h3>
      <p>70 kg equals 154.32 pounds. Multiply 70 by 2.20462: 70 × 2.20462 = 154.323 lbs. This is a common average adult body weight in many countries.</p>

      <h3>How do you convert kg to lbs?</h3>
      <p>Multiply kilograms by 2.20462. Quick mental shortcut: multiply by 2.2 (result is 0.2% low). For 80 kg: 80 × 2.2 = 176 lb (actual: 176.37 lb).</p>

      <h3>How many pounds is 100 kg?</h3>
      <p>100 kg equals 220.46 pounds. This is a round number making it a useful mental anchor: 100 kg &asymp; 220 lb.</p>

      <h3>How many kg is 1 pound?</h3>
      <p>1 pound equals exactly 0.45359237 kg. This is the international definition set in 1959. For quick mental use: 1 lb &asymp; 0.454 kg, or 2.2 lb &asymp; 1 kg.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter/lb-to-kg">Pounds to Kilograms Converter</a>
            <p>Reverse conversion - enter lbs and get kg instantly, with a pounds-first reference table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter/kg-to-st">Kilograms to Stone Converter</a>
            <p>Convert kg to stone - common for body weight in the UK.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter/kg-to-g">Kilograms to Grams Converter</a>
            <p>Convert kg to grams for precise small measurements.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter">Weight Converter (all units)</a>
            <p>Convert between all metric and imperial weight units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
