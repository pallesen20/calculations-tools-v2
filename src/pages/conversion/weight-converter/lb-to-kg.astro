---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{kg} = \\text{lb} \\times 0.453592$$",
  rev: "$$\\text{lb} = \\text{kg} \\times 2.20462$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert lbs to kg' },
  { id: 'reverse',         label: 'How to convert kg to lbs' },
  { id: 'reference-table', label: 'lbs to kg reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Pounds to Kilograms Converter",
    "url": "https://calculations.tools/conversion/weight-converter/lb-to-kg",
    "description": "Convert pounds to kilograms instantly. Formula: kg = lb × 0.453592. Includes reverse kg to lbs conversion and a body weight reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert pounds to kilograms",
    "description": "Convert pounds to kilograms using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter lbs value", "text": "Type your pounds value in the lb field. The kilograms result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted kg value appears immediately. For 150 lbs, the result is 68.04 kg." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the kg field to convert back to lbs. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many kg is 150 pounds?",
        "acceptedAnswer": { "@type": "Answer", "text": "150 pounds equals 68.04 kg. Multiply 150 by 0.453592: 150 × 0.453592 = 68.039 kg." }
      },
      {
        "@type": "Question",
        "name": "How do you convert pounds to kg?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply pounds by 0.453592, or divide by 2.20462. Quick mental estimate: divide by 2.2. Example: 180 lbs ÷ 2.2 = 81.8 kg (actual: 81.65 kg)." }
      },
      {
        "@type": "Question",
        "name": "How many kg is 200 pounds?",
        "acceptedAnswer": { "@type": "Answer", "text": "200 pounds equals 90.72 kg. Multiply 200 by 0.453592: 200 × 0.453592 = 90.718 kg." }
      },
      {
        "@type": "Question",
        "name": "Is 1 pound more or less than 1 kg?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 pound is less than 1 kg. One pound equals 0.453592 kg, so a kilogram is about 2.2 times heavier than a pound." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Pounds to Kilograms Converter"
  metaTitle="Pounds to Kilograms Converter | lbs to kg ᐅ"
  description="Convert pounds to kilograms instantly. Formula: kg = lb × 0.453592. Body weight reference table included - 100 lb, 150 lb, 200 lb in kg and more."
  canonical="https://calculations.tools/conversion/weight-converter/lb-to-kg"
  tocItems={tocItems}
  embedSlug="lb-to-kg"
  schema={schema}
  ogFormula="kg = lb × 0.453592"
  ogExample="150 lb = 68.04 kg"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Pound to Kilogram (lb to kg) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Pounds (lb)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 150" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Kilograms (kg)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 68.04" />
          </div>
        </div>

        <div class="pair-formula-note">1 lb = 0.453592 kg &nbsp;·&nbsp; 1 kg = 2.20462 lb</div>

      </div>
    </section>

    <script src="/js/lb-to-kg.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert pounds to kilograms, multiply by <strong>0.453592</strong> (or divide by 2.20462). So 150 lb = 68.04 kg and 200 lb = 90.72 kg. The factor is exact: 1 lb = 0.45359237 kg, defined internationally in 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 lb = 0.45359237 kg (international definition, fixed in 1959).</li>
          <li>150 lb = 68.04 kg. 180 lb = 81.65 kg. 200 lb = 90.72 kg.</li>
          <li>Quick mental estimate: divide by 2.2 - result is 0.2% high.</li>
          <li>The US uses lbs for body weight; most other countries use kg.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any pounds value in the lb field and the kg result appears instantly. You can also type in the kg field to convert back to lbs - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Pounds to Kilograms?</h2>
      <p>Multiply pounds by 0.453592. The exact value is 0.45359237 kg/lb - the international pound definition adopted in 1959 by the US, UK, and other countries.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 100 lb = 45.36 kg. 120 lb = 54.43 kg. 150 lb = 68.04 kg. 180 lb = 81.65 kg. 200 lb = 90.72 kg.</p>

      <p>Mental shortcut: divide by 2.2 for a quick estimate. For 165 lb: 165 ÷ 2.2 = 75 kg (actual: 74.84 kg). The error is under 0.2%.</p>

      <h2 id="reverse">How Do You Convert Kilograms to Pounds?</h2>
      <p>Multiply kilograms by 2.20462. See the dedicated <a href="/conversion/weight-converter/kg-to-lb">kilograms to pounds converter</a> for a kg-first reference table.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 60 kg = 132.28 lb. 70 kg = 154.32 lb. 80 kg = 176.37 lb.</p>

      <h2 id="reference-table">Pounds to Kilograms Reference Table</h2>
      <p>Common body weight values converted using the exact factor 0.45359237 kg/lb:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Pounds (lb)</th><th>Kilograms (kg)</th><th>Context</th></tr>
          </thead>
          <tbody>
            <tr><td>100 lb</td><td>45.36 kg</td><td>Lower adult body weight</td></tr>
            <tr><td>110 lb</td><td>49.90 kg</td><td>-</td></tr>
            <tr><td>120 lb</td><td>54.43 kg</td><td>-</td></tr>
            <tr><td>130 lb</td><td>58.97 kg</td><td>-</td></tr>
            <tr><td>140 lb</td><td>63.50 kg</td><td>Average female body weight (US)</td></tr>
            <tr><td>150 lb</td><td>68.04 kg</td><td>-</td></tr>
            <tr><td>160 lb</td><td>72.57 kg</td><td>-</td></tr>
            <tr><td>170 lb</td><td>77.11 kg</td><td>Average male body weight (US)</td></tr>
            <tr><td>180 lb</td><td>81.65 kg</td><td>-</td></tr>
            <tr><td>200 lb</td><td>90.72 kg</td><td>-</td></tr>
            <tr><td>220 lb</td><td>99.79 kg</td><td>Near 100 kg threshold</td></tr>
            <tr><td>250 lb</td><td>113.40 kg</td><td>-</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert lbs to kg?</h2>
      <p>This conversion is most commonly needed when a US-based weight measurement must be interpreted in metric countries, or when filling out international forms. Common use cases:</p>
      <ul>
        <li><strong>Health and medical</strong> - entering body weight in international health systems, BMI calculators, or clinical research data that uses kg.</li>
        <li><strong>Fitness</strong> - US gym equipment and fitness apps often default to lbs; international programs use kg for load calculations.</li>
        <li><strong>Shipping</strong> - converting parcel weights from US lbs to kg for international carriers and customs declarations.</li>
        <li><strong>Sport</strong> - weight class divisions in international competitions (Olympics, FIFA, etc.) are specified in kg.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many kg is 150 pounds?</h3>
      <p>150 pounds equals 68.04 kg. Multiply 150 by 0.453592: 150 × 0.453592 = 68.039 kg. This is a commonly referenced body weight - roughly average female weight in the US.</p>

      <h3>How do you convert lbs to kg?</h3>
      <p>Multiply pounds by 0.453592. Quick mental check: divide by 2.2 (result is 0.2% high). For 200 lb: 200 ÷ 2.2 = 90.9 kg (actual: 90.72 kg).</p>

      <h3>How many kg is 200 pounds?</h3>
      <p>200 pounds equals 90.72 kg. This is just under the 100 kg threshold commonly referenced in weightlifting and medical contexts.</p>

      <h3>Is 1 pound more or less than 1 kg?</h3>
      <p>1 pound is less than 1 kg. One pound = 0.4536 kg, so it takes about 2.205 pounds to equal 1 kilogram. A kilogram is roughly 2.2 times heavier than a pound.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter/kg-to-lb">Kilograms to Pounds Converter</a>
            <p>Reverse conversion - enter kg and get lbs instantly, with a kg-first reference table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter/lb-to-st">Pounds to Stone Converter</a>
            <p>Convert lbs to stone - used for body weight in the UK.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter/lb-to-oz">Pounds to Ounces Converter</a>
            <p>Convert lbs to oz within the imperial system.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter">Weight Converter (all units)</a>
            <p>Convert between all metric and imperial weight units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
