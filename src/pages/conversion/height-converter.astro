---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'cm-to-feet',      label: 'cm to feet and inches' },
  { id: 'feet-to-cm',      label: 'feet and inches to cm' },
  { id: 'height-formats',  label: 'Height formats explained' },
  { id: 'reference',       label: 'Common height reference table' },
  { id: 'common-mistakes', label: 'Common mistakes' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Height Converter",
    "url": "https://calculations.tools/conversion/height-converter",
    "description": "Convert height between centimeters, meters, feet, inches, and the combined feet+inches format. Includes a full reference table for heights from 4'11\" to 6'4\".",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert height between cm and feet and inches",
    "description": "Step-by-step guide to converting height using the height converter, including the combined feet+inches format.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Select units", "text": "Choose the unit you are converting from and the unit you want to convert to using the two dropdowns." },
      { "@type": "HowToStep", "position": 2, "name": "Enter the value", "text": "Type your height value. If converting from Feet & Inches, enter feet in the first field and inches in the second field that appears." },
      { "@type": "HowToStep", "position": 3, "name": "Read the result", "text": "The converted height appears instantly. The swap button reverses the direction without retyping." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How tall is 5'10\" in cm?", "acceptedAnswer": { "@type": "Answer", "text": "5 feet 10 inches equals 177.8 cm. Calculation: (5 x 12 + 10) x 2.54 = 70 x 2.54 = 177.8 cm." } },
      { "@type": "Question", "name": "How tall is 170 cm in feet and inches?", "acceptedAnswer": { "@type": "Answer", "text": "170 cm equals 5 feet 6.9 inches. Calculation: 170 / 2.54 = 66.929 total inches, which is 5 feet (60 inches) plus 6.929 inches." } },
      { "@type": "Question", "name": "How tall is 6 feet in cm?", "acceptedAnswer": { "@type": "Answer", "text": "6 feet equals exactly 182.88 cm. Calculation: 6 x 30.48 = 182.88 cm." } },
      { "@type": "Question", "name": "How many cm is one inch?", "acceptedAnswer": { "@type": "Answer", "text": "One inch equals exactly 2.54 cm. This is an exact international standard set in 1959, so all inch-to-cm conversions are precise rather than approximate." } },
      { "@type": "Question", "name": "What is the average height for men and women?", "acceptedAnswer": { "@type": "Answer", "text": "The global average adult male height is approximately 171 cm (5 ft 7 in) and the average adult female is approximately 159 cm (5 ft 2.5 in). These vary significantly by country: Dutch men average around 183 cm, while South Asian averages are closer to 165 cm for men." } },
      { "@type": "Question", "name": "How do I convert 5'11\" to cm?", "acceptedAnswer": { "@type": "Answer", "text": "5 feet 11 inches equals 180.34 cm. Calculation: (5 x 12 + 11) x 2.54 = 71 x 2.54 = 180.34 cm." } },
      { "@type": "Question", "name": "What is 175 cm in feet and inches?", "acceptedAnswer": { "@type": "Answer", "text": "175 cm equals 5 feet 8.9 inches. Calculation: 175 / 2.54 = 68.898 total inches = 5 feet and 8.898 inches." } }
    ]
  }
];
---

<CalculatorLayout
  title="Height Converter"
  metaTitle="Fast Height Converter | Convert cm, meters, feet & inches ᐅ"
  description="Convert height between centimeters, meters, feet, inches, and the combined ft+in format. Includes a full reference table from 4ft 11in to 6ft 4in with cm and meter values. Free, instant, no sign-up."
  canonical="https://calculations.tools/conversion/height-converter"
  tocItems={tocItems}
  embedSlug="height-converter"
  schema={schema}
>

  <!-- CALCULATOR WIDGET -->
  <div slot="calculator">
    <section class="calculator-interface" id="hc-calculator">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Height Conversion Calculator</h2>
          <p>Enter a value and select units - result updates instantly</p>
        </div>

        <!-- Quick conversions -->
        <h3 class="font-semibold text-white text-center mb-6">Quick Conversions</h3>
        <div id="hc-quick" class="lc-quick"></div>

        <!-- Inputs -->
        <div class="lc-inputs">
          <div class="input-group">
            <label for="hc-value">Value</label>
            <div class="hc-value-wrap">
              <input id="hc-value" type="number" value="180" placeholder="Enter value" />
              <input id="hc-in-part" type="number" placeholder="in" min="0" max="11" step="0.1" />
            </div>
          </div>
          <div class="input-group">
            <label for="hc-from">From</label>
            <select id="hc-from"></select>
          </div>
          <div class="unit-swap-wrap">
            <button class="unit-swap" id="hc-swap" title="Swap units" aria-label="Swap units">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#ffffff" width="16" height="16">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
              </svg>
            </button>
          </div>
          <div class="input-group">
            <label for="hc-to">To</label>
            <select id="hc-to"></select>
          </div>
        </div>

        <!-- Result -->
        <div class="lc-result-box">
          <div class="result-label">Result</div>
          <div class="lc-result" id="hc-result">-</div>
          <div class="lc-result-desc" id="hc-result-desc"></div>
        </div>

        <!-- Common conversions -->
        <div class="lc-common-section">
          <h3 id="hc-common-title" class="lc-common-title"></h3>
          <div id="hc-common" class="lc-common-grid"></div>
        </div>

      </div>
    </section>

    <script src="/js/height-converter.js" is:inline></script>
  </div>

  <!-- LONG-FORM CONTENT -->
  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert cm to feet and inches: divide cm by 2.54 to get total inches, then divide by 12. The whole number is feet, the remainder is inches. Example: 180 cm / 2.54 = 70.87 in = 5 ft 10.9 in. To go the other way, multiply feet by 30.48 and inches by 2.54, then add them together.</p>
      </div>

      <h2 id="how-to-use">How to use this converter</h2>
      <p>Select the unit you are converting from and the unit you want in the two dropdowns, then type your height. The result updates as you type. When "Feet &amp; Inches" is selected as the source unit, a second input appears for the inches portion: enter feet in the first box and inches in the second. The swap button reverses direction without retyping.</p>
      <p>All calculations use the exact definition of 1 inch = 2.54 cm and run locally in your browser.</p>

      <h2 id="cm-to-feet">cm to feet and inches</h2>
      <p>Converting centimetres to feet and inches requires three steps. Here is a worked example using 180 cm:</p>
      <ol>
        <li><strong>Divide by 2.54</strong> to get total inches: 180 / 2.54 = 70.866 inches</li>
        <li><strong>Divide total inches by 12</strong> to find feet: 70.866 / 12 = 5 feet with a remainder of 0.866</li>
        <li><strong>Multiply the remainder by 12</strong> to get inches: 0.866 × 12 = 10.4 inches</li>
      </ol>
      <p><strong>Result: 180 cm = 5 ft 10.4 in</strong></p>
      <p>The key relationship: 1 inch = 2.54 cm exactly, and 1 foot = 12 inches = 30.48 cm exactly.</p>

      <h2 id="feet-to-cm">feet and inches to cm</h2>
      <p>Converting feet and inches to centimetres is two steps. Worked example using 5'11":</p>
      <ol>
        <li><strong>Convert feet to total inches:</strong> 5 × 12 = 60 inches, then add the remaining inches: 60 + 11 = 71 total inches</li>
        <li><strong>Multiply by 2.54:</strong> 71 × 2.54 = 180.34 cm</li>
      </ol>
      <p><strong>Result: 5'11" = 180.34 cm</strong></p>
      <p>Alternatively: multiply feet by 30.48 and inches by 2.54, then add. So 5'11" = (5 × 30.48) + (11 × 2.54) = 152.4 + 27.94 = 180.34 cm. Both methods give the same result.</p>

      <h2 id="height-formats">Height formats explained</h2>
      <p>Height is recorded in different formats depending on context, and switching between them is one of the most common sources of confusion.</p>

      <h3>Feet and inches (ft+in)</h3>
      <p>This is the format used for personal height in the United States and informally in the UK. You say "five foot eleven" and write it as 5'11" or 5 ft 11 in. The feet and inches are separate values: 5'11" is not the same as 5.11 feet (see the common mistakes section below).</p>

      <h3>Decimal feet</h3>
      <p>This format expresses the entire height as a decimal number of feet, for example 5.917 ft for 5'11". It is used in surveying, construction drawings, and some aviation contexts. It is not how people state their personal height, but it is common in technical fields. 5.917 ft × 30.48 = 180.34 cm, which confirms it matches 5'11".</p>

      <h3>Centimeters and meters</h3>
      <p>Centimeters are the standard for personal height everywhere outside the US and UK. Medical forms, driver's licences, and passport applications in Europe, Asia, South America, and most of the world use centimeters. Meters are used in scientific and technical contexts: a person who is 175 cm tall is 1.75 m tall.</p>

      <h3>Which format to use</h3>
      <p>For personal height on international medical forms, use centimeters. For US medical forms or US databases, use feet and inches. If you are doing any calculation that involves your height (BMI, surface area, proportions), convert to meters first since most formulas use SI units.</p>

      <h2 id="reference">Common height reference table</h2>
      <p>This table covers typical adult heights from 4'11" to 6'4", with values in both centimetres and meters.</p>
      <div class="responsive-table">
      <table>
        <thead>
          <tr><th>Feet &amp; Inches</th><th>Centimetres</th><th>Meters</th></tr>
        </thead>
        <tbody>
          <tr><td>4'11"</td><td>149.9 cm</td><td>1.499 m</td></tr>
          <tr><td>5'0"</td><td>152.4 cm</td><td>1.524 m</td></tr>
          <tr><td>5'1"</td><td>154.9 cm</td><td>1.549 m</td></tr>
          <tr><td>5'2"</td><td>157.5 cm</td><td>1.575 m</td></tr>
          <tr><td>5'3"</td><td>160.0 cm</td><td>1.600 m</td></tr>
          <tr><td>5'4"</td><td>162.6 cm</td><td>1.626 m</td></tr>
          <tr><td>5'5"</td><td>165.1 cm</td><td>1.651 m</td></tr>
          <tr><td>5'6"</td><td>167.6 cm</td><td>1.676 m</td></tr>
          <tr><td>5'7"</td><td>170.2 cm</td><td>1.702 m</td></tr>
          <tr><td>5'8"</td><td>172.7 cm</td><td>1.727 m</td></tr>
          <tr><td>5'9"</td><td>175.3 cm</td><td>1.753 m</td></tr>
          <tr><td>5'10"</td><td>177.8 cm</td><td>1.778 m</td></tr>
          <tr><td>5'11"</td><td>180.3 cm</td><td>1.803 m</td></tr>
          <tr><td>6'0"</td><td>182.9 cm</td><td>1.829 m</td></tr>
          <tr><td>6'1"</td><td>185.4 cm</td><td>1.854 m</td></tr>
          <tr><td>6'2"</td><td>187.9 cm</td><td>1.880 m</td></tr>
          <tr><td>6'3"</td><td>190.5 cm</td><td>1.905 m</td></tr>
          <tr><td>6'4"</td><td>193.0 cm</td><td>1.930 m</td></tr>
        </tbody>
      </table>
      </div>

      <h2 id="common-mistakes">Common mistakes</h2>

      <h3>Entering 5.11 instead of 5 ft 11 in</h3>
      <p>This is the most common height conversion error. If you type "5.11" into a decimal feet field, the converter reads it as 5.11 feet, which is 5 feet and 0.11 × 12 = 1.32 inches, giving 155.8 cm. The correct value for 5'11" is 5.917 ft (or entered as 5 ft and 11 in separately), which gives 180.34 cm. The difference is over 24 cm. When using "Feet &amp; Inches" mode, always use the two separate input fields provided.</p>

      <h3>Confusing decimal feet with feet+inches on forms</h3>
      <p>If a form asks for height in feet and you enter 5.9, that means 5 feet and 0.9 × 12 = 10.8 inches (175.0 cm). But many people think 5.9 means 5 feet 9 inches (175.3 cm). These are nearly the same, but for a form asking for two separate fields (feet: 5, inches: 9), entering 5.9 in the feet field is wrong. Read the form carefully to understand whether it wants a decimal or two separate values.</p>

      <h3>Rounding 30.5 instead of using 30.48 for cm per foot</h3>
      <p>A common approximation is "1 foot = 30 cm" or "1 foot = 30.5 cm." The exact value is 30.48 cm. The error from using 30.5 is small per foot (0.066%) but compounds across multiple feet. For a 6-foot person: 6 × 30.5 = 183 cm vs the correct 182.88 cm, a 1.2 mm difference. For most purposes this is fine, but for any official form or medical record, use the exact value.</p>

      <h2 id="faq">FAQs</h2>

      <h3>How tall is 5'10" in cm?</h3>
      <p>5 feet 10 inches equals <strong>177.8 cm</strong>. Calculation: (5 × 12 + 10) × 2.54 = 70 × 2.54 = 177.8 cm.</p>

      <h3>How tall is 170 cm in feet and inches?</h3>
      <p>170 cm equals <strong>5 ft 6.9 in</strong>. Calculation: 170 / 2.54 = 66.929 total inches = 5 feet (60 in) + 6.929 inches.</p>

      <h3>How tall is 6 feet in cm?</h3>
      <p>6 feet equals exactly <strong>182.88 cm</strong>. Calculation: 6 × 30.48 = 182.88 cm. Since 1 foot = 0.3048 m exactly, this is also 1.8288 m.</p>

      <h3>How do I convert 5'11" to cm?</h3>
      <p>5 feet 11 inches equals <strong>180.34 cm</strong>. Calculation: (5 × 12 + 11) × 2.54 = 71 × 2.54 = 180.34 cm.</p>

      <h3>What is 175 cm in feet and inches?</h3>
      <p>175 cm equals <strong>5 ft 8.9 in</strong>. Calculation: 175 / 2.54 = 68.898 total inches = 5 feet and 8.898 inches.</p>

      <h3>How many cm is one inch?</h3>
      <p>One inch equals exactly <strong>2.54 cm</strong>. This is a fixed international standard set in 1959. All inch-to-cm conversions are exact rather than approximate.</p>

      <h3>What is the average adult height?</h3>
      <p>The global average adult male height is approximately <strong>171 cm (5 ft 7 in)</strong> and the global average adult female is approximately <strong>159 cm (5 ft 2.5 in)</strong>. These vary considerably by country. Dutch men average around 183 cm (6 ft 0 in), one of the tallest averages in the world. US male average is about 176 cm (5 ft 9 in).</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter">Weight Converter</a>
            <p>Convert between kilograms, pounds, ounces, stone, and metric or US tons.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter</a>
            <p>Convert between meters, kilometers, feet, inches, miles, nautical miles, and more.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">🌡️</span>
          <div>
            <a href="/conversion/temperature-converter">Temperature Converter</a>
            <p>Convert between Celsius, Fahrenheit, Kelvin, Rankine, and Réaumur.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .hc-value-wrap { display: flex; gap: 0.5rem; }
  .hc-value-wrap input { flex: 1; min-width: 0; }
</style>
