---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$°F = °C \\times \\frac{9}{5} + 32$$",
  rev: "$$°C = (°F - 32) \\times \\frac{5}{9}$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert Celsius to Fahrenheit' },
  { id: 'reverse',         label: 'How to convert Fahrenheit to Celsius' },
  { id: 'reference-table', label: 'Celsius to Fahrenheit reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Celsius to Fahrenheit Converter",
    "url": "https://calculations.tools/conversion/temperature-converter/c-to-f",
    "description": "Convert Celsius to Fahrenheit instantly. Formula: °F = °C × 9/5 + 32. Includes reverse Fahrenheit to Celsius conversion and a full reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert Celsius to Fahrenheit",
    "description": "Convert Celsius to Fahrenheit using the standard formula.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter Celsius value", "text": "Type your Celsius temperature in the °C field. The Fahrenheit result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted Fahrenheit value appears immediately. For 100°C, the result is 212°F." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the °F field to convert back to Celsius. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you convert Celsius to Fahrenheit?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply the Celsius value by 9/5 (1.8), then add 32. Formula: °F = °C × 9/5 + 32. Example: 100°C × 9/5 = 180, + 32 = 212°F. Quick mental estimate: double the Celsius and add 30." }
      },
      {
        "@type": "Question",
        "name": "What is 37 degrees Celsius in Fahrenheit?",
        "acceptedAnswer": { "@type": "Answer", "text": "37°C equals 98.6°F. Calculation: 37 × 9/5 + 32 = 66.6 + 32 = 98.6°F. This is normal human body temperature." }
      },
      {
        "@type": "Question",
        "name": "What is 20 Celsius in Fahrenheit?",
        "acceptedAnswer": { "@type": "Answer", "text": "20°C equals 68°F. Calculation: 20 × 9/5 + 32 = 36 + 32 = 68°F. This is a comfortable room temperature." }
      },
      {
        "@type": "Question",
        "name": "What temperature is the same in Celsius and Fahrenheit?",
        "acceptedAnswer": { "@type": "Answer", "text": "-40 degrees is the only point where both scales are equal: -40°C = -40°F. Below -40, Fahrenheit values are lower; above -40, Fahrenheit values are higher." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Celsius to Fahrenheit Converter"
  metaTitle="Celsius to Fahrenheit Converter | °C to °F ᐅ"
  description="Convert Celsius to Fahrenheit instantly. Formula: °F = °C × 9/5 + 32. Includes common temperatures - body temp, boiling point, oven settings - and reverse °F to °C."
  canonical="https://calculations.tools/conversion/temperature-converter/c-to-f"
  tocItems={tocItems}
  embedSlug="c-to-f"
  schema={schema}
  ogFormula="°F = °C × 9/5 + 32"
  ogExample="100°C = 212°F"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Celsius to Fahrenheit (°C to °F) Converter</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Celsius (°C)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 100" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Fahrenheit (°F)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 212" />
          </div>
        </div>

        <div class="pair-formula-note">°F = °C × 9/5 + 32 &nbsp;·&nbsp; °C = (°F − 32) × 5/9</div>

      </div>
    </section>

    <script src="/js/c-to-f.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert Celsius to Fahrenheit, multiply by <strong>9/5</strong> then add <strong>32</strong>. Formula: °F = °C × 9/5 + 32. Key values: 0°C = 32°F, 20°C = 68°F, 37°C = 98.6°F, 100°C = 212°F. Quick mental estimate: double the Celsius value and add 30.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Formula: °F = °C × 9/5 + 32 (multiply scales the degree size; adding 32 adjusts the zero point).</li>
          <li>37°C = 98.6°F - normal human body temperature.</li>
          <li>100°C = 212°F - water boils at sea level.</li>
          <li>-40°C = -40°F - the only point where both scales are equal.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any Celsius value in the °C field and the Fahrenheit result appears instantly. You can also type in the °F field to convert back to Celsius - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Celsius to Fahrenheit?</h2>
      <p>Multiply by 9/5 (which scales the degree size from Celsius to Fahrenheit), then add 32 (which shifts the zero point). The two scales differ in both degree size and where zero sits, so you need both operations.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 0°C = 32°F. 20°C = 68°F. 37°C = 98.6°F. 100°C = 212°F. 180°C = 356°F.</p>

      <p>Mental shortcut: double the Celsius value and add 30. For 20°C: 20 × 2 = 40, + 30 = 70°F (actual: 68°F, error 2°F). For 100°C: 100 × 2 = 200, + 30 = 230°F (actual: 212°F, error 18°F - the shortcut loses accuracy at extremes, use the full formula for cooking and science).</p>

      <h2 id="reverse">How Do You Convert Fahrenheit to Celsius?</h2>
      <p>Subtract 32 first (remove the zero-point offset), then multiply by 5/9 (scale back to Celsius degree size). See the dedicated <a href="/conversion/temperature-converter/f-to-c">Fahrenheit to Celsius converter</a> for a Fahrenheit-first reference table.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 32°F = 0°C. 72°F = 22.2°C. 98.6°F = 37°C. 212°F = 100°C.</p>

      <h2 id="reference-table">Celsius to Fahrenheit Reference Table</h2>
      <p>Common temperatures converted using the exact formula °F = °C × 9/5 + 32:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Celsius (°C)</th><th>Fahrenheit (°F)</th><th>Context</th></tr>
          </thead>
          <tbody>
            <tr><td>-40°C</td><td>-40°F</td><td>Scales are equal at this point</td></tr>
            <tr><td>-20°C</td><td>-4°F</td><td>Very cold winter day</td></tr>
            <tr><td>0°C</td><td>32°F</td><td>Water freezes</td></tr>
            <tr><td>10°C</td><td>50°F</td><td>Cool spring day</td></tr>
            <tr><td>20°C</td><td>68°F</td><td>Comfortable room temperature</td></tr>
            <tr><td>25°C</td><td>77°F</td><td>Warm room / mild summer day</td></tr>
            <tr><td>30°C</td><td>86°F</td><td>Hot day</td></tr>
            <tr><td>37°C</td><td>98.6°F</td><td>Normal body temperature</td></tr>
            <tr><td>38°C</td><td>100.4°F</td><td>Fever threshold (adults)</td></tr>
            <tr><td>40°C</td><td>104°F</td><td>Extreme heat / high fever</td></tr>
            <tr><td>100°C</td><td>212°F</td><td>Water boils at sea level</td></tr>
            <tr><td>180°C</td><td>356°F</td><td>Moderate oven (baking)</td></tr>
            <tr><td>200°C</td><td>392°F</td><td>Hot oven</td></tr>
            <tr><td>220°C</td><td>428°F</td><td>Very hot oven</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Celsius to Fahrenheit?</h2>
      <p>The Celsius–Fahrenheit conversion is the most common temperature conversion. The US uses Fahrenheit for everyday temperatures (weather, cooking, body temperature) while most of the world uses Celsius. Common situations:</p>
      <ul>
        <li><strong>Cooking</strong> - US recipes specify oven temperatures in °F; European or metric recipes use °C. A 350°F oven = 176.7°C; a 180°C oven = 356°F.</li>
        <li><strong>Weather</strong> - travelling between the US and Europe means reading weather forecasts in an unfamiliar scale.</li>
        <li><strong>Medicine</strong> - US clinical references often give body temperature in °F (98.6°F = 37°C; fever at 100.4°F = 38°C).</li>
        <li><strong>Science</strong> - lab work uses Celsius globally; some older US scientific publications used Fahrenheit.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How do you convert Celsius to Fahrenheit?</h3>
      <p>Multiply by 9/5 then add 32. Formula: °F = °C × 9/5 + 32. Example: 37°C × 9/5 = 66.6, + 32 = 98.6°F. Quick mental estimate: double the Celsius and add 30 (works within ~5°F for everyday temps).</p>

      <h3>What is 37 degrees Celsius in Fahrenheit?</h3>
      <p>37°C = 98.6°F. Calculation: 37 × 1.8 + 32 = 66.6 + 32 = 98.6°F. This is normal adult body temperature. A temperature of 38°C (100.4°F) is generally the threshold for a fever in adults.</p>

      <h3>What is 20°C in Fahrenheit?</h3>
      <p>20°C = 68°F. Calculation: 20 × 9/5 + 32 = 36 + 32 = 68°F. This is a comfortable room temperature and a common indoor thermostat setting in Celsius countries.</p>

      <h3>What is the same temperature in Celsius and Fahrenheit?</h3>
      <p>-40 degrees. At -40, both scales give the same number: -40°C = -40°F. Above -40, Fahrenheit is always numerically higher than Celsius. Below -40, Fahrenheit is lower.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">🌡️</span>
          <div>
            <a href="/conversion/temperature-converter/f-to-c">Fahrenheit to Celsius Converter</a>
            <p>Reverse conversion - enter °F and get °C instantly, with a Fahrenheit-first reference table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">🌡️</span>
          <div>
            <a href="/conversion/temperature-converter/c-to-k">Celsius to Kelvin Converter</a>
            <p>Convert °C to Kelvin - add 273.15. Used in chemistry and physics.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">🌡️</span>
          <div>
            <a href="/conversion/temperature-converter">Temperature Converter (all scales)</a>
            <p>Convert between Celsius, Fahrenheit, Kelvin, Rankine, and Réaumur simultaneously.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">⚖️</span>
          <div>
            <a href="/conversion/weight-converter">Weight Converter</a>
            <p>Convert between kilograms, pounds, ounces, stone, and more.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
