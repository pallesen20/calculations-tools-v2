    <script src="/js/currency-converter-v2.js" is:inline></script>

    <a href="https://wise.prf.hn/click/camref:1011lkBX5/creativeref:1101l100659" target="_blank" rel="sponsored"><img src="https://wise-creative.prf.hn/source/camref:1011lkBX5/creativeref:1101l100659" style="width:-webkit-fill-available;display:block;margin:1rem 0" alt="Send money internationally banner"/></a>

    <section class="cc-chart-section" id="cp-chart-section" style="display:none">
      <div class="cc-chart-header">
        <h2 id="cp-chart-title">Exchange rate history</h2>
        <div class="cc-chart-btns">
          <button class="cc-chart-btn" data-days="7">1W</button>
          <button class="cc-chart-btn active" data-days="30">1M</button>
          <button class="cc-chart-btn" data-days="90">3M</button>
