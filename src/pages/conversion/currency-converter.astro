      <div class="cc-pairings-grid">
        {POPULAR_PAIRS.map(([from, to]) => (
          <a href={`/conversion/currency-converter/${from.toLowerCase()}-to-${to.toLowerCase()}`} class="cc-pairing-card">
            <span class="cc-pairing-code">{from} → {to}</span>
