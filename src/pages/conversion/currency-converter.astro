];

const tocItems = [
  { id: 'how-to-use',           label: 'How to use this converter' },
  { id: 'mid-market',           label: 'The mid-market rate' },
  { id: 'how-rates-work',       label: 'How exchange rates work' },
  { id: 'provider-comparison',  label: 'Comparing exchange providers' },
  { id: 'popular-pairs',        label: 'Popular currency pairs' },
  { id: 'all-pairs',            label: 'All currency pair converters' },
  { id: 'travelers',            label: 'Practical tips for travelers' },
  { id: 'common-mistakes',      label: 'Common mistakes' },
  { id: 'faq',                  label: 'FAQs' },
  { id: 'related-tools',        label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Currency Converter",
    "url": "https://calculations.tools/conversion/currency-converter",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "description": "Convert between 150+ currencies using live mid-market exchange rates. Includes a multi-currency comparison table. Free, no sign-up.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://calculations.tools/conversion/currency-converter?from={from_currency}&to={to_currency}&amount={amount}"
      },
      "query-input": "name=from_currency name=to_currency required name=amount"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert currencies with this tool",
    "description": "Step-by-step guide to converting between currencies using live mid-market rates.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter an amount", "text": "Type the amount you want to convert in the Amount field." },
      { "@type": "HowToStep", "position": 2, "name": "Select source currency", "text": "Choose the currency you are converting from in the left dropdown." },
      { "@type": "HowToStep", "position": 3, "name": "Select target currency", "text": "Choose the currency you want to convert to in the right dropdown." },
      { "@type": "HowToStep", "position": 4, "name": "Read the result", "text": "The converted amount and current exchange rate appear instantly below. Use the swap button to reverse the conversion direction." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is the mid-market exchange rate?", "acceptedAnswer": { "@type": "Answer", "text": "The mid-market rate is the midpoint between the buy and sell prices for two currencies on the global foreign exchange market. It is the rate banks use when trading with each other - also called the interbank rate. It has no markup added, which is why it differs from what banks and exchange bureaus offer to consumers." } },
      { "@type": "Question", "name": "Why is my bank's exchange rate different?", "acceptedAnswer": { "@type": "Answer", "text": "Banks add a profit margin - typically 2 to 5% - to the mid-market rate for retail customers. Airport exchange desks often charge 8 to 12% above mid-market. This converter shows the mid-market rate so you can see the true exchange rate and identify how much markup you are paying elsewhere." } },
      { "@type": "Question", "name": "How often are the exchange rates updated?", "acceptedAnswer": { "@type": "Answer", "text": "Rates are updated once per day. The exact update time is shown below the exchange rate in the converter. For high-value or time-sensitive transactions, always confirm the rate with your actual payment provider." } },
      { "@type": "Question", "name": "What is a bid-ask spread in currency exchange?", "acceptedAnswer": { "@type": "Answer", "text": "The bid price is what a market maker will pay to buy a currency from you. The ask price is what they charge to sell it to you. The difference between these two prices is the spread, which is the market maker's profit. The mid-market rate sits exactly between the bid and ask." } },
      { "@type": "Question", "name": "What is the cheapest way to exchange currency?", "acceptedAnswer": { "@type": "Answer", "text": "Fintech transfer services (such as Wise or Revolut) typically offer the closest rates to mid-market with transparent flat fees, making them the most cost-effective for most amounts. Credit cards with no foreign transaction fee are also competitive. Bank wire transfers and airport exchange desks tend to be the most expensive options." } },
      { "@type": "Question", "name": "How do I convert USD to EUR?", "acceptedAnswer": { "@type": "Answer", "text": "Select USD in the left dropdown, enter your amount, then select EUR in the right dropdown. The converted amount appears instantly. You can also use the swap button to reverse the conversion." } },
      { "@type": "Question", "name": "What is a currency cross rate?", "acceptedAnswer": { "@type": "Answer", "text": "A cross rate is the exchange rate between two currencies that are neither the US dollar nor the domestic currency of the country where the rate is quoted. For example, EUR/JPY is a cross rate. Cross rates are usually calculated through their USD values - the USD acts as an intermediary in most global currency pricing." } },
      { "@type": "Question", "name": "Are cryptocurrency conversions supported?", "acceptedAnswer": { "@type": "Answer", "text": "No. This converter covers traditional fiat currencies only. Cryptocurrency markets are open 24/7 and use entirely different pricing mechanisms, so they require separate tools." } }
    ]
  }
];
---

