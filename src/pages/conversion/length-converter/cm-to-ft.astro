---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{ft} = \\text{cm} \\div 30.48$$",
  rev: "$$\\text{cm} = \\text{ft} \\times 30.48$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert cm to feet' },
  { id: 'reverse',         label: 'How to convert feet to cm' },
  { id: 'reference-table', label: 'Centimeters to feet reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Centimeters to Feet Converter",
    "url": "https://calculations.tools/conversion/length-converter/cm-to-ft",
    "description": "Convert centimeters to feet instantly. Formula: ft = cm ÷ 30.48. Includes reverse feet to cm conversion and a height reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert centimeters to feet",
    "description": "Convert centimeters to feet using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter centimeters value", "text": "Type your cm value in the cm field. The feet result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted feet value appears immediately. For 170 cm, the result is 5.57743 ft." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the ft field to convert back to centimeters. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many feet is 170 cm?",
        "acceptedAnswer": { "@type": "Answer", "text": "170 cm equals 5.57743 feet (approximately 5 feet 6.9 inches). Divide 170 by 30.48 to get the exact result. 170 cm is the approximate global average height for adult males." }
      },
      {
        "@type": "Question",
        "name": "How do you convert centimeters to feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide centimeters by 30.48 to get feet. Example: 180 cm ÷ 30.48 = 5.90551 ft. The factor 30.48 comes from the definition of one foot as exactly 30.48 cm (or 0.3048 m)." }
      },
      {
        "@type": "Question",
        "name": "How many cm is 5 feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "5 feet equals exactly 152.4 cm. Multiply 5 by 30.48: 5 × 30.48 = 152.4 cm. Each foot is exactly 30.48 cm, so the calculation is straightforward." }
      },
      {
        "@type": "Question",
        "name": "How many cm is 6 feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "6 feet equals exactly 182.88 cm. Multiply 6 by 30.48: 6 × 30.48 = 182.88 cm." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Centimeters to Feet Converter"
  metaTitle="Centimeters to Feet Converter | Calculate cm to ft ᐅ"
  description="Convert centimeters to feet instantly. Formula: ft = cm ÷ 30.48. Height reference table included - find 170 cm, 175 cm, 180 cm in feet and more."
  canonical="https://calculations.tools/conversion/length-converter/cm-to-ft"
  tocItems={tocItems}
  embedSlug="cm-to-ft"
  schema={schema}
  ogFormula="ft = cm ÷ 30.48"
  ogExample="170 cm = 5.577 ft"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Centimeter to Foot (cm to ft) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Centimeters (cm)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 170" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Feet (ft)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 5.577" />
          </div>
        </div>

        <div class="pair-formula-note">1 ft = 30.48 cm &nbsp;·&nbsp; 1 cm = 0.032808 ft</div>

      </div>
    </section>

    <script src="/js/cm-to-ft.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert centimeters to feet, divide by <strong>30.48</strong>. So 170 cm = 5.577 ft and 180 cm = 5.906 ft. The factor is exact - one foot is defined as exactly 30.48 cm since the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 ft = 30.48 cm (defined, not approximate).</li>
          <li>170 cm = 5.577 ft (≈ 5 ft 6.9 in) - approximate global male average height.</li>
          <li>165 cm = 5.413 ft (≈ 5 ft 5 in) - approximate global female average height.</li>
          <li>Quick mental check: divide cm by 30 for a rough estimate (slightly high by ~1.6%).</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any centimeter value in the cm field and the feet result appears instantly. You can also type in the ft field to convert back to centimeters - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Centimeters to Feet?</h2>
      <p>Divide centimeters by 30.48. One foot is defined as exactly 0.3048 meters, which equals exactly 30.48 centimeters. There is no approximation involved.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 160 cm ÷ 30.48 = 5.249 ft. 175 cm ÷ 30.48 = 5.741 ft. 190 cm ÷ 30.48 = 6.234 ft.</p>

      <p>Mental shortcut: divide by 30 and subtract ~1.6%. Or use the common benchmark - 5 ft = 152.4 cm, so every additional foot adds 30.48 cm.</p>

      <h2 id="reverse">How Do You Convert Feet to Centimeters?</h2>
      <p>Multiply feet by 30.48. For fractional feet (e.g. 5'10"), first convert everything to decimal feet: 5 + 10/12 = 5.833 ft, then multiply by 30.48 = 177.8 cm. For a dedicated page, see the <a href="/conversion/length-converter/ft-to-cm">feet to centimeters converter</a>.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 5 ft = 152.4 cm. 6 ft = 182.88 cm. 5.5 ft = 167.64 cm.</p>

      <h2 id="reference-table">Centimeters to Feet Reference Table</h2>
      <p>Common height values converted using the exact factor 1 ÷ 30.48:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Centimeters</th><th>Feet (decimal)</th><th>Feet &amp; inches</th></tr>
          </thead>
          <tbody>
            <tr><td>150 cm</td><td>4.921 ft</td><td>4 ft 11 in</td></tr>
            <tr><td>155 cm</td><td>5.085 ft</td><td>5 ft 1 in</td></tr>
            <tr><td>160 cm</td><td>5.249 ft</td><td>5 ft 3 in</td></tr>
            <tr><td>163 cm</td><td>5.348 ft</td><td>5 ft 4.2 in</td></tr>
            <tr><td>165 cm</td><td>5.413 ft</td><td>5 ft 5 in</td></tr>
            <tr><td>170 cm</td><td>5.577 ft</td><td>5 ft 6.9 in</td></tr>
            <tr><td>175 cm</td><td>5.741 ft</td><td>5 ft 8.9 in</td></tr>
            <tr><td>178 cm</td><td>5.840 ft</td><td>5 ft 10.1 in</td></tr>
            <tr><td>180 cm</td><td>5.906 ft</td><td>5 ft 10.9 in</td></tr>
            <tr><td>183 cm</td><td>6.004 ft</td><td>6 ft 0.1 in</td></tr>
            <tr><td>185 cm</td><td>6.070 ft</td><td>6 ft 0.8 in</td></tr>
            <tr><td>190 cm</td><td>6.234 ft</td><td>6 ft 2.8 in</td></tr>
            <tr><td>200 cm</td><td>6.562 ft</td><td>6 ft 6.7 in</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Centimeters to Feet?</h2>
      <p>The cm-to-feet conversion is most commonly needed for human height. Medical systems in the US record height in feet and inches, while most other countries use centimeters. This creates practical conversion needs for:</p>
      <ul>
        <li><strong>Health records</strong> - comparing or entering height when systems use different units.</li>
        <li><strong>Online forms</strong> - many US fitness apps and dating profiles use feet/inches.</li>
        <li><strong>Sports</strong> - player heights in basketball, football, and athletics are often quoted in both units depending on the audience.</li>
        <li><strong>Travel</strong> - US building regulations and infrastructure (clearance heights, doorways) use feet.</li>
      </ul>
      <p>For height conversions that also include the inches component (e.g. "5 ft 9 in"), use the <a href="/conversion/height-converter">height converter</a> which handles the feet-and-inches format directly.</p>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many feet is 170 cm?</h3>
      <p>170 cm equals 5.577 feet, which is approximately 5 feet 6.9 inches. This is often rounded to "5 foot 7" in everyday conversation. It corresponds to the approximate global average height for adult males (World Health Organization data).</p>

      <h3>How do you convert centimeters to feet?</h3>
      <p>Divide by 30.48. The factor comes directly from the international definition: 1 foot = 0.3048 m = 30.48 cm. There is no rounding in this definition - it is exact.</p>

      <h3>How many cm is 5 feet?</h3>
      <p>5 feet equals exactly 152.4 cm. Each foot is 30.48 cm, so 5 × 30.48 = 152.4 cm. To convert back, 152.4 ÷ 30.48 = 5.000 exactly.</p>

      <h3>How many cm is 6 feet?</h3>
      <p>6 feet equals exactly 182.88 cm. This is a commonly quoted height for tall adults. In metric contexts it is typically rounded to 183 cm. Use the <a href="/conversion/length-converter/ft-to-cm">feet to centimeters converter</a> to check any feet value instantly.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-cm">Feet to Centimeters Converter</a>
            <p>Reverse conversion - enter feet and get centimeters instantly.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📐</span>
          <div>
            <a href="/conversion/height-converter">Height Converter</a>
            <p>Convert height between cm, feet and inches, and meters - handles the ft/in format.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-in">Centimeters to Inches Converter</a>
            <p>Convert cm to inches - useful for screen sizes and body measurements.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-in">Feet to Inches Converter</a>
            <p>Convert feet to inches within the imperial system.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
