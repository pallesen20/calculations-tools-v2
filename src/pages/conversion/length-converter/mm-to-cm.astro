---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{cm} = \\text{mm} \\div 10$$",
  rev: "$$\\text{mm} = \\text{cm} \\times 10$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert mm to cm' },
  { id: 'reverse',         label: 'How to convert cm to mm' },
  { id: 'reference-table', label: 'Millimeters to centimeters reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Millimeters to Centimeters Converter",
    "url": "https://calculations.tools/conversion/length-converter/mm-to-cm",
    "description": "Convert millimeters to centimeters instantly. Formula: cm = mm ÷ 10. Includes reverse cm to mm conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert millimeters to centimeters",
    "description": "Convert millimeters to centimeters by dividing by 10.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter millimeters value", "text": "Type your mm value in the mm field. The cm result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted cm value appears immediately. For 10 mm, the result is 1 cm." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the cm field to convert back to mm. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many cm is 1 mm?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 mm equals 0.1 cm. There are exactly 10 millimeters in one centimeter, so 1 mm = 1/10 cm = 0.1 cm." }
      },
      {
        "@type": "Question",
        "name": "How do you convert mm to cm?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide millimeters by 10. Example: 50 mm ÷ 10 = 5 cm. The factor is exact: 1 cm = 10 mm by the SI metric prefix definition." }
      },
      {
        "@type": "Question",
        "name": "How many mm is 1 cm?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 cm equals exactly 10 mm. This is the SI definition: the prefix 'centi-' means 1/100 and 'milli-' means 1/1000, so 1 cm = 10 mm." }
      },
      {
        "@type": "Question",
        "name": "What is 25 mm in cm?",
        "acceptedAnswer": { "@type": "Answer", "text": "25 mm equals 2.5 cm. Divide 25 by 10: 25 ÷ 10 = 2.5 cm." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Millimeters to Centimeters Converter"
  metaTitle="Millimeters to Centimeters | mm to cm"
  description="Convert millimeters to centimeters instantly. Formula: cm = mm ÷ 10. Includes reverse cm to mm conversion and a reference table for sewing and crafts."
  canonical="https://calculations.tools/conversion/length-converter/mm-to-cm"
  tocItems={tocItems}
  embedSlug="mm-to-cm"
  schema={schema}
  ogFormula="cm = mm ÷ 10"
  ogExample="10 mm = 1 cm"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Millimeters to Centimeters Converter</h2>
          <p>Type in either field — converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Millimeters (mm)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 10" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Centimeters (cm)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
        </div>

        <div class="pair-formula-note">1 cm = 10 mm &nbsp;·&nbsp; 1 mm = 0.1 cm</div>

      </div>
    </section>

    <script src="/js/mm-to-cm.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert millimeters to centimeters, divide by <strong>10</strong>. So 10 mm = 1 cm, 25 mm = 2.5 cm, and 100 mm = 10 cm. The factor is exact — 1 cm = 10 mm by the SI metric prefix system.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 cm = 10 mm (SI prefix definition, no approximation).</li>
          <li>10 mm = 1 cm. 25 mm = 2.5 cm. 100 mm = 10 cm = 1 dm.</li>
          <li>The conversion is a simple decimal shift — just move the decimal point one place left.</li>
          <li>Common use cases: sewing patterns, woodworking, medical measurements.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any millimeter value in the mm field and the centimeters result appears instantly. You can also type in the cm field to convert back to millimeters — it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Millimeters to Centimeters?</h2>
      <p>Divide millimeters by 10. The relationship is exact: the SI prefix "centi-" means 1/100 and "milli-" means 1/1000, so there are exactly 10 mm in every centimeter. No rounding is ever needed.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 5 mm = 0.5 cm. 10 mm = 1 cm. 50 mm = 5 cm. 100 mm = 10 cm. 210 mm = 21 cm (A4 paper width).</p>

      <p>Mental shortcut: simply move the decimal point one place to the left. 125 mm → 12.5 cm. This is the simplest conversion in the metric system.</p>

      <h2 id="reverse">How Do You Convert Centimeters to Millimeters?</h2>
      <p>Multiply centimeters by 10. For a dedicated reverse converter, see the <a href="/conversion/length-converter/cm-to-mm">centimeters to millimeters converter</a>.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 1 cm = 10 mm. 2.5 cm = 25 mm. 30 cm = 300 mm (standard ruler length).</p>

      <h2 id="reference-table">Millimeters to Centimeters Reference Table</h2>
      <p>Common values converted at the exact factor of 0.1:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Millimeters</th><th>Centimeters</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>1 mm</td><td>0.1 cm</td><td>Fine line on a ruler</td></tr>
            <tr><td>5 mm</td><td>0.5 cm</td><td>Standard pencil diameter</td></tr>
            <tr><td>10 mm</td><td>1 cm</td><td>Small button diameter</td></tr>
            <tr><td>25 mm</td><td>2.5 cm</td><td>Approx. 1 inch (25.4 mm exactly)</td></tr>
            <tr><td>50 mm</td><td>5 cm</td><td>Standard camera filter rim</td></tr>
            <tr><td>100 mm</td><td>10 cm</td><td>Smartphone width (approx.)</td></tr>
            <tr><td>150 mm</td><td>15 cm</td><td>6-inch ruler</td></tr>
            <tr><td>210 mm</td><td>21 cm</td><td>A4 paper width</td></tr>
            <tr><td>297 mm</td><td>29.7 cm</td><td>A4 paper height</td></tr>
            <tr><td>300 mm</td><td>30 cm</td><td>Standard 30 cm ruler</td></tr>
            <tr><td>500 mm</td><td>50 cm</td><td>Half a meter</td></tr>
            <tr><td>1000 mm</td><td>100 cm</td><td>1 meter exactly</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Millimeters to Centimeters?</h2>
      <p>Within the metric system, mm and cm are the two most common small-length units. The conversion is needed when measurements come from different sources or instruments:</p>
      <ul>
        <li><strong>Sewing and crafts</strong> — patterns often mix mm and cm; seam allowances in mm, fabric widths in cm.</li>
        <li><strong>Woodworking</strong> — European rulers show both; joinery and inlay work is often specified in mm, room dimensions in cm.</li>
        <li><strong>Medical</strong> — tumour sizes and wound measurements are recorded in mm; height and anatomy in cm.</li>
        <li><strong>Photography</strong> — focal lengths and sensor dimensions are in mm; print sizes are in cm.</li>
        <li><strong>Engineering drawings</strong> — tolerances in mm, overall part dimensions often in cm for readability.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many cm is 1 mm?</h3>
      <p>1 mm equals 0.1 cm. There are 10 millimeters in one centimeter, so 1 mm is one-tenth of a centimeter. In decimal notation: 1 mm = 0.1 cm = 0.001 m.</p>

      <h3>How do you convert mm to cm?</h3>
      <p>Divide by 10, or equivalently move the decimal point one place to the left. This is the simplest conversion in the SI system. 125 mm → 12.5 cm. 7 mm → 0.7 cm.</p>

      <h3>How many mm is 1 cm?</h3>
      <p>Exactly 10 mm. Use the <a href="/conversion/length-converter/cm-to-mm">centimeters to millimeters converter</a> to check any cm value. For converting further to inches, see the <a href="/conversion/length-converter/mm-to-in">mm to inches converter</a>.</p>

      <h3>What is 25 mm in cm?</h3>
      <p>25 mm equals 2.5 cm. This is close to 1 inch (which is exactly 25.4 mm = 2.54 cm). For mm to inches, use the <a href="/conversion/length-converter/mm-to-in">millimeters to inches converter</a>.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-mm">Centimeters to Millimeters Converter</a>
            <p>Reverse conversion — enter cm and get mm instantly.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/mm-to-in">Millimeters to Inches Converter</a>
            <p>Convert mm to inches for engineering and hardware applications.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-in">Centimeters to Inches Converter</a>
            <p>Convert cm to inches — useful for screen sizes and clothing dimensions.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
