---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{ft} = \\text{m} \\div 0.3048$$",
  rev: "$$\\text{m} = \\text{ft} \\times 0.3048$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert meters to feet' },
  { id: 'reverse',         label: 'How to convert feet to meters' },
  { id: 'reference-table', label: 'Meters to feet reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Meters to Feet Converter",
    "url": "https://calculations.tools/conversion/length-converter/m-to-ft",
    "description": "Convert meters to feet instantly. Formula: ft = m ÷ 0.3048. Includes reverse feet to meters conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert meters to feet",
    "description": "Convert meters to feet using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter meters value", "text": "Type your meters value in the m field. The feet result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted feet value appears immediately. For 1 m, the result is 3.28084 ft." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the ft field to convert back to meters. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many feet is 1 meter?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 meter equals 3.28084 feet. The exact value is 1 ÷ 0.3048, since one foot is defined as exactly 0.3048 meters by the International Yard and Pound Agreement of 1959. The conversion is precise, not an approximation." }
      },
      {
        "@type": "Question",
        "name": "How do you convert meters to feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide meters by 0.3048 to get feet. Alternatively, multiply by 3.28084. Example: 10 m ÷ 0.3048 = 32.8084 ft. For a quick estimate, multiply by 3.28 - the error is under 0.025%." }
      },
      {
        "@type": "Question",
        "name": "How many meters is 6 feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "6 feet equals 1.8288 meters. Multiply feet by 0.3048: 6 × 0.3048 = 1.8288 m exactly. This is the commonly quoted height for a tall person - just over 1.83 m is how it's typically rounded in medical contexts." }
      },
      {
        "@type": "Question",
        "name": "Is a meter longer than a foot?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. One meter is 3.28084 feet - roughly 3 feet and 3.4 inches. A meter is about 9.4% longer than a yard (3 feet). A meter is 100 cm; a foot is 30.48 cm." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Meters to Feet Converter"
  metaTitle="Meters to Feet Converter | Calculate meters to imperial ft ᐅ"
  description="Convert meters to feet instantly. Formula: ft = m ÷ 0.3048. Reverse feet to meters included. Reference table for common heights and distances."
  canonical="https://calculations.tools/conversion/length-converter/m-to-ft"
  tocItems={tocItems}
  embedSlug="m-to-ft"
  schema={schema}
  ogFormula="ft = m ÷ 0.3048"
  ogExample="1 m = 3.28084 ft"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Meters to Feet (m to ft) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Meters (m)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Feet (ft)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 3.28084" />
          </div>
        </div>

        <div class="pair-formula-note">1 m = 3.28084 ft &nbsp;·&nbsp; 1 ft = 0.3048 m</div>

      </div>
    </section>

    <script src="/js/m-to-ft.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert meters to feet, divide by <strong>0.3048</strong> (or multiply by 3.28084). So 1 m = 3.28084 ft. The factor is exact - one foot is defined as exactly 0.3048 meters since the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 ft = 0.3048 m (international definition, fixed in 1959).</li>
          <li>1 meter = 3.28084 ft, or 3 ft 3.37 in.</li>
          <li>Quick mental check: multiply meters by 3.28 for a close estimate (error under 0.025%).</li>
          <li>The US and UK are the main countries still using feet for everyday heights and distances (NIST, 2023).</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any value in the meters field and the feet result appears instantly. You can also type in the feet field to convert back to meters - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Meters to Feet?</h2>
      <p>Divide meters by 0.3048. This is an exact factor: one foot is defined as exactly 0.3048 meters under the International Yard and Pound Agreement of 1959, signed by the US, UK, Canada, Australia, New Zealand, and South Africa. There is no rounding.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 1.8 m = 5.905 ft. 10 m = 32.808 ft. 100 m = 328.084 ft.</p>

      <p>Mental shortcut: multiply by 3.28 for a quick estimate. The error is only 0.025%, which is negligible for everyday use.</p>

      <h2 id="reverse">How Do You Convert Feet to Meters?</h2>
      <p>Multiply feet by 0.3048. This is the same exact definition used in reverse. For a full multi-unit converter, the <a href="/conversion/length-converter">length converter</a> handles all metric and imperial units simultaneously.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 5 ft = 1.524 m. 6 ft = 1.8288 m. 100 ft = 30.48 m.</p>

      <h2 id="reference-table">Meters to Feet Reference Table</h2>
      <p>Common values converted using the exact factor 1 ÷ 0.3048 = 3.280839895...</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Meters</th><th>Feet</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>0.5 m</td><td>1.64 ft</td><td>Counter height</td></tr>
            <tr><td>1 m</td><td>3.281 ft</td><td>Approx. 3 ft 3 in</td></tr>
            <tr><td>1.5 m</td><td>4.921 ft</td><td>Average child height</td></tr>
            <tr><td>1.65 m</td><td>5.413 ft</td><td>Average adult female height (global)</td></tr>
            <tr><td>1.75 m</td><td>5.741 ft</td><td>Average adult male height (global)</td></tr>
            <tr><td>1.83 m</td><td>6.004 ft</td><td>Approx. 6 feet</td></tr>
            <tr><td>2 m</td><td>6.562 ft</td><td>Standard ceiling height</td></tr>
            <tr><td>5 m</td><td>16.404 ft</td><td>One-storey building</td></tr>
            <tr><td>10 m</td><td>32.808 ft</td><td>Three storeys</td></tr>
            <tr><td>100 m</td><td>328.084 ft</td><td>Short sprint distance</td></tr>
            <tr><td>1000 m</td><td>3,280.84 ft</td><td>1 kilometer</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Meters to Feet?</h2>
      <p>The meter/foot divide follows a geographic split. According to NIST (2023), only the US, Liberia, and Myanmar use feet as a primary unit for everyday measurement. This creates conversion needs for travellers, architects working across borders, and anyone reading international height or distance data.</p>
      <ul>
        <li><strong>Height</strong> - medical records in the US use feet and inches; international records use meters and centimeters.</li>
        <li><strong>Aviation</strong> - altitude is given in feet globally (even in metric countries), per ICAO convention.</li>
        <li><strong>Construction</strong> - US blueprints use feet; European blueprints use meters.</li>
        <li><strong>Sports</strong> - track and field events are measured in meters; American football uses yards and feet.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many feet is 1 meter?</h3>
      <p>1 meter is 3.28084 feet. The exact conversion is 1 ÷ 0.3048 = 3.280839895... ft. In practical terms, 1 meter is about 3 feet and 3⅜ inches - slightly more than a yard (which is exactly 3 feet).</p>

      <h3>How do you convert meters to feet?</h3>
      <p>Divide by 0.3048 or multiply by 3.28084. Both are equivalent - 3.28084 is simply 1 ÷ 0.3048 rounded to 5 decimal places. The exact factor is a repeating decimal: 3.2808398950131...</p>

      <h3>How many meters is 6 feet?</h3>
      <p>6 feet is exactly 1.8288 meters. Multiply 6 by 0.3048: 6 × 0.3048 = 1.8288 m. This is a commonly cited height - in clinical settings it's often rounded to 1.83 m.</p>

      <h3>Is a meter longer than a foot?</h3>
      <p>Yes - a meter is 3.28084 feet, so it's more than three times the length of a foot. A meter is also about 9.4% longer than a yard (0.9144 m). If you need to compare meters and yards, use the <a href="/conversion/length-converter/m-to-yd">meters to yards converter</a>.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-m">Feet to Meters Converter</a>
            <p>Reverse conversion - dedicated page with feet-first reference table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-in">Centimeters to Inches Converter</a>
            <p>Convert cm to inches - useful for screen sizes, clothing, and body measurements.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-ft">Centimeters to Feet Converter</a>
            <p>Convert cm to feet - the most common height lookup (170 cm, 175 cm, 180 cm in feet).</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-in">Feet to Inches Converter</a>
            <p>Convert feet to total inches within the imperial system.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📐</span>
          <div>
            <a href="/conversion/height-converter">Height Converter</a>
            <p>Convert height between cm, feet and inches, and meters with a full reference table.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
