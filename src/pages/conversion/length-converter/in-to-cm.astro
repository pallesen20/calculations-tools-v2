---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{cm} = \\text{in} \\times 2.54$$",
  rev: "$$\\text{in} = \\text{cm} \\div 2.54$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert inches to cm' },
  { id: 'reverse',         label: 'How to convert cm to inches' },
  { id: 'reference-table', label: 'Inches to cm reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Inches to Centimeters Converter",
    "url": "https://calculations.tools/conversion/length-converter/in-to-cm",
    "description": "Convert inches to centimeters instantly. Formula: cm = in × 2.54. Includes reverse cm to inches conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert inches to centimeters",
    "description": "Convert inches to centimeters using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter inches value", "text": "Type your inches value in the in field. The cm result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted cm value appears immediately. For 1 in, the result is 2.54 cm." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the cm field to convert back to inches. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many cm is 1 inch?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 inch equals exactly 2.54 centimeters. This is a fixed international standard established by the International Yard and Pound Agreement of 1959. The factor is exact - not a rounded approximation." }
      },
      {
        "@type": "Question",
        "name": "How do you convert inches to centimeters?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply inches by 2.54. Example: 10 in × 2.54 = 25.4 cm. The factor 2.54 is exact, so the conversion introduces no rounding error. For a quick mental estimate, multiply by 2.5 - the result is about 1.6% low." }
      },
      {
        "@type": "Question",
        "name": "How many inches is 30 cm?",
        "acceptedAnswer": { "@type": "Answer", "text": "30 cm equals 11.811 inches. Divide by 2.54: 30 ÷ 2.54 = 11.811 in. A 30 cm ruler is very close to 12 inches (one foot) - the difference is less than 2 mm." }
      },
      {
        "@type": "Question",
        "name": "How many cm is 5 feet 10 inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "5 feet 10 inches equals 177.8 cm. Convert to total inches: 5 × 12 + 10 = 70 in. Then multiply by 2.54: 70 × 2.54 = 177.8 cm. The height converter handles feet-and-inches input directly." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Inches to Centimeters Converter"
  metaTitle="Inches to Centimeters Converter | Calculate in to cm ᐅ"
  description="Convert inches to centimeters instantly. Formula: cm = in × 2.54. Reverse cm to inches included. Reference table for screen sizes, clothing, and body measurements."
  canonical="https://calculations.tools/conversion/length-converter/in-to-cm"
  tocItems={tocItems}
  embedSlug="in-to-cm"
  schema={schema}
  ogFormula="cm = in × 2.54"
  ogExample="12 in = 12 × 2.54 = 30.48 cm"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Inch to Centimeter (in to cm) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Inches (in)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Centimeters (cm)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 2.54" />
          </div>
        </div>

        <div class="pair-formula-note">1 in = 2.54 cm &nbsp;·&nbsp; 1 cm = 0.393701 in</div>

      </div>
    </section>

    <script src="/js/in-to-cm.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert inches to centimeters, multiply by <strong>2.54</strong>. So 1 in = 2.54 cm. The factor is exact - one inch is defined as exactly 2.54 centimeters since the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 in = 2.54 cm (international definition, fixed in 1959).</li>
          <li>1 foot = 12 inches = 30.48 cm.</li>
          <li>Quick mental check: multiply inches by 2.5 for a close estimate (1.6% low).</li>
          <li>TV and monitor screen sizes are specified in inches in most markets - converting to cm is routine outside the US.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any value in the inches field and the cm result appears instantly. You can also type in the cm field to convert back to inches - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Inches to Centimeters?</h2>
      <p>Multiply inches by 2.54. This factor is exact: one inch is defined as precisely 2.54 centimeters under the International Yard and Pound Agreement of 1959. No rounding is introduced by the conversion factor itself.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 6 in = 15.24 cm. 12 in = 30.48 cm. 36 in = 91.44 cm.</p>

      <p>Mental shortcut: multiply by 2.5 for a quick estimate. The result is 1.6% low - for a 10-inch screen that gives 25 cm instead of 25.4 cm, a 4 mm difference.</p>

      <h2 id="reverse">How Do You Convert Centimeters to Inches?</h2>
      <p>Divide centimeters by 2.54, or multiply by 0.393701. For a full multi-unit converter, the <a href="/conversion/length-converter">length converter</a> handles all units at once.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 10 cm = 3.937 in. 30 cm = 11.811 in. 100 cm = 39.37 in.</p>

      <h2 id="reference-table">Inches to Centimeters Reference Table</h2>
      <p>Common screen sizes, clothing dimensions, and body measurements converted using the exact factor 2.54.</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Inches</th><th>Centimeters</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>1 in</td><td>2.54 cm</td><td>Thumb width approx.</td></tr>
            <tr><td>6 in</td><td>15.24 cm</td><td>Half a foot ruler</td></tr>
            <tr><td>12 in</td><td>30.48 cm</td><td>1 foot / ruler length</td></tr>
            <tr><td>13 in</td><td>33.02 cm</td><td>Small laptop screen</td></tr>
            <tr><td>15.6 in</td><td>39.62 cm</td><td>Standard laptop screen</td></tr>
            <tr><td>24 in</td><td>60.96 cm</td><td>Desktop monitor</td></tr>
            <tr><td>27 in</td><td>68.58 cm</td><td>Large desktop monitor</td></tr>
            <tr><td>32 in</td><td>81.28 cm</td><td>Small TV</td></tr>
            <tr><td>55 in</td><td>139.7 cm</td><td>Large TV</td></tr>
            <tr><td>65 in</td><td>165.1 cm</td><td>Extra-large TV</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Inches to Centimeters?</h2>
      <p>Inches are used in the US and, to some extent, the UK for specific measurements such as screen sizes, waist measurements, and some hardware dimensions. According to NIST (2023), most countries use centimeters for these everyday measurements.</p>
      <ul>
        <li><strong>Screen sizes</strong> - TVs, monitors, and phones are marketed in inches globally. European retailers typically also list the cm equivalent.</li>
        <li><strong>Clothing</strong> - waist and inseam measurements are in inches for US and UK brands; EU sizing uses centimeters.</li>
        <li><strong>Tools and hardware</strong> - drill bits, pipe diameters, and fasteners in the US are in inches; European equivalents are in mm.</li>
        <li><strong>Height</strong> - body height in feet and inches needs converting to cm for international medical records.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many cm is 1 inch?</h3>
      <p>Exactly 2.54 centimeters. This is an internationally fixed definition, not an approximation. It was established in 1959 and is the anchor point for all imperial-to-metric length conversions. A centimeter is 10 millimeters; an inch is 25.4 millimeters.</p>

      <h3>How do you convert inches to centimeters?</h3>
      <p>Multiply by 2.54. Since the factor is exact, the only rounding in your result comes from the number of decimal places you choose to display. Quick mental estimate: multiply by 2.5 (1.6% low). For 10 inches that's 25 cm; the correct answer is 25.4 cm.</p>

      <h3>How many inches is 30 cm?</h3>
      <p>30 cm = 11.811 inches. Divide by 2.54: 30 ÷ 2.54 = 11.811 in. A standard 30 cm ruler is almost exactly 12 inches (one foot) - about 2 mm short. Use the <a href="/conversion/length-converter/cm-to-in">cm to inches converter</a> for the reverse direction.</p>

      <h3>How many cm is 5 feet 10 inches?</h3>
      <p>177.8 cm. Convert to total inches first: 5 × 12 + 10 = 70 in. Multiply by 2.54: 70 × 2.54 = 177.8 cm. For mixed feet-and-inches inputs, the <a href="/conversion/height-converter">height converter</a> handles this automatically.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-in">Centimeters to Inches Converter</a>
            <p>Reverse conversion - cm to inches with a cm-first reference table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📐</span>
          <div>
            <a href="/conversion/height-converter">Height Converter</a>
            <p>Convert height between cm, feet and inches, and meters - handles mixed formats.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/in-to-mm">Inches to Millimeters Converter</a>
            <p>Convert inches to mm for engineering, 3D printing, and hardware applications.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-in">Feet to Inches Converter</a>
            <p>Convert feet to inches - for when you need everything in a single imperial unit.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/m-to-ft">Meters to Feet Converter</a>
            <p>Convert meters to feet - the most common metric-to-imperial length conversion.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
