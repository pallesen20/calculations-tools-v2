---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{m} = \\text{yd} \\times 0.9144$$",
  rev: "$$\\text{yd} = \\text{m} \\div 0.9144$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert yards to meters' },
  { id: 'reverse',         label: 'How to convert meters to yards' },
  { id: 'reference-table', label: 'Yards to meters reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Yards to Meters Converter",
    "url": "https://calculations.tools/conversion/length-converter/yd-to-m",
    "description": "Convert yards to meters instantly. Formula: m = yd × 0.9144. Includes reverse meters to yards conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert yards to meters",
    "description": "Convert yards to meters using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter yards value", "text": "Type your yards value in the yd field. The meters result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted meters value appears immediately. For 1 yd, the result is 0.9144 m." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the m field to convert back to yards. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many meters is 1 yard?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 yard equals exactly 0.9144 meters. This is a fixed international definition from the 1959 International Yard and Pound Agreement. One yard is 3 feet, and since 1 foot = 0.3048 m exactly, 1 yard = 3 × 0.3048 = 0.9144 m." }
      },
      {
        "@type": "Question",
        "name": "How do you convert yards to meters?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply yards by 0.9144. Example: 100 yd × 0.9144 = 91.44 m. The factor is exact. Quick mental estimate: multiply by 0.9 — the result is 0.48% low, which is negligible for most purposes." }
      },
      {
        "@type": "Question",
        "name": "How many yards is 100 meters?",
        "acceptedAnswer": { "@type": "Answer", "text": "100 meters equals 109.36 yards. Divide by 0.9144: 100 ÷ 0.9144 = 109.361 yd. This is why the 100 yard dash was replaced by the 100 meter sprint in track and field — the distances are close but not identical." }
      },
      {
        "@type": "Question",
        "name": "Is a yard bigger than a meter?",
        "acceptedAnswer": { "@type": "Answer", "text": "No — a meter is slightly longer than a yard. 1 meter = 1.09361 yards, so a meter is about 9.4% longer than a yard. Alternatively, 1 yard = 0.9144 m, which is just under 3 feet." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Yards to Meters Converter"
  metaTitle="Yards to Meters Converter | yd to m ᐅ"
  description="Convert yards to meters instantly. Formula: m = yd × 0.9144. Reverse meters to yards included. Reference table for sports fields and fabric measurements."
  canonical="https://calculations.tools/conversion/length-converter/yd-to-m"
  tocItems={tocItems}
  embedSlug="yd-to-m"
  schema={schema}
  ogFormula="m = yd × 0.9144"
  ogExample="100 yd = 91.44 m"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Yards to Meters Converter</h2>
          <p>Type in either field — converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Yards (yd)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Meters (m)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 0.9144" />
          </div>
        </div>

        <div class="pair-formula-note">1 yd = 0.9144 m &nbsp;·&nbsp; 1 m = 1.09361 yd</div>

      </div>
    </section>

    <script src="/js/yd-to-m.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert yards to meters, multiply by <strong>0.9144</strong>. So 100 yd = 91.44 m. The factor is exact — one yard is defined as exactly 0.9144 meters since the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 yd = 0.9144 m (international definition, fixed in 1959).</li>
          <li>1 yard = 3 feet = 36 inches = 0.9144 m.</li>
          <li>Quick mental check: multiply yards by 0.9 for a close estimate (0.48% low).</li>
          <li>American football fields are 100 yards (91.44 m); standard athletics tracks are 400 m (437.4 yd).</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any value in the yards field and the meters result appears instantly. You can also type in the meters field to convert back to yards — it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Yards to Meters?</h2>
      <p>Multiply yards by 0.9144. This is exact: one yard is defined as 3 feet, and one foot is defined as exactly 0.3048 m. So 1 yd = 3 × 0.3048 = 0.9144 m precisely.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 10 yd = 9.144 m. 100 yd = 91.44 m. 1760 yd = 1609.344 m (= 1 mile).</p>

      <h2 id="reverse">How Do You Convert Meters to Yards?</h2>
      <p>Divide meters by 0.9144, or multiply by 1.09361. For a full multi-unit converter, the <a href="/conversion/length-converter">length converter</a> handles all units at once.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 1 m = 1.094 yd. 100 m = 109.36 yd. 400 m = 437.4 yd.</p>

      <h2 id="reference-table">Yards to Meters Reference Table</h2>
      <p>Common sports field dimensions and fabric measurements converted using the exact factor 0.9144.</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Yards</th><th>Meters</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>1 yd</td><td>0.914 m</td><td>Standard yard</td></tr>
            <tr><td>10 yd</td><td>9.144 m</td><td>First down (American football)</td></tr>
            <tr><td>25 yd</td><td>22.86 m</td><td>Short swim lane</td></tr>
            <tr><td>50 yd</td><td>45.72 m</td><td>Short-course pool</td></tr>
            <tr><td>100 yd</td><td>91.44 m</td><td>Old sprint distance</td></tr>
            <tr><td>100 m</td><td>109.36 yd</td><td>Modern sprint distance</td></tr>
            <tr><td>110 yd</td><td>100.584 m</td><td>Approx. 110 m hurdles</td></tr>
            <tr><td>120 yd</td><td>109.728 m</td><td>Close to 110 m</td></tr>
            <tr><td>1760 yd</td><td>1609.344 m</td><td>1 mile</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Yards to Meters?</h2>
      <p>Yards are primarily used in the US for American football, fabric, and some construction contexts. Most international sports and trade use meters. According to NIST (2023), the yard is one of the few imperial units still in common everyday use in the US.</p>
      <ul>
        <li><strong>American football</strong> — field is 100 yards; international reports often give dimensions in meters.</li>
        <li><strong>Swimming</strong> — US pools are often 25 yards; international competition pools are 50 meters.</li>
        <li><strong>Fabric and textiles</strong> — US fabric is sold by the yard; European fabric is sold by the meter.</li>
        <li><strong>Golf</strong> — distances are in yards in the US and UK, meters in most other countries.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many meters is 1 yard?</h3>
      <p>Exactly 0.9144 meters. A yard is 3 feet, and each foot is 0.3048 m, so 3 × 0.3048 = 0.9144 m. A meter is about 9.4% longer than a yard. Put another way, 1 m = 1.09361 yd.</p>

      <h3>How do you convert yards to meters?</h3>
      <p>Multiply by 0.9144. Quick mental estimate: multiply by 0.9 (error 0.48%). For 100 yards: 100 × 0.9 = 90 m; actual is 91.44 m. The 1.44 m difference matters in competitive swimming or track events but is negligible for fabric or garden measurements.</p>

      <h3>How many yards is 100 meters?</h3>
      <p>109.36 yards. Divide 100 by 0.9144 = 109.361 yd. The 100 m sprint is 9.36 yards longer than the old 100 yard dash. That's why world records for the two distances aren't directly comparable — 100 m is about 8.5% farther.</p>

      <h3>Is a yard bigger than a meter?</h3>
      <p>No — a meter is longer. 1 m = 1.09361 yd, so a meter is about 9.4% longer than a yard. If you need to compare yards and feet or yards and miles, the <a href="/conversion/length-converter">length converter</a> handles all imperial units together.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/m-to-yd">Meters to Yards Converter</a>
            <p>Reverse conversion — meters to yards with a meters-first reference table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/m-to-ft">Meters to Feet Converter</a>
            <p>Convert meters to feet — 1 yard = 3 feet, so both converters are closely related.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/mi-to-km">Miles to Kilometers Converter</a>
            <p>Convert miles to km — 1 mile = 1,760 yards = 1.609344 km.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
