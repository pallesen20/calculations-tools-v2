---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{mm} = \\text{in} \\times 25.4$$",
  rev: "$$\\text{in} = \\text{mm} \\div 25.4$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert inches to mm' },
  { id: 'reverse',         label: 'How to convert mm to inches' },
  { id: 'reference-table', label: 'Inches to millimeters reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Inches to Millimeters Converter",
    "url": "https://calculations.tools/conversion/length-converter/in-to-mm",
    "description": "Convert inches to millimeters instantly. Formula: mm = in × 25.4. Includes reverse mm to inches conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert inches to millimeters",
    "description": "Convert inches to millimeters using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter inches value", "text": "Type your inches value in the in field. The mm result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted mm value appears immediately. For 1 in, the result is exactly 25.4 mm." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the mm field to convert back to inches. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many mm is 1 inch?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 inch equals exactly 25.4 mm. This is the international definition set in 1959. All inch-to-mm conversions derive from this exact value." }
      },
      {
        "@type": "Question",
        "name": "How do you convert inches to mm?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply inches by 25.4. Example: 6 in × 25.4 = 152.4 mm. The factor 25.4 is exact - one inch is defined as exactly 25.4 mm." }
      },
      {
        "@type": "Question",
        "name": "How many mm is 12 inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "12 inches equals exactly 304.8 mm. Multiply 12 × 25.4 = 304.8 mm. 12 inches is one foot, so one foot = 304.8 mm = 30.48 cm = 0.3048 m." }
      },
      {
        "@type": "Question",
        "name": "What is 2 inches in mm?",
        "acceptedAnswer": { "@type": "Answer", "text": "2 inches equals exactly 50.8 mm. Multiply 2 × 25.4 = 50.8 mm." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Inches to Millimeters Converter"
  metaTitle="Inches to Millimeters Converter | Calculate in to mm ᐅ"
  description="Convert inches to millimeters instantly. Formula: mm = in × 25.4. Reference table for engineering, 3D printing, and hardware measurements."
  canonical="https://calculations.tools/conversion/length-converter/in-to-mm"
  tocItems={tocItems}
  embedSlug="in-to-mm"
  schema={schema}
  ogFormula="mm = in × 25.4"
  ogExample="1 in = 25.4 mm"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Inch to Millimeter (in to mm) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Inches (in)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Millimeters (mm)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 25.4" />
          </div>
        </div>

        <div class="pair-formula-note">1 in = 25.4 mm &nbsp;·&nbsp; 1 mm = 0.03937 in</div>

      </div>
    </section>

    <script src="/js/in-to-mm.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert inches to millimeters, multiply by <strong>25.4</strong>. So 1 in = 25.4 mm exactly, and 12 in = 304.8 mm. The factor is exact - one inch is defined as exactly 25.4 mm since the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 in = 25.4 mm (defined, not approximate).</li>
          <li>1 in = 25.4 mm. 12 in = 304.8 mm (= 1 foot). 36 in = 914.4 mm (= 1 yard).</li>
          <li>Quick mental estimate: multiply by 25 (result is ~1.6% low).</li>
          <li>Essential for engineering, 3D printing, and hardware spec conversion.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any inch value in the in field and the mm result appears instantly. You can also type in the mm field to convert back to inches - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Inches to Millimeters?</h2>
      <p>Multiply inches by 25.4. One inch is defined as exactly 25.4 mm - this is the foundational international definition from which all other inch-based metric conversions are derived.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 0.5 in = 12.7 mm. 1 in = 25.4 mm. 6 in = 152.4 mm. 12 in = 304.8 mm.</p>

      <p>Mental shortcut: multiply by 25 for a quick estimate. The error is 1.57%, which is usually acceptable for rough checks but not for precision work.</p>

      <h2 id="reverse">How Do You Convert Millimeters to Inches?</h2>
      <p>Divide millimeters by 25.4. For a dedicated reverse converter with reference table, see the <a href="/conversion/length-converter/mm-to-in">millimeters to inches converter</a>.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 50 mm ÷ 25.4 = 1.9685 in. 100 mm ÷ 25.4 = 3.937 in. 254 mm ÷ 25.4 = 10 in.</p>

      <h2 id="reference-table">Inches to Millimeters Reference Table</h2>
      <p>Common values converted using the exact factor 25.4 mm/in:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Inches</th><th>Millimeters</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>1/4 in</td><td>6.35 mm</td><td>Common drill bit size</td></tr>
            <tr><td>1/2 in</td><td>12.7 mm</td><td>Standard pipe size</td></tr>
            <tr><td>1 in</td><td>25.4 mm</td><td>Definition anchor point</td></tr>
            <tr><td>1.5 in</td><td>38.1 mm</td><td>Standard 1-1/2 inch lumber</td></tr>
            <tr><td>2 in</td><td>50.8 mm</td><td>Common camera filter diameter</td></tr>
            <tr><td>3 in</td><td>76.2 mm</td><td>Standard 3-inch drain pipe</td></tr>
            <tr><td>4 in</td><td>101.6 mm</td><td>Standard concrete block width</td></tr>
            <tr><td>6 in</td><td>152.4 mm</td><td>Half a foot</td></tr>
            <tr><td>8 in</td><td>203.2 mm</td><td>Common tile size</td></tr>
            <tr><td>10 in</td><td>254 mm</td><td>iPad screen (approximate)</td></tr>
            <tr><td>12 in</td><td>304.8 mm</td><td>1 foot exactly</td></tr>
            <tr><td>36 in</td><td>914.4 mm</td><td>1 yard exactly</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Inches to Millimeters?</h2>
      <p>Inches-to-mm is a daily conversion in technical fields where US and international standards intersect:</p>
      <ul>
        <li><strong>Engineering drawings</strong> - converting US imperial specifications to metric for international manufacturing or ISO standards.</li>
        <li><strong>3D printing</strong> - many models are designed in inches; metric slicers require mm dimensions.</li>
        <li><strong>Hardware and fasteners</strong> - US bolts are specified in fractional inches; metric equivalents are in mm.</li>
        <li><strong>Woodworking</strong> - US lumber and tools use inch fractions; European machinery uses mm settings.</li>
        <li><strong>Electronics</strong> - PCB trace widths, connector pitches, and enclosure dimensions often mix both systems.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many mm is 1 inch?</h3>
      <p>Exactly 25.4 mm. This is the international definition: the inch was standardized as 25.4 mm in 1959 by agreement between the US, UK, Canada, Australia, New Zealand, and South Africa. Every inch-to-mm value is a multiple of 25.4.</p>

      <h3>How do you convert inches to mm?</h3>
      <p>Multiply by 25.4. The calculation is straightforward because the factor is exact: 2 in = 50.8 mm, 3 in = 76.2 mm, 4 in = 101.6 mm. No rounding is required for any integer-inch input.</p>

      <h3>How many mm is 12 inches?</h3>
      <p>Exactly 304.8 mm. Since 12 inches = 1 foot, this means 1 ft = 304.8 mm = 30.48 cm = 0.3048 m - all the foot-based definitions chain from the same 25.4 mm anchor. For the cm conversion, see the <a href="/conversion/length-converter/in-to-cm">inches to centimeters converter</a>.</p>

      <h3>What is 2 inches in mm?</h3>
      <p>2 inches equals exactly 50.8 mm. Multiply 2 × 25.4 = 50.8. This is a common size for pipe fittings, drill bits, and camera filter threads.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/mm-to-in">Millimeters to Inches Converter</a>
            <p>Reverse conversion - enter mm and get inches instantly.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/in-to-cm">Inches to Centimeters Converter</a>
            <p>Convert inches to cm - useful for clothing, screens, and body measurements.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-in">Feet to Inches Converter</a>
            <p>Convert feet to inches within the imperial system.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
