---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{m} = \\text{ft} \\times 0.3048$$",
  rev: "$$\\text{ft} = \\text{m} \\div 0.3048$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert feet to meters' },
  { id: 'reverse',         label: 'How to convert meters to feet' },
  { id: 'reference-table', label: 'Feet to meters reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Feet to Meters Converter",
    "url": "https://calculations.tools/conversion/length-converter/ft-to-m",
    "description": "Convert feet to meters instantly. Formula: m = ft × 0.3048. Includes reverse meters to feet conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert feet to meters",
    "description": "Convert feet to meters using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter feet value", "text": "Type your feet value in the ft field. The meters result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted meters value appears immediately. For 1 ft, the result is 0.3048 m." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the m field to convert back to feet. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many meters is 1 foot?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 foot equals exactly 0.3048 meters. This is a fixed international definition established by the International Yard and Pound Agreement of 1959, signed by the US, UK, Canada, Australia, New Zealand, and South Africa." }
      },
      {
        "@type": "Question",
        "name": "How do you convert feet to meters?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply feet by 0.3048. Example: 10 ft × 0.3048 = 3.048 m. For a quick mental estimate, divide by 3.28 - error is under 0.025%. The factor 0.3048 is exact, not a rounded approximation." }
      },
      {
        "@type": "Question",
        "name": "How many meters is 5 feet 11 inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "5 feet 11 inches equals 1.8034 meters. Convert to total inches first: 5 × 12 + 11 = 71 inches. Then multiply by 0.0254 (since 1 inch = 0.0254 m): 71 × 0.0254 = 1.8034 m." }
      },
      {
        "@type": "Question",
        "name": "How many meters is 6 feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "6 feet equals exactly 1.8288 meters. Multiply 6 by 0.3048: 6 × 0.3048 = 1.8288 m. This is a commonly cited height benchmark - often rounded to 1.83 m in clinical and sports contexts." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Feet to Meters Converter"
  metaTitle="Feet to Meters Converter | Calculate foot to metric meter ᐅ"
  description="Convert feet to meters instantly. Formula: m = ft × 0.3048. Reverse meters to feet included. Reference table for common heights and distances."
  canonical="https://calculations.tools/conversion/length-converter/ft-to-m"
  tocItems={tocItems}
  embedSlug="ft-to-m"
  schema={schema}
  ogFormula="m = ft × 0.3048"
  ogExample="6 ft = 6 × 0.3048 = 1.8288 m"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Feet to Meters (ft to m) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Feet (ft)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Meters (m)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 0.3048" />
          </div>
        </div>

        <div class="pair-formula-note">1 ft = 0.3048 m &nbsp;·&nbsp; 1 m = 3.28084 ft</div>

      </div>
    </section>

    <script src="/js/ft-to-m.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert feet to meters, multiply by <strong>0.3048</strong>. So 6 ft = 1.8288 m. The factor is exact - one foot is defined as exactly 0.3048 meters since the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 ft = 0.3048 m (international definition, fixed in 1959).</li>
          <li>1 foot = 30.48 cm exactly.</li>
          <li>Quick mental check: divide feet by 3.28 for a close estimate (error under 0.025%).</li>
          <li>Aviation altitude is measured in feet worldwide, even in countries that use metric (ICAO standard).</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any value in the feet field and the meters result appears instantly. You can also type in the meters field to convert back to feet - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Feet to Meters?</h2>
      <p>Multiply feet by 0.3048. This factor is exact: one foot is defined as precisely 0.3048 meters under the International Yard and Pound Agreement of 1959. There is no rounding error in the conversion itself.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 5 ft = 1.524 m. 6 ft = 1.8288 m. 100 ft = 30.48 m.</p>

      <h2 id="reverse">How Do You Convert Meters to Feet?</h2>
      <p>Divide meters by 0.3048, or multiply by 3.28084. For a full multi-unit converter, the <a href="/conversion/length-converter">length converter</a> handles all metric and imperial units at once.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 1 m = 3.28084 ft. 1.8 m = 5.9055 ft. 10 m = 32.808 ft.</p>

      <h2 id="reference-table">Feet to Meters Reference Table</h2>
      <p>Common height and distance values converted using the exact factor 0.3048.</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Feet</th><th>Meters</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>1 ft</td><td>0.3048 m</td><td>Ruler length</td></tr>
            <tr><td>3 ft</td><td>0.9144 m</td><td>1 yard</td></tr>
            <tr><td>4 ft</td><td>1.2192 m</td><td>Tall child</td></tr>
            <tr><td>5 ft</td><td>1.524 m</td><td>Short adult</td></tr>
            <tr><td>5 ft 6 in</td><td>1.6764 m</td><td>Average female height (US)</td></tr>
            <tr><td>5 ft 9 in</td><td>1.7526 m</td><td>Average male height (US)</td></tr>
            <tr><td>6 ft</td><td>1.8288 m</td><td>Tall adult</td></tr>
            <tr><td>6 ft 6 in</td><td>1.9812 m</td><td>NBA average height</td></tr>
            <tr><td>10 ft</td><td>3.048 m</td><td>Standard ceiling (US)</td></tr>
            <tr><td>100 ft</td><td>30.48 m</td><td>10-storey building approx.</td></tr>
            <tr><td>1000 ft</td><td>304.8 m</td><td>Low cloud ceiling</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Feet to Meters?</h2>
      <p>Feet are primarily used in the US and to some extent the UK for everyday heights and some distances. According to NIST (2023), most other countries use meters. Common conversion scenarios include international height records, construction documents, and aviation altitudes.</p>
      <ul>
        <li><strong>Height records</strong> - athletes and medical records in the US use feet and inches; international standards use meters.</li>
        <li><strong>Aviation</strong> - ICAO requires altitude in feet, so all pilots and controllers worldwide use feet regardless of their country's unit system.</li>
        <li><strong>Construction</strong> - US blueprints use feet; EU blueprints use meters.</li>
        <li><strong>Real estate</strong> - US property listings use square feet; European listings use square meters.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many meters is 1 foot?</h3>
      <p>1 foot equals exactly 0.3048 meters. This is a fixed definition - not an approximation. It was agreed upon internationally in 1959 to standardize the relationship between imperial and metric units permanently.</p>

      <h3>How do you convert feet to meters?</h3>
      <p>Multiply feet by 0.3048. The result is exact because the foot is defined in terms of meters. Quick mental shortcut: divide by 3.28 (error under 0.025%). For feet-and-inches, convert inches to decimal feet first by dividing inches by 12.</p>

      <h3>How many meters is 5 feet 11 inches?</h3>
      <p>5 ft 11 in = 1.8034 m. Convert to total inches: 5 × 12 + 11 = 71 in. Then multiply by 0.0254 m/in: 71 × 0.0254 = 1.8034 m. For any feet-and-inches combo, the <a href="/conversion/height-converter">height converter</a> handles this directly.</p>

      <h3>How many meters is 6 feet?</h3>
      <p>6 feet equals 1.8288 meters exactly. This is one of the most commonly looked-up conversions because 6 ft is a commonly cited height benchmark in English-speaking countries. In metric contexts it's typically stated as 1.83 m (rounded).</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/m-to-ft">Meters to Feet Converter</a>
            <p>Reverse conversion - dedicated page with meters-first reference table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-cm">Feet to Centimeters Converter</a>
            <p>Convert feet to cm - useful for height records and metric body measurements.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-in">Feet to Inches Converter</a>
            <p>Convert feet to total inches within the imperial system.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📐</span>
          <div>
            <a href="/conversion/height-converter">Height Converter</a>
            <p>Convert height between cm, feet and inches, and meters - handles mixed formats.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/in-to-cm">Inches to Centimeters Converter</a>
            <p>Convert inches to cm - useful for screen sizes, clothing, and body measurements.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
