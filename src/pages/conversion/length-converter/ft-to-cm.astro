---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{cm} = \\text{ft} \\times 30.48$$",
  rev: "$$\\text{ft} = \\text{cm} \\div 30.48$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert feet to cm' },
  { id: 'reverse',         label: 'How to convert cm to feet' },
  { id: 'reference-table', label: 'Feet to centimeters reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Feet to Centimeters Converter",
    "url": "https://calculations.tools/conversion/length-converter/ft-to-cm",
    "description": "Convert feet to centimeters instantly. Formula: cm = ft × 30.48. Includes reverse cm to feet conversion and a height reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert feet to centimeters",
    "description": "Convert feet to centimeters using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter feet value", "text": "Type your feet value in the ft field. The centimeters result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted cm value appears immediately. For 6 ft, the result is 182.88 cm." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the cm field to convert back to feet. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many cm is 5 feet 10 inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "5 feet 10 inches equals 177.8 cm. Convert to decimal feet first: 5 + 10/12 = 5.8333 ft, then multiply by 30.48: 5.8333 × 30.48 = 177.8 cm." }
      },
      {
        "@type": "Question",
        "name": "How do you convert feet to centimeters?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply feet by 30.48. Example: 6 ft × 30.48 = 182.88 cm. The factor 30.48 comes from the definition of one foot as exactly 0.3048 meters = 30.48 cm." }
      },
      {
        "@type": "Question",
        "name": "How many cm is 5 feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "5 feet equals exactly 152.4 cm. Multiply 5 by 30.48: 5 × 30.48 = 152.4 cm." }
      },
      {
        "@type": "Question",
        "name": "How many cm is 6 feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "6 feet equals exactly 182.88 cm. Multiply 6 by 30.48: 6 × 30.48 = 182.88 cm. In metric contexts this is commonly rounded to 183 cm." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Feet to Centimeters Converter"
  metaTitle="Feet to Centimeters Converter | Instantly Calculate ft to cm ᐅ"
  description="Convert feet to centimeters instantly. Formula: cm = ft × 30.48. Height reference table included - 5 ft, 5 ft 10 in, 6 ft in cm and more."
  canonical="https://calculations.tools/conversion/length-converter/ft-to-cm"
  tocItems={tocItems}
  embedSlug="ft-to-cm"
  schema={schema}
  ogFormula="cm = ft × 30.48"
  ogExample="6 ft = 182.88 cm"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Foot to Centimeter (ft to cm) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Feet (ft)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 6" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Centimeters (cm)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 182.88" />
          </div>
        </div>

        <div class="pair-formula-note">1 ft = 30.48 cm &nbsp;·&nbsp; 1 cm = 0.032808 ft</div>

      </div>
    </section>

    <script src="/js/ft-to-cm.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert feet to centimeters, multiply by <strong>30.48</strong>. So 5 ft = 152.4 cm and 6 ft = 182.88 cm. The factor is exact - one foot is defined as exactly 30.48 cm since the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 ft = 30.48 cm (defined, not approximate).</li>
          <li>5 ft = 152.4 cm. 6 ft = 182.88 cm.</li>
          <li>For ft + inches: convert everything to decimal feet first, then multiply by 30.48.</li>
          <li>Quick mental estimate: multiply feet by 30 (gives result ~1.6% low).</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any feet value in the ft field and the centimeters result appears instantly. You can also type in the cm field to convert back to feet - it works in both directions. Note: this converter accepts decimal feet (e.g. 5.833 for 5'10"). For a feet-and-inches input format, use the <a href="/conversion/height-converter">height converter</a>.</p>

      <h2 id="formula">How Do You Convert Feet to Centimeters?</h2>
      <p>Multiply feet by 30.48. One foot is defined as exactly 0.3048 meters = 30.48 centimeters. This is an exact definition with no rounding.</p>

      <Formula expr={f.fwd} />

      <p>For feet and inches, first convert to decimal feet: add inches ÷ 12 to the feet value. Example: 5'10" = 5 + 10/12 = 5.8333 ft × 30.48 = 177.8 cm.</p>

      <p>Worked examples: 5 ft = 152.4 cm. 5.5 ft = 167.64 cm. 6 ft = 182.88 cm. 6.5 ft = 198.12 cm.</p>

      <h2 id="reverse">How Do You Convert Centimeters to Feet?</h2>
      <p>Divide centimeters by 30.48. For a dedicated page with a height reference table, see the <a href="/conversion/length-converter/cm-to-ft">centimeters to feet converter</a>.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 160 cm ÷ 30.48 = 5.249 ft. 175 cm ÷ 30.48 = 5.741 ft. 183 cm ÷ 30.48 = 6.004 ft.</p>

      <h2 id="reference-table">Feet to Centimeters Reference Table</h2>
      <p>Common height values converted using the exact factor 30.48 cm/ft:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Feet</th><th>Feet &amp; inches</th><th>Centimeters</th></tr>
          </thead>
          <tbody>
            <tr><td>4.5 ft</td><td>4 ft 6 in</td><td>137.16 cm</td></tr>
            <tr><td>4.917 ft</td><td>4 ft 11 in</td><td>149.86 cm</td></tr>
            <tr><td>5 ft</td><td>5 ft 0 in</td><td>152.40 cm</td></tr>
            <tr><td>5.25 ft</td><td>5 ft 3 in</td><td>160.02 cm</td></tr>
            <tr><td>5.417 ft</td><td>5 ft 5 in</td><td>165.10 cm</td></tr>
            <tr><td>5.583 ft</td><td>5 ft 7 in</td><td>170.18 cm</td></tr>
            <tr><td>5.75 ft</td><td>5 ft 9 in</td><td>175.26 cm</td></tr>
            <tr><td>5.833 ft</td><td>5 ft 10 in</td><td>177.80 cm</td></tr>
            <tr><td>6 ft</td><td>6 ft 0 in</td><td>182.88 cm</td></tr>
            <tr><td>6.167 ft</td><td>6 ft 2 in</td><td>187.96 cm</td></tr>
            <tr><td>6.5 ft</td><td>6 ft 6 in</td><td>198.12 cm</td></tr>
            <tr><td>7 ft</td><td>7 ft 0 in</td><td>213.36 cm</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Feet to Centimeters?</h2>
      <p>The feet-to-cm conversion is driven almost entirely by human height. The US uses feet and inches for height; most other countries use centimeters. Common use cases:</p>
      <ul>
        <li><strong>Medical and fitness</strong> - entering height in metric systems, BMI calculators, and international health records.</li>
        <li><strong>Travel</strong> - understanding height restrictions on rides, clearances, and equipment stated in metric units.</li>
        <li><strong>Sports</strong> - basketball, athletics, and combat sports often list athlete heights in both units depending on the publication's audience.</li>
        <li><strong>Architecture and construction</strong> - converting US blueprint dimensions to metric for international projects.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many cm is 5 feet 10 inches?</h3>
      <p>5 feet 10 inches equals 177.8 cm. Convert to decimal feet: 5 + 10/12 = 5.8333 ft. Multiply by 30.48: 5.8333 × 30.48 = 177.8 cm. This is a common height for adult males in Western countries.</p>

      <h3>How do you convert feet to centimeters?</h3>
      <p>Multiply feet by 30.48. If you have feet and inches, convert to decimal feet first by adding inches/12 to the foot count. The factor 30.48 is exact - it comes from the international definition of the foot as 0.3048 m.</p>

      <h3>How many cm is 5 feet?</h3>
      <p>Exactly 152.4 cm. This is the threshold often used in clothing and medical contexts to identify shorter-than-average adult stature. Multiply 5 × 30.48 = 152.4 cm.</p>

      <h3>How many cm is 6 feet?</h3>
      <p>Exactly 182.88 cm, commonly rounded to 183 cm in metric medical records. Use the <a href="/conversion/length-converter/cm-to-ft">centimeters to feet converter</a> to go the other direction - enter 183 and you get 6.004 ft.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-ft">Centimeters to Feet Converter</a>
            <p>Reverse conversion - enter cm and get feet instantly, with full height table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📐</span>
          <div>
            <a href="/conversion/height-converter">Height Converter</a>
            <p>Handles the feet-and-inches format - converts between cm, ft/in, and meters.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-in">Feet to Inches Converter</a>
            <p>Convert feet to inches within the imperial system.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-m">Feet to Meters Converter</a>
            <p>Convert feet to meters - the SI base unit for length.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
