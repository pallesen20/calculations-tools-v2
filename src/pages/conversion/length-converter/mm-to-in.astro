---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{in} = \\text{mm} \\div 25.4$$",
  rev: "$$\\text{mm} = \\text{in} \\times 25.4$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert mm to inches' },
  { id: 'reverse',         label: 'How to convert inches to mm' },
  { id: 'reference-table', label: 'Millimeters to inches reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Millimeters to Inches Converter",
    "url": "https://calculations.tools/conversion/length-converter/mm-to-in",
    "description": "Convert millimeters to inches instantly. Formula: in = mm ÷ 25.4. Includes reverse inches to mm conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert millimeters to inches",
    "description": "Convert millimeters to inches using the exact international conversion factor.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter millimeters value", "text": "Type your mm value in the mm field. The inches result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted inches value appears immediately. For 25.4 mm, the result is exactly 1 inch." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the in field to convert back to millimeters. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many inches is 1 mm?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 mm equals 0.0393701 inches. Divide 1 by 25.4 to get the exact result. In fractions, 1 mm is approximately 5/127 of an inch." }
      },
      {
        "@type": "Question",
        "name": "How do you convert mm to inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide millimeters by 25.4. Example: 50 mm ÷ 25.4 = 1.9685 inches. The factor 25.4 comes from the definition of one inch as exactly 25.4 mm." }
      },
      {
        "@type": "Question",
        "name": "How many mm is 1 inch?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 inch equals exactly 25.4 mm. This is the international definition set in 1959." }
      },
      {
        "@type": "Question",
        "name": "What is 10 mm in inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "10 mm equals 0.393701 inches. That is just under 13/32 of an inch. In practical terms, 10 mm is about the width of a typical adult finger." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Millimeters to Inches Converter"
  metaTitle="Millimeters to Inches Converter | mm to in"
  description="Convert millimeters to inches instantly. Formula: in = mm ÷ 25.4. Reference table for engineering, 3D printing, and woodworking measurements."
  canonical="https://calculations.tools/conversion/length-converter/mm-to-in"
  tocItems={tocItems}
  embedSlug="mm-to-in"
  schema={schema}
  ogFormula="in = mm ÷ 25.4"
  ogExample="25.4 mm = 1 in"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Millimeters to Inches Converter</h2>
          <p>Type in either field — converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Millimeters (mm)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 25.4" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Inches (in)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
        </div>

        <div class="pair-formula-note">1 in = 25.4 mm &nbsp;·&nbsp; 1 mm = 0.03937 in</div>

      </div>
    </section>

    <script src="/js/mm-to-in.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert millimeters to inches, divide by <strong>25.4</strong>. So 25.4 mm = 1 in exactly, and 100 mm = 3.937 in. The factor is exact — one inch is defined as exactly 25.4 mm since the International Yard and Pound Agreement of 1959.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 in = 25.4 mm (defined, not approximate).</li>
          <li>25.4 mm = 1 in exactly. 50.8 mm = 2 in exactly.</li>
          <li>Quick mental check: divide mm by 25 for an estimate (gives result ~1.6% high).</li>
          <li>Used heavily in engineering, 3D printing, woodworking, and hardware specifications.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any millimeter value in the mm field and the inches result appears instantly. You can also type in the in field to convert back to millimeters — it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Millimeters to Inches?</h2>
      <p>Divide millimeters by 25.4. One inch is defined as exactly 25.4 mm under the International Yard and Pound Agreement of 1959. This definition is exact with no rounding.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 10 mm ÷ 25.4 = 0.3937 in. 50 mm ÷ 25.4 = 1.9685 in. 100 mm ÷ 25.4 = 3.937 in.</p>

      <p>Mental shortcut: divide by 25 for a quick estimate — the result is about 1.6% higher than the true value. For precision work always use 25.4.</p>

      <h2 id="reverse">How Do You Convert Inches to Millimeters?</h2>
      <p>Multiply inches by 25.4. This is the same exact definition used in reverse. For a dedicated reverse converter, see the <a href="/conversion/length-converter/in-to-mm">inches to millimeters converter</a>.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 1 in = 25.4 mm. 6 in = 152.4 mm. 12 in = 304.8 mm (= 1 foot).</p>

      <h2 id="reference-table">Millimeters to Inches Reference Table</h2>
      <p>Common values converted using the exact factor 1 ÷ 25.4 = 0.039370...</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Millimeters</th><th>Inches (decimal)</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>1 mm</td><td>0.03937 in</td><td>Thickness of a credit card (~0.76 mm)</td></tr>
            <tr><td>5 mm</td><td>0.19685 in</td><td>Standard pencil diameter</td></tr>
            <tr><td>10 mm</td><td>0.39370 in</td><td>About 3/8 in; common bolt size</td></tr>
            <tr><td>12.7 mm</td><td>0.5 in</td><td>Exactly 1/2 inch</td></tr>
            <tr><td>25 mm</td><td>0.98425 in</td><td>Just under 1 inch</td></tr>
            <tr><td>25.4 mm</td><td>1 in</td><td>Exactly 1 inch (definition)</td></tr>
            <tr><td>50 mm</td><td>1.9685 in</td><td>2-inch lens filter (~52 mm)</td></tr>
            <tr><td>100 mm</td><td>3.9370 in</td><td>Standard 4-inch pipe (~101.6 mm)</td></tr>
            <tr><td>150 mm</td><td>5.9055 in</td><td>6-inch ruler length</td></tr>
            <tr><td>200 mm</td><td>7.8740 in</td><td>Standard A4 width (210 mm)</td></tr>
            <tr><td>254 mm</td><td>10 in</td><td>Exactly 10 inches</td></tr>
            <tr><td>300 mm</td><td>11.811 in</td><td>30 cm ruler</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Millimeters to Inches?</h2>
      <p>The mm-to-inch conversion is common wherever metric and imperial specifications appear side by side. Key use cases:</p>
      <ul>
        <li><strong>Engineering and manufacturing</strong> — technical drawings and CAD files are often specified in mm in Europe, in inches in the US.</li>
        <li><strong>3D printing</strong> — slicer software and filament specs use both units depending on the manufacturer's market.</li>
        <li><strong>Woodworking and DIY</strong> — European timber and hardware is sized in mm; US hardware stores use inches.</li>
        <li><strong>Camera and optics</strong> — filter diameters, sensor sizes, and lens mounts are specified in mm; screen sizes in inches.</li>
        <li><strong>Plumbing and fasteners</strong> — pipe diameters, drill bits, and bolt sizes mix both systems.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many inches is 1 mm?</h3>
      <p>1 mm equals 0.0393701 inches. In fractional terms that is approximately 5/127 of an inch — too small to be useful as a fraction in everyday work. For most practical purposes, note that 25.4 mm = 1 inch exactly.</p>

      <h3>How do you convert mm to inches?</h3>
      <p>Divide by 25.4. The factor is exact: the international inch is defined as exactly 25.4 mm. So 50 mm ÷ 25.4 = 1.9685 in, and 100 mm ÷ 25.4 = 3.9370 in.</p>

      <h3>How many mm is 1 inch?</h3>
      <p>Exactly 25.4 mm. This is the foundational definition — all other mm/in conversions derive from it. Use the <a href="/conversion/length-converter/in-to-mm">inches to mm converter</a> to check any inch value.</p>

      <h3>What is 10 mm in inches?</h3>
      <p>10 mm equals 0.393701 inches — just under 13/32 of an inch, or about 3/8 in for practical rounding. This is a common size for metric bolts and drill bits that corresponds closely to the imperial 3/8-inch standard.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/in-to-mm">Inches to Millimeters Converter</a>
            <p>Reverse conversion — enter inches and get millimeters instantly.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/mm-to-cm">Millimeters to Centimeters Converter</a>
            <p>Convert mm to cm — both metric, useful for ruler and sewing measurements.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-in">Centimeters to Inches Converter</a>
            <p>Convert cm to inches — common for screen sizes and clothing dimensions.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
