---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{in} = \\text{ft} \\times 12$$",
  rev: "$$\\text{ft} = \\text{in} \\div 12$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert feet to inches' },
  { id: 'reverse',         label: 'How to convert inches to feet' },
  { id: 'reference-table', label: 'Feet to inches reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Feet to Inches Converter",
    "url": "https://calculations.tools/conversion/length-converter/ft-to-in",
    "description": "Convert feet to inches instantly. Formula: in = ft × 12. Includes reverse inches to feet conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert feet to inches",
    "description": "Convert feet to inches using the exact factor of 12 inches per foot.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter feet value", "text": "Type your feet value in the ft field. The inches result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted inches value appears immediately. For 1 ft, the result is 12 in." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the in field to convert back to feet. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many inches is 6 feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "6 feet equals exactly 72 inches. Multiply 6 by 12: 6 × 12 = 72 in." }
      },
      {
        "@type": "Question",
        "name": "How do you convert feet to inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply feet by 12. Example: 5 ft × 12 = 60 in. There are exactly 12 inches in one foot by definition." }
      },
      {
        "@type": "Question",
        "name": "How many inches is 5 feet?",
        "acceptedAnswer": { "@type": "Answer", "text": "5 feet equals exactly 60 inches. Multiply 5 by 12: 5 × 12 = 60 in." }
      },
      {
        "@type": "Question",
        "name": "How many feet is 72 inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "72 inches equals exactly 6 feet. Divide 72 by 12: 72 ÷ 12 = 6 ft." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Feet to Inches Converter"
  metaTitle="Feet to Inches Converter | Instantly Calculate ft to in ᐅ"
  description="Convert feet to inches instantly. Formula: in = ft × 12. Includes reverse inches to feet conversion and a reference table."
  canonical="https://calculations.tools/conversion/length-converter/ft-to-in"
  tocItems={tocItems}
  embedSlug="ft-to-in"
  schema={schema}
  ogFormula="in = ft × 12"
  ogExample="1 ft = 12 in"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Foot to Inch (ft to in) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Feet (ft)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Inches (in)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 12" />
          </div>
        </div>

        <div class="pair-formula-note">1 ft = 12 in &nbsp;·&nbsp; 1 in = 0.08333 ft</div>

      </div>
    </section>

    <script src="/js/ft-to-in.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert feet to inches, multiply by <strong>12</strong>. So 1 ft = 12 in, 5 ft = 60 in, and 6 ft = 72 in. There are exactly 12 inches in one foot - this is the definition of the foot within the imperial system.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 ft = 12 in (imperial definition).</li>
          <li>5 ft = 60 in. 5.5 ft = 66 in. 6 ft = 72 in.</li>
          <li>To handle mixed "5 ft 9 in" format: total inches = (feet × 12) + extra inches.</li>
          <li>To convert to metric, use the <a href="/conversion/length-converter/ft-to-cm">feet to cm converter</a> or the <a href="/conversion/length-converter/in-to-mm">inches to mm converter</a>.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any feet value in the ft field and the inches result appears instantly. You can also type in the in field to convert back to feet - it works in both directions without pressing a button. For decimal feet (e.g. 5.75 for 5'9"), the converter handles them directly.</p>

      <h2 id="formula">How Do You Convert Feet to Inches?</h2>
      <p>Multiply feet by 12. There are exactly 12 inches in one foot - this is the foundational imperial definition. The calculation is always exact for integer foot values.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 1 ft = 12 in. 5 ft = 60 in. 5.5 ft = 66 in. 6 ft = 72 in. 6.5 ft = 78 in.</p>

      <p>For mixed feet and inches (e.g. "5 ft 9 in"), the total in inches is: (5 × 12) + 9 = 69 in.</p>

      <h2 id="reverse">How Do You Convert Inches to Feet?</h2>
      <p>Divide inches by 12. For a dedicated page, see the <a href="/conversion/length-converter/in-to-ft">inches to feet converter</a>. For inches to metric, see the <a href="/conversion/length-converter/in-to-cm">inches to centimeters converter</a> or <a href="/conversion/length-converter/in-to-mm">inches to millimeters converter</a>.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 60 in ÷ 12 = 5 ft. 66 in ÷ 12 = 5.5 ft. 72 in ÷ 12 = 6 ft.</p>

      <h2 id="reference-table">Feet to Inches Reference Table</h2>
      <p>Common height and distance values converted at the exact factor of 12:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Feet</th><th>Inches</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>1 ft</td><td>12 in</td><td>Standard ruler length</td></tr>
            <tr><td>2 ft</td><td>24 in</td><td>Counter-height stool seat</td></tr>
            <tr><td>3 ft</td><td>36 in</td><td>1 yard exactly</td></tr>
            <tr><td>4 ft</td><td>48 in</td><td>Standard door width (~36 in)</td></tr>
            <tr><td>4.917 ft</td><td>59 in</td><td>4 ft 11 in</td></tr>
            <tr><td>5 ft</td><td>60 in</td><td>Average short adult height</td></tr>
            <tr><td>5.417 ft</td><td>65 in</td><td>5 ft 5 in - average female (US)</td></tr>
            <tr><td>5.75 ft</td><td>69 in</td><td>5 ft 9 in - average male (US)</td></tr>
            <tr><td>5.833 ft</td><td>70 in</td><td>5 ft 10 in</td></tr>
            <tr><td>6 ft</td><td>72 in</td><td>Tall adult height benchmark</td></tr>
            <tr><td>6.5 ft</td><td>78 in</td><td>6 ft 6 in - NBA average height</td></tr>
            <tr><td>7 ft</td><td>84 in</td><td>NBA center height threshold</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Feet to Inches?</h2>
      <p>Feet-to-inches conversions arise whenever you need a single consistent unit within the imperial system:</p>
      <ul>
        <li><strong>Height comparison</strong> - it is easier to compare heights as total inches (69 in vs 72 in) than as mixed feet and inches.</li>
        <li><strong>Construction and carpentry</strong> - measurements on plans often use feet; cutting instructions use inches.</li>
        <li><strong>Fabric and upholstery</strong> - fabric widths are sold by the yard or in inches; pattern measurements are in inches.</li>
        <li><strong>Sports</strong> - American football field dimensions use both yards and feet; the hash marks and yard lines relate to 36-inch yards.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many inches is 6 feet?</h3>
      <p>6 feet equals exactly 72 inches. Multiply 6 × 12 = 72. This is a common benchmark height - "6 foot" is 72 inches whether you're measuring for a door, a bed, or a person.</p>

      <h3>How do you convert feet to inches?</h3>
      <p>Multiply by 12. The calculation is always exact: 1 ft = 12 in exactly, so 5 ft = 60 in, 10 ft = 120 in. For mixed units (feet + inches), multiply the feet by 12 then add the extra inches: 5'9" = (5×12)+9 = 69 in.</p>

      <h3>How many inches is 5 feet?</h3>
      <p>5 feet equals exactly 60 inches. This corresponds to approximately 152.4 cm - use the <a href="/conversion/length-converter/ft-to-cm">feet to cm converter</a> to check the metric equivalent of any height.</p>

      <h3>How many feet is 72 inches?</h3>
      <p>72 inches equals exactly 6 feet. Divide 72 ÷ 12 = 6. For the full reverse conversion tool, see the <a href="/conversion/length-converter/in-to-ft">inches to feet converter</a>.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/in-to-ft">Inches to Feet Converter</a>
            <p>Reverse conversion - enter inches and get feet instantly.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/ft-to-cm">Feet to Centimeters Converter</a>
            <p>Convert feet to metric - useful for height records and international contexts.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/in-to-mm">Inches to Millimeters Converter</a>
            <p>Convert inches to mm for engineering and hardware applications.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📐</span>
          <div>
            <a href="/conversion/height-converter">Height Converter</a>
            <p>Convert height between cm, feet and inches, and meters with reference table.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
