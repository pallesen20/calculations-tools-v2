---
import CalculatorLayout from '../../../layouts/CalculatorLayout.astro';
import Formula from '../../../components/Formula.astro';

const f = {
  fwd: "$$\\text{mm} = \\text{cm} \\times 10$$",
  rev: "$$\\text{cm} = \\text{mm} \\div 10$$",
};

const tocItems = [
  { id: 'how-to-use',      label: 'How to use this converter' },
  { id: 'formula',         label: 'How to convert cm to mm' },
  { id: 'reverse',         label: 'How to convert mm to cm' },
  { id: 'reference-table', label: 'Centimeters to millimeters reference table' },
  { id: 'when-to-use',     label: 'When you need this conversion' },
  { id: 'faq',             label: 'FAQs' },
  { id: 'related-tools',   label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Centimeters to Millimeters Converter",
    "url": "https://calculations.tools/conversion/length-converter/cm-to-mm",
    "description": "Convert centimeters to millimeters instantly. Formula: mm = cm × 10. Includes reverse mm to cm conversion and a reference table.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to convert centimeters to millimeters",
    "description": "Convert centimeters to millimeters by multiplying by 10.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter centimeters value", "text": "Type your cm value in the cm field. The mm result updates instantly." },
      { "@type": "HowToStep", "position": 2, "name": "Read the result", "text": "The converted mm value appears immediately. For 1 cm, the result is 10 mm." },
      { "@type": "HowToStep", "position": 3, "name": "Convert in reverse", "text": "Type in the mm field to convert back to cm. The converter works in both directions." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many mm is 1 cm?",
        "acceptedAnswer": { "@type": "Answer", "text": "1 cm equals exactly 10 mm. There are exactly 10 millimeters in one centimeter by the SI metric prefix definition." }
      },
      {
        "@type": "Question",
        "name": "How do you convert cm to mm?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply centimeters by 10. Example: 5 cm × 10 = 50 mm. The factor is exact: 1 cm = 10 mm by SI definition." }
      },
      {
        "@type": "Question",
        "name": "How many mm is 2.5 cm?",
        "acceptedAnswer": { "@type": "Answer", "text": "2.5 cm equals exactly 25 mm. Multiply 2.5 × 10 = 25 mm." }
      },
      {
        "@type": "Question",
        "name": "How many mm is 30 cm?",
        "acceptedAnswer": { "@type": "Answer", "text": "30 cm equals exactly 300 mm. Multiply 30 × 10 = 300 mm. This is the length of a standard 30 cm ruler." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Centimeters to Millimeters Converter"
  metaTitle="Centimeters to Millimeters Converter | Calculate cm to mm ᐅ"
  description="Convert centimeters to millimeters instantly. Formula: mm = cm × 10. Includes reverse mm to cm conversion and a reference table for crafts and engineering."
  canonical="https://calculations.tools/conversion/length-converter/cm-to-mm"
  tocItems={tocItems}
  embedSlug="cm-to-mm"
  schema={schema}
  ogFormula="mm = cm × 10"
  ogExample="1 cm = 10 mm"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">

        <div class="calculator-header">
          <h2>Instant Centimeter to Millimeter (cm to mm) Calculator</h2>
          <p>Type in either field - converts instantly in both directions</p>
        </div>

        <div class="pair-inputs">
          <div class="pair-field">
            <label for="lp-a">Centimeters (cm)</label>
            <input id="lp-a" type="text" inputmode="decimal" placeholder="e.g. 1" />
          </div>
          <div class="pair-eq">=</div>
          <div class="pair-field">
            <label for="lp-b">Millimeters (mm)</label>
            <input id="lp-b" type="text" inputmode="decimal" placeholder="e.g. 10" />
          </div>
        </div>

        <div class="pair-formula-note">1 cm = 10 mm &nbsp;·&nbsp; 1 mm = 0.1 cm</div>

      </div>
    </section>

    <script src="/js/cm-to-mm.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>To convert centimeters to millimeters, multiply by <strong>10</strong>. So 1 cm = 10 mm, 5 cm = 50 mm, and 30 cm = 300 mm. The factor is exact - 1 cm = 10 mm by the SI metric prefix definition.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>Exact factor: 1 cm = 10 mm (SI prefix definition, no approximation).</li>
          <li>1 cm = 10 mm. 10 cm = 100 mm. 100 cm = 1000 mm = 1 m.</li>
          <li>The conversion is a simple decimal shift - move the decimal point one place right.</li>
          <li>Common use cases: sewing, woodworking, photography, precision manufacturing.</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This Converter</h2>
      <p>Type any centimeter value in the cm field and the millimeters result appears instantly. You can also type in the mm field to convert back to centimeters - it works in both directions without pressing a button.</p>

      <h2 id="formula">How Do You Convert Centimeters to Millimeters?</h2>
      <p>Multiply centimeters by 10. The relationship is exact: the SI prefix "centi-" means 1/100 and "milli-" means 1/1000. Since 1/100 ÷ 1/1000 = 10, there are exactly 10 mm in every centimeter.</p>

      <Formula expr={f.fwd} />

      <p>Worked examples: 1 cm = 10 mm. 2.5 cm = 25 mm. 30 cm = 300 mm. 100 cm = 1000 mm = 1 m.</p>

      <p>Mental shortcut: simply move the decimal point one place to the right. 12.5 cm → 125 mm. This is the simplest conversion in the metric system.</p>

      <h2 id="reverse">How Do You Convert Millimeters to Centimeters?</h2>
      <p>Divide millimeters by 10. For a dedicated reverse converter, see the <a href="/conversion/length-converter/mm-to-cm">millimeters to centimeters converter</a>.</p>

      <Formula expr={f.rev} />

      <p>Worked examples: 10 mm = 1 cm. 25 mm = 2.5 cm. 300 mm = 30 cm.</p>

      <h2 id="reference-table">Centimeters to Millimeters Reference Table</h2>
      <p>Common values converted at the exact factor of 10:</p>

      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Centimeters</th><th>Millimeters</th><th>Common context</th></tr>
          </thead>
          <tbody>
            <tr><td>0.5 cm</td><td>5 mm</td><td>Standard pencil diameter</td></tr>
            <tr><td>1 cm</td><td>10 mm</td><td>Small button diameter</td></tr>
            <tr><td>2.54 cm</td><td>25.4 mm</td><td>Exactly 1 inch</td></tr>
            <tr><td>5 cm</td><td>50 mm</td><td>Camera filter rim (approx.)</td></tr>
            <tr><td>10 cm</td><td>100 mm</td><td>Smartphone width (approx.)</td></tr>
            <tr><td>15 cm</td><td>150 mm</td><td>6-inch ruler</td></tr>
            <tr><td>21 cm</td><td>210 mm</td><td>A4 paper width</td></tr>
            <tr><td>29.7 cm</td><td>297 mm</td><td>A4 paper height</td></tr>
            <tr><td>30 cm</td><td>300 mm</td><td>Standard 30 cm ruler</td></tr>
            <tr><td>50 cm</td><td>500 mm</td><td>Half a meter</td></tr>
            <tr><td>100 cm</td><td>1000 mm</td><td>1 meter exactly</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="when-to-use">When Do You Need to Convert Centimeters to Millimeters?</h2>
      <p>Both units are used in everyday metric measurement, and conversions happen when precision requirements change:</p>
      <ul>
        <li><strong>Sewing and tailoring</strong> - seam allowances and buttonhole sizes are in mm; fabric widths and garment measurements in cm.</li>
        <li><strong>Woodworking and joinery</strong> - overall dimensions in cm; tenons, grooves, and fine tolerances in mm.</li>
        <li><strong>Photography and optics</strong> - print sizes in cm; lens filter threads, sensor dimensions in mm.</li>
        <li><strong>Medical imaging</strong> - anatomy dimensions in cm; lesion sizes, catheter diameters in mm.</li>
        <li><strong>Engineering</strong> - product dimensions in cm for readability; tight tolerances specified in mm.</li>
      </ul>

      <h2 id="faq">Frequently Asked Questions</h2>

      <h3>How many mm is 1 cm?</h3>
      <p>Exactly 10 mm. The "centi-" prefix means 1/100 of a meter; "milli-" means 1/1000. So 1 cm = 10 × 1 mm. This holds true for any cm value - just multiply by 10.</p>

      <h3>How do you convert cm to mm?</h3>
      <p>Multiply by 10, or move the decimal point one position to the right. 3.7 cm → 37 mm. 0.8 cm → 8 mm. 100 cm → 1000 mm. The conversion is exact with no rounding for any input.</p>

      <h3>How many mm is 2.5 cm?</h3>
      <p>2.5 cm equals exactly 25 mm. This is very close to 1 inch (which is 25.4 mm = 2.54 cm). To convert to inches directly, use the <a href="/conversion/length-converter/cm-to-in">centimeters to inches converter</a>.</p>

      <h3>How many mm is 30 cm?</h3>
      <p>30 cm equals exactly 300 mm - the length of a standard 30 cm ruler. To convert 30 cm to inches: 30 ÷ 2.54 = 11.811 in. For that conversion use the <a href="/conversion/length-converter/cm-to-in">cm to inches converter</a>.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/mm-to-cm">Millimeters to Centimeters Converter</a>
            <p>Reverse conversion - enter mm and get cm instantly.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-in">Centimeters to Inches Converter</a>
            <p>Convert cm to inches - useful for screen sizes and clothing dimensions.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/mm-to-in">Millimeters to Inches Converter</a>
            <p>Convert mm to inches for engineering and hardware applications.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter/cm-to-ft">Centimeters to Feet Converter</a>
            <p>Convert cm to feet - the most common height conversion.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">📏</span>
          <div>
            <a href="/conversion/length-converter">Length Converter (all units)</a>
            <p>Convert between all metric and imperial length units simultaneously.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .pair-inputs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: end; margin-bottom: 1rem; }
  .pair-field label { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-bottom: 0.35rem; }
  .pair-field input { width: 100%; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 1rem; box-sizing: border-box; }
  .pair-eq { font-size: 1.5rem; color: rgba(255,255,255,0.5); padding-bottom: 0.35rem; }
  .pair-formula-note { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; }
  @media (max-width: 480px) { .pair-inputs { grid-template-columns: 1fr; } .pair-eq { text-align: center; padding-bottom: 0; } }
</style>
