---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Speed Converter - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container">
      <div class="calculator-header">
        <h2>Speed Converter</h2>
        <p>Enter a value and select units</p>
      </div>

      <div id="spd-quick" class="spd-quick"></div>

      <div class="spd-inputs">
        <div class="input-group">
          <label for="spd-value">Value</label>
          <input id="spd-value" type="text" inputmode="decimal" value="100" placeholder="Enter value" />
        </div>
        <div class="input-group">
          <label for="spd-from">From</label>
          <select id="spd-from"></select>
        </div>
        <div class="unit-swap-wrap">
          <button class="unit-swap" id="spd-swap" title="Swap units" aria-label="Swap units">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#ffffff" width="16" height="16">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
            </svg>
          </button>
        </div>
        <div class="input-group">
          <label for="spd-to">To</label>
          <select id="spd-to"></select>
        </div>
      </div>

      <div class="spd-result-box">
        <div class="result-label">Result</div>
        <div class="spd-result" id="spd-result">-</div>
        <div class="spd-result-desc" id="spd-result-desc"></div>
      </div>

      <div class="spd-common-section">
        <h3 id="spd-common-title" class="spd-common-title"></h3>
        <div id="spd-common" class="spd-common-grid"></div>
      </div>
    </div>
  </section>

  <script src="/js/speed-converter.js" is:inline></script>
</EmbedLayout>

<style>
  .spd-quick { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem; }
  .spd-quick-btn { padding: 0.35rem 0.7rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 20px; color: rgba(255,255,255,0.85); font-size: 0.75rem; cursor: pointer; }
  .spd-inputs { display: grid; grid-template-columns: 1fr 1fr auto 1fr; gap: 0.75rem; margin-bottom: 1rem; }
  .spd-inputs input, .spd-inputs select { width: 100%; padding: 0.5rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-size: 0.875rem; box-sizing: border-box; }
  .spd-result-box { background: linear-gradient(135deg, #2563eb, #7c3aed); border-radius: 10px; padding: 1rem; text-align: center; margin-bottom: 1rem; }
  .spd-result { font-size: 1.75rem; font-weight: 700; color: white; }
  .spd-result-desc { font-size: 0.8rem; color: rgba(255,255,255,0.7); margin-top: 0.25rem; }
  .spd-common-title { font-size: 0.9rem; font-weight: 600; color: white; margin-bottom: 0.5rem; }
  .spd-common-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem; }
  .spd-common-row { display: flex; justify-content: space-between; background: rgba(255,255,255,0.05); border-radius: 6px; padding: 0.5rem 0.6rem; font-size: 0.8rem; color: rgba(255,255,255,0.8); }
  .spd-common-val { color: #93c5fd; font-weight: 600; }
  @media (max-width: 480px) { .spd-inputs { grid-template-columns: 1fr; } .spd-common-grid { grid-template-columns: 1fr; } }
</style>
