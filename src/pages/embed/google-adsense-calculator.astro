---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Google AdSense Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Google AdSense Calculator</h2>
        <p>Enter your daily page views, CTR, and average CPC</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="gac-pageviews">Daily Page Views</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="gac-pageviews" class="bmi-input" placeholder="e.g. 10000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="gac-ctr">Click-Through Rate (CTR %)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="gac-ctr" class="bmi-input" value="2" placeholder="2" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="gac-cpc">Average CPC</label>
        <div class="gac-cpc-row">
          <div class="gac-currency-wrap">
            <select id="gac-currency" class="gac-currency-select" aria-label="Currency"></select>
            <svg class="gac-currency-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 4 6 8 10 4"/></svg>
          </div>
          <input type="text" inputmode="decimal" id="gac-cpc" class="bmi-input gac-cpc-input" value="0.25" placeholder="0.25" />
        </div>
      </div>

      <div id="gac-result" class="lbm-result hidden">
        <div class="gac-results-grid">
          <div class="gac-result-row">
            <span class="gac-period-label">Daily clicks</span>
            <span class="gac-period-val" id="gac-res-clicks">-</span>
          </div>
          <div class="gac-result-row">
            <span class="gac-period-label">Daily earnings</span>
            <span class="gac-period-val" id="gac-res-daily">-</span>
          </div>
          <div class="gac-result-row gac-row-highlight">
            <span class="gac-period-label">Monthly earnings</span>
            <span class="gac-period-val" id="gac-res-monthly">-</span>
          </div>
          <div class="gac-result-row">
            <span class="gac-period-label">Annual earnings</span>
            <span class="gac-period-val" id="gac-res-annual">-</span>
          </div>
          <div class="gac-result-row gac-row-rpm">
            <span class="gac-period-label">Page RPM</span>
            <span class="gac-period-val" id="gac-res-rpm">-</span>
          </div>
        </div>
        <p class="gac-note">Estimates are pre-tax and assume consistent daily traffic.</p>
      </div>
    </div>
  </section>

  <script src="/js/google-adsense-calculator.js" is:inline></script>
</EmbedLayout>

<style>
  .gac-cpc-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }
  .gac-currency-wrap { position: relative; flex-shrink: 0; }
  .gac-currency-select {
    width: 92px;
    height: 100%;
    padding: 0 2rem 0 0.75rem;
    background: rgba(167,139,250,0.15);
    border: 1px solid rgba(167,139,250,0.45);
    border-radius: 8px;
    color: white;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    letter-spacing: 0.03em;
  }
  .gac-currency-select:focus { outline: none; border-color: rgba(167,139,250,0.8); background: rgba(167,139,250,0.22); }
  .gac-currency-chevron { pointer-events: none; position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); color: rgba(167,139,250,0.9); }
  .gac-cpc-input { flex: 1; min-width: 0; border-color: rgba(255,255,255,0.25) !important; font-size: 1rem !important; }
  .gac-results-grid {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    overflow: hidden;
    margin-top: 0.25rem;
  }
  .gac-result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.1rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .gac-result-row:last-child { border-bottom: none; }
  .gac-result-row:nth-child(odd) { background: rgba(255,255,255,0.025); }
  .gac-row-highlight { background: rgba(167,139,250,0.08) !important; border-bottom-color: rgba(167,139,250,0.15) !important; }
  .gac-row-rpm { border-top: 1px solid rgba(255,255,255,0.12); }
  .gac-period-label { font-size: 0.85rem; color: rgba(255,255,255,0.55); }
  .gac-row-highlight .gac-period-label { color: rgba(255,255,255,0.8); font-weight: 600; }
  .gac-period-val { font-size: 1rem; font-weight: 700; color: white; font-variant-numeric: tabular-nums; }
  .gac-row-highlight .gac-period-val { color: #a78bfa; font-size: 1.15rem; }
  .gac-note { font-size: 0.75rem; color: rgba(255,255,255,0.3); text-align: center; margin: 0.6rem 0 0; }
</style>
