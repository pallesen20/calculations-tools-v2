---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Lean Body Mass Calculator — calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Calculate Your Lean Body Mass</h2>
        <p>LBM, body fat %, and FFMI — metric or imperial</p>
      </div>

      <div class="bmi-unit-toggle">
        <button class="bmi-unit-btn active" data-unit="metric">Metric</button>
        <button class="bmi-unit-btn" data-unit="imperial">Imperial</button>
      </div>

      <div class="bmi-field" style="margin-bottom:1.25rem">
        <label class="bmi-label">Sex</label>
        <div class="bmi-sex-toggle">
          <button class="bmi-sex-btn active" data-sex="male">Male</button>
          <button class="bmi-sex-btn" data-sex="female">Female</button>
        </div>
      </div>

      <div id="bmi-metric" class="bmi-inputs active">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-kg">Weight</label>
          <div class="bmi-input-wrap">
            <input type="number" id="bmi-weight-kg" class="bmi-input" min="1" max="500" step="0.1" placeholder="80" />
            <span class="bmi-unit-tag">kg</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-height-cm">Height</label>
          <div class="bmi-input-wrap">
            <input type="number" id="bmi-height-cm" class="bmi-input" min="50" max="280" step="1" placeholder="178" />
            <span class="bmi-unit-tag">cm</span>
          </div>
        </div>
      </div>

      <div id="bmi-imperial" class="bmi-inputs">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-lb">Weight</label>
          <div class="bmi-input-wrap">
            <input type="number" id="bmi-weight-lb" class="bmi-input" min="1" max="1100" step="0.5" placeholder="176" />
            <span class="bmi-unit-tag">lbs</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label">Height</label>
          <div class="bmi-ftin">
            <div class="bmi-input-wrap">
              <input type="number" id="bmi-height-ft" class="bmi-input" min="1" max="9" step="1" placeholder="5" />
              <span class="bmi-unit-tag">ft</span>
            </div>
            <div class="bmi-input-wrap">
              <input type="number" id="bmi-height-in" class="bmi-input" min="0" max="11" step="1" placeholder="10" />
              <span class="bmi-unit-tag">in</span>
            </div>
          </div>
        </div>
      </div>

      <div id="lbm-result" class="lbm-result hidden">
        <div class="lbm-primary">
          <span class="lbm-primary-val" id="lbm-val">—</span>
          <span class="lbm-primary-unit" id="lbm-unit">kg</span>
        </div>
        <div class="lbm-primary-lbl">Lean Body Mass</div>
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="lbm-fat-mass">—</div>
            <div class="lbm-card-lbl">Fat mass</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="lbm-bf-pct">—</div>
            <div class="lbm-card-lbl">Body fat %</div>
            <div class="lbm-card-badge" id="lbm-bf-badge">—</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="lbm-ffmi-val">—</div>
            <div class="lbm-card-lbl">FFMI (normalised)</div>
            <div class="lbm-card-badge" id="lbm-ffmi-badge">—</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="lbm-bmi">—</div>
            <div class="lbm-card-lbl">BMI</div>
          </div>
        </div>
        <div class="lbm-formula-row" id="lbm-formula-note"></div>
      </div>

    </div>
  </section>

  <script src="/js/lean-body-mass-calculator.js" is:inline></script>
</EmbedLayout>
