---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Percent Error Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Percent Error Calculator</h2>
        <p>Enter the experimental and theoretical values</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="pe-experimental">Experimental Value</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="pe-experimental" class="bmi-input" placeholder="e.g. 9.6" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="pe-theoretical">Theoretical Value</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="pe-theoretical" class="bmi-input" placeholder="e.g. 10" />
        </div>
      </div>

      <div id="pe-result" class="lbm-result hidden">
        <div class="lbm-primary">
          <span class="lbm-primary-val" id="pe-pct">-</span>
        </div>
        <div class="lbm-primary-lbl">Percent Error</div>

        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="pe-signed">-</div>
            <div class="lbm-card-lbl">Signed error</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="pe-abs">-</div>
            <div class="lbm-card-lbl">Absolute difference</div>
          </div>
        </div>

        <div class="pi-steps">
          <div class="pi-steps-title">How it was calculated</div>
          <div class="pi-step">
            <span class="pi-step-label">Step 1 - Subtract</span>
            <span id="pe-step1" class="pi-step-val">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Step 2 - Divide</span>
            <span id="pe-step2" class="pi-step-val">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Step 3 - Multiply by 100</span>
            <span id="pe-step3" class="pi-step-val">-</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/percent-error-calculator.js" is:inline></script>
</EmbedLayout>
