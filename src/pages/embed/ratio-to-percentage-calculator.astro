---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Ratio to Percentage Calculator — calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Ratio to Percentage Calculator</h2>
        <p>Convert a:b to percentages</p>
      </div>

      <div class="ratio-row">
        <div class="bmi-field" style="flex:1;">
          <label class="bmi-label" for="rp-a">Part A</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="rp-a" class="bmi-input" placeholder="e.g. 3" />
          </div>
        </div>
        <div class="ratio-colon">:</div>
        <div class="bmi-field" style="flex:1;">
          <label class="bmi-label" for="rp-b">Part B</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="rp-b" class="bmi-input" placeholder="e.g. 5" />
          </div>
        </div>
      </div>

      <div id="rp-result" class="lbm-result hidden">
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="rp-pct-a">—</div>
            <div class="lbm-card-lbl">Part A (%)</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="rp-pct-b">—</div>
            <div class="lbm-card-lbl">Part B (%)</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="rp-dec-a">—</div>
            <div class="lbm-card-lbl">Part A (decimal)</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="rp-dec-b">—</div>
            <div class="lbm-card-lbl">Part B (decimal)</div>
          </div>
        </div>

        <div class="pi-steps" style="margin-top:0.75rem;">
          <div class="pi-steps-title">Step-by-step</div>
          <div class="pi-step">
            <span class="pi-step-label">Total parts</span>
            <span class="pi-step-val" id="rp-step1">—</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Part A %</span>
            <span class="pi-step-val" id="rp-step2">—</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Part B %</span>
            <span class="pi-step-val" id="rp-step3">—</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style is:global>
    .ratio-row   { display:flex; align-items:flex-end; gap:0.5rem; }
    .ratio-colon { font-size:1.5rem; font-weight:700; color:rgba(255,255,255,0.6); padding-bottom:0.75rem; }
  </style>

  <script src="/js/ratio-to-percentage-calculator.js" is:inline></script>
</EmbedLayout>
