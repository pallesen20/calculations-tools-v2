---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="ROI Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>ROI Calculator</h2>
        <p>Enter initial investment and final value to calculate return</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="roi-initial">Initial Investment</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="roi-initial" class="bmi-input" placeholder="e.g. 10000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="roi-final">Final Value</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="roi-final" class="bmi-input" placeholder="e.g. 13500" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="roi-years">Holding Period in Years (optional)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="roi-years" class="bmi-input" placeholder="e.g. 3" />
        </div>
      </div>

      <div id="roi-result" class="lbm-result hidden">
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="roi-net-return">-</div>
            <div class="lbm-card-lbl">Net Return</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="roi-pct">-</div>
            <div class="lbm-card-lbl">ROI</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="roi-multiple">-</div>
            <div class="lbm-card-lbl">Multiple</div>
          </div>
        </div>

        <div id="roi-ann-row" class="lbm-cards hidden" style="margin-top:0.5rem;">
          <div class="lbm-card">
            <div class="lbm-card-val" id="roi-ann-val">-</div>
            <div class="lbm-card-lbl">Annualized ROI (CAGR)</div>
          </div>
        </div>

        <div class="pi-steps" style="margin-top:0.75rem;">
          <div class="pi-steps-title">Calculation</div>
          <div class="pi-step">
            <span class="pi-step-label">Final − Initial = Net Return</span>
            <span class="pi-step-val" id="roi-step1">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Net Return / Initial × 100 = ROI</span>
            <span class="pi-step-val" id="roi-step2">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Annualized ROI (CAGR)</span>
            <span class="pi-step-val" id="roi-step3">-</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/roi-calculator.js" is:inline></script>
</EmbedLayout>
