---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="BMI Calculator — calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">

      <div class="calculator-header">
        <h2>BMI Calculator</h2>
        <p>Body Mass Index in metric or imperial units</p>
      </div>

      <!-- Unit toggle -->
      <div class="bmi-unit-toggle">
        <button class="bmi-unit-btn active" data-unit="metric">Metric</button>
        <button class="bmi-unit-btn" data-unit="imperial">Imperial</button>
      </div>

      <!-- Metric inputs -->
      <div id="bmi-metric" class="bmi-inputs active">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-kg">Weight</label>
          <div class="bmi-input-wrap">
            <input type="number" id="bmi-weight-kg" class="bmi-input" min="1" max="500" step="0.1" placeholder="70" />
            <span class="bmi-unit-tag">kg</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-height-cm">Height</label>
          <div class="bmi-input-wrap">
            <input type="number" id="bmi-height-cm" class="bmi-input" min="50" max="280" step="1" placeholder="175" />
            <span class="bmi-unit-tag">cm</span>
          </div>
        </div>
      </div>

      <!-- Imperial inputs -->
      <div id="bmi-imperial" class="bmi-inputs">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-lb">Weight</label>
          <div class="bmi-input-wrap">
            <input type="number" id="bmi-weight-lb" class="bmi-input" min="1" max="1100" step="0.5" placeholder="154" />
            <span class="bmi-unit-tag">lbs</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label">Height</label>
          <div class="bmi-ftin">
            <div class="bmi-input-wrap">
              <input type="number" id="bmi-height-ft" class="bmi-input" min="1" max="9" step="1" placeholder="5" />
              <span class="bmi-unit-tag">ft</span>
            </div>
            <div class="bmi-input-wrap">
              <input type="number" id="bmi-height-in" class="bmi-input" min="0" max="11" step="1" placeholder="9" />
              <span class="bmi-unit-tag">in</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Result -->
      <div id="bmi-result" class="bmi-result hidden">
        <div class="bmi-value-row">
          <div class="bmi-value" id="bmi-value">—</div>
          <div class="bmi-category-badge" id="bmi-category-badge">—</div>
        </div>
        <div class="bmi-scale">
          <div class="bmi-scale-bar">
            <div class="bmi-seg bmi-seg-underweight"></div>
            <div class="bmi-seg bmi-seg-normal"></div>
            <div class="bmi-seg bmi-seg-overweight"></div>
            <div class="bmi-seg bmi-seg-obese"></div>
            <div class="bmi-indicator" id="bmi-indicator"></div>
          </div>
          <div class="bmi-scale-labels">
            <span style="left:0%">10</span>
            <span style="left:28.3%">18.5</span>
            <span style="left:50%">25</span>
            <span style="left:66.7%">30</span>
            <span style="left:100%">40+</span>
          </div>
        </div>
        <div class="bmi-details">
          <div class="bmi-detail" id="bmi-healthy-range"></div>
          <div class="bmi-detail bmi-detail-hint" id="bmi-next-category"></div>
        </div>
      </div>

    </div>
  </section>

  <script src="/js/bmi-calculator.js" is:inline></script>
</EmbedLayout>

