---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Gross Profit Margin Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Gross Profit Margin Calculator</h2>
        <p>Subtract COGS from Revenue, then divide by Revenue</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="gpm-revenue">Revenue</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="gpm-revenue" class="bmi-input" placeholder="e.g. 5000000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="gpm-cogs">Cost of Goods Sold (COGS)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="gpm-cogs" class="bmi-input" placeholder="e.g. 3000000" />
        </div>
      </div>

      <div id="gpm-result" class="lbm-result hidden">
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="gpm-gross-profit-val">-</div>
            <div class="lbm-card-lbl">Gross Profit</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="gpm-margin-val">-</div>
            <div class="lbm-card-lbl">Gross Profit Margin</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="gpm-interp-val">-</div>
            <div class="lbm-card-lbl">Interpretation</div>
          </div>
        </div>

        <div class="pi-steps" style="margin-top:0.75rem;">
          <div class="pi-steps-title">Calculation</div>
          <div class="pi-step">
            <span class="pi-step-label">Revenue − COGS = Gross Profit</span>
            <span class="pi-step-val" id="gpm-step1">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Gross Profit / Revenue = ratio</span>
            <span class="pi-step-val" id="gpm-step2">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">ratio × 100 = margin %</span>
            <span class="pi-step-val" id="gpm-step3">-</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/gross-profit-margin-calculator.js" is:inline></script>
</EmbedLayout>
