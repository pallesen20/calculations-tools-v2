---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Average Percentage Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Calculate Average Percentage</h2>
        <p>Enter two or more percentage values</p>
      </div>

      <div id="pav-rows" class="pav-rows"></div>
      <button type="button" id="pav-add" class="pav-add-btn">+ Add value</button>

      <div id="pav-result" class="lbm-result hidden">
        <div class="lbm-primary">
          <span class="lbm-primary-val" id="pav-avg">-</span>
        </div>
        <div class="lbm-primary-lbl">Average Percentage</div>

        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="pav-count">-</div>
            <div class="lbm-card-lbl">Values entered</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="pav-sum">-</div>
            <div class="lbm-card-lbl">Sum</div>
          </div>
        </div>

        <div class="pi-steps">
          <div class="pi-steps-title">How it was calculated</div>
          <div class="pi-step">
            <span class="pi-step-label">Step 1 - Sum</span>
            <span id="pav-step1" class="pi-step-val">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Step 2 - Divide by count</span>
            <span id="pav-step2" class="pi-step-val">-</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/average-percentage-calculator.js" is:inline></script>
</EmbedLayout>
