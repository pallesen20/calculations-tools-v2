---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Free Cash Flow Calculator — calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Free Cash Flow Calculator</h2>
        <p>Cash generated after capital investment</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="fcf-ocf">Operating Cash Flow</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="fcf-ocf" class="bmi-input" placeholder="e.g. 12000000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="fcf-capex">Capital Expenditures (CapEx)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="fcf-capex" class="bmi-input" placeholder="e.g. 3000000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="fcf-market-cap">Market Capitalisation (optional — for FCF Yield)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="fcf-market-cap" class="bmi-input" placeholder="e.g. 200000000" />
        </div>
      </div>

      <div id="fcf-result" class="lbm-result hidden">
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="fcf-val">—</div>
            <div class="lbm-card-lbl">Free Cash Flow</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="fcf-ocf-out">—</div>
            <div class="lbm-card-lbl">Operating Cash Flow</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="fcf-capex-out">—</div>
            <div class="lbm-card-lbl">CapEx</div>
          </div>
        </div>

        <div id="fcf-yield-row" class="lbm-cards hidden" style="margin-top:0.5rem;">
          <div class="lbm-card">
            <div class="lbm-card-val" id="fcf-yield-val">—</div>
            <div class="lbm-card-lbl">FCF Yield</div>
          </div>
        </div>

        <div class="pi-steps" style="margin-top:0.75rem;">
          <div class="pi-steps-title">Calculation</div>
          <div class="pi-step">
            <span class="pi-step-label">OCF − CapEx = FCF</span>
            <span class="pi-step-val" id="fcf-step1">—</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">FCF / Market Cap × 100 = FCF Yield</span>
            <span class="pi-step-val" id="fcf-step2">—</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/free-cash-flow-calculator.js" is:inline></script>
</EmbedLayout>
