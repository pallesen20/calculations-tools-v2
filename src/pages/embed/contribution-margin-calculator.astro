---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Contribution Margin Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Contribution Margin Calculator</h2>
        <p>Revenue minus variable costs - what's left to cover fixed costs and profit</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="cm-revenue">Total Revenue</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="cm-revenue" class="bmi-input" placeholder="e.g. 500000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="cm-variable">Total Variable Costs</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="cm-variable" class="bmi-input" placeholder="e.g. 300000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="cm-units">Units Sold (optional)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="cm-units" class="bmi-input" placeholder="e.g. 5000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="cm-fixed">Fixed Costs (optional)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="cm-fixed" class="bmi-input" placeholder="e.g. 120000" />
        </div>
      </div>

      <div id="cm-result" class="lbm-result hidden">
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="cm-val">-</div>
            <div class="lbm-card-lbl">Contribution Margin</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="cm-ratio-val">-</div>
            <div class="lbm-card-lbl">CM Ratio</div>
          </div>
        </div>

        <div id="cm-perunit-row" class="lbm-cards hidden" style="margin-top:0.5rem;">
          <div class="lbm-card">
            <div class="lbm-card-val" id="cm-perunit-val">-</div>
            <div class="lbm-card-lbl">CM per Unit</div>
          </div>
        </div>

        <div id="cm-profit-row" class="lbm-cards hidden" style="margin-top:0.5rem;">
          <div class="lbm-card">
            <div class="lbm-card-val" id="cm-profit-val">-</div>
            <div class="lbm-card-lbl">Operating Profit</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="cm-profitpct-val">-</div>
            <div class="lbm-card-lbl">Operating Margin</div>
          </div>
        </div>

        <div class="pi-steps" style="margin-top:0.75rem;">
          <div class="pi-steps-title">Calculation</div>
          <div class="pi-step">
            <span class="pi-step-label">Revenue − Variable = CM</span>
            <span class="pi-step-val" id="cm-step1">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">CM / Revenue × 100 = CM Ratio</span>
            <span class="pi-step-val" id="cm-step2">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">CM − Fixed = Operating Profit</span>
            <span class="pi-step-val" id="cm-step3">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">CM per unit</span>
            <span class="pi-step-val" id="cm-step4">-</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/contribution-margin-calculator.js" is:inline></script>
</EmbedLayout>
