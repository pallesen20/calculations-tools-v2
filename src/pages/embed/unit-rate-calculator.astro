---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Unit Rate Calculator — calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Unit Rate Calculator</h2>
        <p>Find the rate per one unit</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="ur-quantity">Total quantity (e.g. total cost)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="ur-quantity" class="bmi-input" placeholder="e.g. 15.60" />
        </div>
      </div>
      <div class="bmi-field">
        <label class="bmi-label" for="ur-units">Number of units (e.g. number of items)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="ur-units" class="bmi-input" placeholder="e.g. 12" />
        </div>
      </div>
      <div class="bmi-field">
        <label class="bmi-label" for="ur-scale">Scale (optional — how many units?)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="ur-scale" class="bmi-input" placeholder="e.g. 7" />
        </div>
      </div>

      <div id="ur-result" class="lbm-result hidden">
        <div class="lbm-primary">
          <span class="lbm-primary-val" id="ur-rate">—</span>
        </div>
        <div class="lbm-primary-lbl">Rate per 1 unit</div>

        <div class="lbm-cards">
          <div class="lbm-card hidden" id="ur-scale-row">
            <div class="lbm-card-val" id="ur-scaled">—</div>
            <div class="lbm-card-lbl" id="ur-scale-lbl">Total for N units</div>
          </div>
        </div>

        <div class="pi-steps">
          <div class="pi-steps-title">Step-by-step</div>
          <div class="pi-step">
            <span class="pi-step-label">Divide quantity by units</span>
            <span class="pi-step-val" id="ur-step1">—</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Result</span>
            <span class="pi-step-val" id="ur-step2">—</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/unit-rate-calculator.js" is:inline></script>
</EmbedLayout>
