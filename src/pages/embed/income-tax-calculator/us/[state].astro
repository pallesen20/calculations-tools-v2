---
import EmbedLayout from '../../../../layouts/EmbedLayout.astro';
import { US_INCOME_TAX } from '../../../../data/us-income-tax';

export function getStaticPaths() {
  return US_INCOME_TAX.map(s => ({
    params: { state: s.slug },
    props: { state: s },
  }));
}

const { state } = Astro.props;
const noTax = state.noTax;
const hasLocalTax = state.hasLocalTax;

const bracketsSingle = JSON.stringify(state.single.brackets.map(b => [b.min, b.max, b.rate]));
const bracketsMfj = JSON.stringify(state.mfj.brackets.map(b => [b.min, b.max, b.rate]));
const bracketsHoh = JSON.stringify(state.hoh.brackets.map(b => [b.min, b.max, b.rate]));
const bracketsMfs = JSON.stringify(state.mfs.brackets.map(b => [b.min, b.max, b.rate]));
---

<EmbedLayout title={`${state.name} Income Tax Calculator - calculations.tools`}>
  <div class="itax-card" id="itax-calculator"
    data-slug={state.slug}
    data-no-tax={noTax}
    data-has-local-tax={hasLocalTax}
    data-brackets-single={bracketsSingle}
    data-brackets-mfj={bracketsMfj}
    data-brackets-hoh={bracketsHoh}
    data-brackets-mfs={bracketsMfs}
    data-std-single={state.single.standardDeduction}
    data-std-mfj={state.mfj.standardDeduction}
    data-std-hoh={state.hoh.standardDeduction}
    data-std-mfs={state.mfs.standardDeduction}
    data-exempt-single={state.single.personalExemption || 0}
    data-exempt-mfj={state.mfj.personalExemption || 0}
    data-exempt-hoh={state.hoh.personalExemption || 0}
    data-exempt-mfs={state.mfs.personalExemption || 0}
  >
    <div class="itax-header">
      <div class="itax-state-badge">{state.abbr}</div>
      <div class="itax-header-info">
        <div class="itax-state-name">{state.name} Income Tax</div>
        {noTax ? (
          <div class="itax-rate-line itax-no-tax">
            <span class="itax-rate-pill itax-notax-pill">No state income tax</span>
          </div>
        ) : (
          <div class="itax-rate-line">
            <span class="itax-rate-pill">{state.single.brackets.length === 1 ? `${state.topRate}% flat` : `Up to ${state.topRate}%`}</span>
          </div>
        )}
      </div>
    </div>

    {noTax && (
      <div class="itax-no-tax-notice">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <div>
          <strong>{state.name} has no state income tax.</strong> Federal tax and FICA still apply.
        </div>
      </div>
    )}

    <div class="bmi-field">
      <label class="bmi-label" for="itax-gross">Annual gross income ($)</label>
      <input id="itax-gross" class="amount-input itax-input" type="text" inputmode="decimal" placeholder="75,000" />
    </div>

    <div class="bmi-field">
      <label class="bmi-label" for="itax-filing">Filing status</label>
      <div class="bmi-input-wrap">
        <select id="itax-filing" class="bmi-input">
          <option value="single">Single</option>
          <option value="mfj">Married Filing Jointly</option>
          <option value="hoh">Head of Household</option>
          <option value="mfs">Married Filing Separately</option>
        </select>
      </div>
    </div>

    {hasLocalTax && state.localRates && state.localRates.length > 0 && (
      <div class="bmi-field">
        <label class="bmi-label" for="itax-local">{state.localTaxLabel || 'Local'} income tax (optional)</label>
        <div class="bmi-input-wrap">
          <select id="itax-local" class="bmi-input">
            <option value="0">None / I don't know</option>
            {state.localRates.map(lr => (
              <option value={lr.rate}>{lr.name} - {lr.rate}%</option>
            ))}
          </select>
        </div>
      </div>
    )}

    <div id="itax-results" class="hidden">
      <div class="itax-results-grid">

        <div class="itax-results-section">
          <div class="itax-section-label">Taxes</div>
          <div class="itax-result-row">
            <span>Federal income tax</span>
            <span id="itax-res-fed" class="itax-val itax-tax-val">-</span>
          </div>
          <div class="itax-result-row">
            <span>{noTax ? `${state.name} state tax` : `${state.name} income tax`}</span>
            <span id="itax-res-state" class="itax-val itax-tax-val">-</span>
          </div>
          <div class="itax-result-row">
            <span>Social Security + Medicare</span>
            <span id="itax-res-fica" class="itax-val itax-tax-val">-</span>
          </div>
          {hasLocalTax && (
            <div class="itax-result-row">
              <span>Local tax</span>
              <span id="itax-res-local" class="itax-val itax-tax-val">-</span>
            </div>
          )}
          <div class="itax-result-row itax-row-highlight itax-row-tax-total">
            <span>Total taxes</span>
            <span id="itax-res-total-tax" class="itax-val">-</span>
          </div>
        </div>

        <div class="itax-results-section">
          <div class="itax-section-label">Take-home pay</div>
          <div class="itax-result-row itax-row-highlight">
            <span>Annual take-home</span>
            <span id="itax-res-takehome" class="itax-val">-</span>
          </div>
          <div class="itax-result-row">
            <span>Monthly</span>
            <span id="itax-res-takehome-mo" class="itax-val">-</span>
          </div>
          <div class="itax-result-row itax-row-last">
            <span>Bi-weekly</span>
            <span id="itax-res-takehome-bw" class="itax-val">-</span>
          </div>
        </div>

        <div class="itax-results-section">
          <div class="itax-section-label">Rates</div>
          <div class="itax-result-row">
            <span>Effective total rate</span>
            <span id="itax-res-effective" class="itax-val itax-rate-val">-</span>
          </div>
          <div class="itax-result-row itax-row-last">
            <span>Federal effective / marginal</span>
            <span style="display:flex;align-items:center;gap:0.2rem">
              <span id="itax-res-fed-eff" class="itax-val itax-rate-val">-</span>
              <span style="color:rgba(255,255,255,0.3);font-size:0.78rem">/</span>
              <span id="itax-res-fed-marginal" class="itax-val itax-rate-val">-</span>
            </span>
          </div>
        </div>

      </div>
    </div>

  </div>

  <script src="/js/income-tax-calculator-us-state.js" is:inline></script>
</EmbedLayout>

<style>
  .itax-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .itax-header { display: flex; align-items: center; gap: 0.875rem; }
  .itax-state-badge {
    width: 46px; height: 46px; border-radius: 10px;
    background: linear-gradient(135deg, rgba(139,92,246,0.6), rgba(59,130,246,0.6));
    border: 1px solid rgba(139,92,246,0.4);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; font-weight: 700; color: white; flex-shrink: 0;
  }
  .itax-state-name { font-size: 0.95rem; font-weight: 600; color: white; margin-bottom: 0.3rem; }
  .itax-rate-line { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .itax-rate-pill {
    font-size: 0.73rem; padding: 0.18rem 0.5rem; border-radius: 20px;
    background: rgba(139,92,246,0.25); border: 1px solid rgba(139,92,246,0.4); color: rgba(255,255,255,0.85);
  }
  .itax-rate-line.itax-no-tax .itax-rate-pill { background: rgba(52,211,153,0.2); border-color: rgba(52,211,153,0.4); color: rgba(52,211,153,0.9); }
  .itax-notax-pill { background: rgba(52,211,153,0.15) !important; border: 1px solid rgba(52,211,153,0.35) !important; color: rgba(52,211,153,0.9) !important; }
  .itax-no-tax-notice {
    display: flex; align-items: flex-start; gap: 0.6rem; padding: 0.75rem;
    background: rgba(52,211,153,0.08); border: 1px solid rgba(52,211,153,0.2);
    border-radius: 10px; color: rgba(255,255,255,0.85); font-size: 0.85rem; line-height: 1.5;
  }
  .itax-no-tax-notice svg { flex-shrink: 0; margin-top: 0.1rem; color: rgba(52,211,153,0.8); }
  .itax-results-grid { display: flex; flex-direction: column; gap: 0; }
  .itax-results-section {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px; overflow: hidden; margin-top: 0.75rem;
  }
  .itax-section-label {
    padding: 0.4rem 0.9rem; font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: rgba(255,255,255,0.45); background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .itax-result-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.55rem 0.9rem; font-size: 0.85rem; color: rgba(255,255,255,0.75);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .itax-result-row:last-child { border-bottom: none; }
  .itax-row-highlight { background: rgba(139,92,246,0.08); font-weight: 600; color: white; border-bottom-color: rgba(139,92,246,0.15) !important; }
  .itax-row-tax-total { background: rgba(239,68,68,0.07) !important; border-bottom-color: rgba(239,68,68,0.15) !important; }
  .itax-row-last { border-bottom: none; }
  .itax-val { font-variant-numeric: tabular-nums; font-weight: 500; }
  .itax-tax-val { color: rgba(248,113,113,0.9); }
  .itax-rate-val { color: rgba(167,139,250,0.9); font-size: 0.82rem; }
</style>
