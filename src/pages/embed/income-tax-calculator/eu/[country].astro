---
import EmbedLayout from '../../../../layouts/EmbedLayout.astro';
import { EU_INCOME_TAX } from '../../../../data/eu-income-tax';

export function getStaticPaths() {
  return EU_INCOME_TAX.map(c => ({
    params: { country: c.slug },
    props: { country: c },
  }));
}

const { country } = Astro.props;
const g = country.germanZones!;

const zoneData = JSON.stringify(g);
const socialData = JSON.stringify({
  rvRate: country.rvRate,
  rvCeiling: country.rvCeiling,
  kvPublicRate: country.kvPublicRate,
  kvCeiling: country.kvCeiling,
  pvRateWith: country.pvRateWith,
  pvRateChildless: country.pvRateChildless,
  pvRateSnWith: country.pvRateSnWith || 0,
  pvRateSnChildless: country.pvRateSnChildless || 0,
  avRate: country.avRate,
  avCeiling: country.avCeiling,
});
const soliData = JSON.stringify({
  threshSingle: country.soliThreshSingle || 0,
  threshMarried: country.soliThreshMarried || 0,
});
---

<EmbedLayout title={`${country.name} Income Tax Calculator 2026 - calculations.tools`}>
  <div class="itax-card" id="eutax-calculator"
    data-country={country.abbr.toLowerCase()}
    data-zones={zoneData}
    data-social={socialData}
    data-soli={soliData}
    data-werbungskosten={country.werbungskosten}
    data-entlastungsbetrag={country.taxClass2Deduction || 0}
    data-currency-symbol={country.currencySymbol}
  >

    <div class="itax-header">
      <div class="itax-state-badge">{country.abbr}</div>
      <div class="itax-header-info">
        <div class="itax-state-name">{country.name} Income Tax 2026</div>
        <div class="itax-rate-line">
          <span class="itax-rate-pill">14% - {country.topRate}% progressive</span>
        </div>
      </div>
    </div>

    <div class="eutax-period-row">
      <label class="bmi-label">Period</label>
      <div class="eutax-period-btns">
        <label class="eutax-period-btn"><input type="radio" name="eutax-period" value="monthly" /><span>Monthly</span></label>
        <label class="eutax-period-btn"><input type="radio" name="eutax-period" value="annual" checked /><span>Annual</span></label>
      </div>
    </div>

    <div class="bmi-field">
      <label class="bmi-label" for="eutax-gross">Gross salary ({country.currency})</label>
      <div class="bmi-input-wrap">
        <input id="eutax-gross" class="amount-input eutax-input" type="text" inputmode="decimal" placeholder="60,000" />
        <span class="bmi-unit-tag">{country.currencySymbol}</span>
      </div>
    </div>

    {country.hasHealthSelection && country.healthOptions && (
      <>
        <div class="bmi-field">
          <label class="bmi-label" for="eutax-health">Health insurance</label>
          <div class="bmi-input-wrap">
            <select id="eutax-health" class="bmi-input">
              {country.healthOptions.map(h => <option value={h.value}>{h.label}</option>)}
            </select>
          </div>
        </div>
        <div class="bmi-field" id="eutax-private-field" style="display:none">
          <label class="bmi-label" for="eutax-private-contrib">Private premium (annual {country.currency})</label>
          <div class="bmi-input-wrap">
            <input id="eutax-private-contrib" class="bmi-input eutax-input" type="text" inputmode="decimal" placeholder="6,000" />
            <span class="bmi-unit-tag">{country.currencySymbol}</span>
          </div>
        </div>
      </>
    )}

    {country.hasTaxClass && country.taxClasses && (
      <div class="bmi-field">
        <label class="bmi-label" for="eutax-tax-class">Tax class</label>
        <div class="bmi-input-wrap">
          <select id="eutax-tax-class" class="bmi-input">
            {country.taxClasses.map(tc => <option value={tc.value}>{tc.label} - {tc.description}</option>)}
          </select>
        </div>
      </div>
    )}

    {country.hasStateSelection && country.states && (
      <div class="bmi-field">
        <label class="bmi-label" for="eutax-state">State</label>
        <div class="bmi-input-wrap">
          <select id="eutax-state" class="bmi-input">
            {country.states.map(s => <option value={s.value} data-ks={s.ks || 0.09}>{s.label}</option>)}
          </select>
        </div>
      </div>
    )}

    {country.hasChurchTax && (
      <div class="bmi-field eutax-toggle-field">
        <label class="bmi-label">Church member</label>
        <label class="eutax-toggle">
          <input type="checkbox" id="eutax-church" />
          <span class="eutax-toggle-track"></span>
          <span class="eutax-toggle-label">Add church tax</span>
        </label>
      </div>
    )}

    {country.hasChildlessField && (
      <div class="bmi-field eutax-toggle-field">
        <label class="bmi-label">No children (age 23+)</label>
        <label class="eutax-toggle">
          <input type="checkbox" id="eutax-childless" />
          <span class="eutax-toggle-track"></span>
          <span class="eutax-toggle-label">Childless surcharge (+0.6% PV)</span>
        </label>
      </div>
    )}

    <div id="eutax-results" class="hidden">
      <div class="itax-results-grid">

        <div class="itax-results-section">
          <div class="itax-section-label">Income taxes</div>
          <div class="itax-result-row">
            <span>Income tax (Lohnsteuer)</span>
            <span id="eutax-res-est" class="itax-val itax-tax-val">-</span>
          </div>
          <div class="itax-result-row itax-nested">
            <span>Eff. / Marginal</span>
            <span id="eutax-res-est-rates" class="itax-val itax-rate-val">-</span>
          </div>
          <div class="itax-result-row" id="eutax-row-soli">
            <span>Solidarity surcharge</span>
            <span id="eutax-res-soli" class="itax-val itax-tax-val">-</span>
          </div>
          <div class="itax-result-row" id="eutax-row-kirche" style="display:none">
            <span>Church tax</span>
            <span id="eutax-res-kirche" class="itax-val itax-tax-val">-</span>
          </div>
        </div>

        <div class="itax-results-section">
          <div class="itax-section-label">Social contributions</div>
          <div class="itax-result-row">
            <span>Pension (RV 9.3%)</span>
            <span id="eutax-res-rv" class="itax-val itax-tax-val">-</span>
          </div>
          <div class="itax-result-row">
            <span>Health (KV 8.75%)</span>
            <span id="eutax-res-kv" class="itax-val itax-tax-val">-</span>
          </div>
          <div class="itax-result-row">
            <span id="eutax-pv-label">Long-term care (PV 1.8%)</span>
            <span id="eutax-res-pv" class="itax-val itax-tax-val">-</span>
          </div>
          <div class="itax-result-row">
            <span>Unemployment (AV 1.3%)</span>
            <span id="eutax-res-av" class="itax-val itax-tax-val">-</span>
          </div>
        </div>

        <div class="itax-results-section">
          <div class="itax-section-label">Summary</div>
          <div class="itax-result-row itax-row-highlight itax-row-tax-total">
            <span>Total deductions</span>
            <span id="eutax-res-total" class="itax-val">-</span>
          </div>
          <div class="itax-result-row itax-nested">
            <span>Effective rate</span>
            <span id="eutax-res-eff" class="itax-val itax-rate-val">-</span>
          </div>
          <div class="itax-result-row itax-row-highlight">
            <span>Annual net</span>
            <span id="eutax-res-net-annual" class="itax-val">-</span>
          </div>
          <div class="itax-result-row itax-row-last">
            <span>Monthly net</span>
            <span id="eutax-res-net-monthly" class="itax-val">-</span>
          </div>
        </div>

      </div>
    </div>

    <div class="embed-attribution">
      <a href={`https://calculations.tools/tax/income-tax-calculator/eu/${country.slug}`} target="_blank" rel="noopener">
        {country.name} Income Tax Calculator - calculations.tools
      </a>
    </div>

  </div>

  <script src="/js/income-tax-calculator-eu-country.js" is:inline></script>

  <style is:global>
    .eutax-period-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .eutax-period-btns { display: flex; gap: 0.5rem; }
    .eutax-period-btn { display: flex; align-items: center; cursor: pointer; }
    .eutax-period-btn input[type="radio"] { display: none; }
    .eutax-period-btn span {
      padding: 0.3rem 0.85rem; border-radius: 20px; font-size: 0.82rem;
      border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.55); cursor: pointer;
    }
    .eutax-period-btn input:checked + span {
      background: rgba(139,92,246,0.3); border-color: rgba(139,92,246,0.5); color: white;
    }
    .eutax-toggle-field { flex-direction: column; align-items: flex-start !important; gap: 0.4rem; }
    .eutax-toggle { display: flex; align-items: center; gap: 0.6rem; cursor: pointer; }
    .eutax-toggle input[type="checkbox"] { display: none; }
    .eutax-toggle-track {
      width: 38px; height: 20px; background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2); border-radius: 20px;
      position: relative; transition: background 0.2s; flex-shrink: 0;
    }
    .eutax-toggle-track::after {
      content: ''; position: absolute; top: 2px; left: 2px;
      width: 14px; height: 14px; background: rgba(255,255,255,0.45);
      border-radius: 50%; transition: transform 0.2s, background 0.2s;
    }
    .eutax-toggle input:checked ~ .eutax-toggle-track { background: rgba(139,92,246,0.5); border-color: rgba(139,92,246,0.6); }
    .eutax-toggle input:checked ~ .eutax-toggle-track::after { transform: translateX(18px); background: white; }
    .eutax-toggle-label { font-size: 0.85rem; color: rgba(255,255,255,0.75); }
  </style>
</EmbedLayout>
