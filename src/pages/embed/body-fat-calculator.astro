---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Body Fat Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Navy Tape Test</h2>
        <p>Body fat % from circumference measurements - metric or imperial</p>
      </div>

      <div class="bmi-unit-toggle">
        <button class="bmi-unit-btn active" data-unit="metric">Metric</button>
        <button class="bmi-unit-btn" data-unit="imperial">Imperial</button>
      </div>

      <div class="bmi-shared-fields">
        <div class="bmi-field">
          <label class="bmi-label">Sex</label>
          <div class="bmi-sex-toggle">
            <button class="bmi-sex-btn active" data-sex="male">Male</button>
            <button class="bmi-sex-btn" data-sex="female">Female</button>
          </div>
        </div>
      </div>

      <div id="bmi-metric" class="bmi-inputs active">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-height-cm">Height</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-height-cm" class="bmi-input" min="50" max="280" step="1" placeholder="178" />
            <span class="bmi-unit-tag">cm</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-kg">Weight</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-weight-kg" class="bmi-input" min="1" max="500" step="0.1" placeholder="80" />
            <span class="bmi-unit-tag">kg</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bf-waist-cm">Waist</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bf-waist-cm" class="bmi-input" min="30" max="200" step="0.5" placeholder="85" />
            <span class="bmi-unit-tag">cm</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bf-neck-cm">Neck</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bf-neck-cm" class="bmi-input" min="20" max="70" step="0.5" placeholder="38" />
            <span class="bmi-unit-tag">cm</span>
          </div>
        </div>
        <div class="bmi-field bf-female-only hidden">
          <label class="bmi-label" for="bf-hip-cm">Hip</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bf-hip-cm" class="bmi-input" min="40" max="200" step="0.5" placeholder="95" />
            <span class="bmi-unit-tag">cm</span>
          </div>
        </div>
      </div>

      <div id="bmi-imperial" class="bmi-inputs">
        <div class="bmi-field">
          <label class="bmi-label">Height</label>
          <div class="bmi-height-imperial">
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="bmi-height-ft" class="bmi-input" min="1" max="8" step="1" placeholder="5" />
              <span class="bmi-unit-tag">ft</span>
            </div>
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="bmi-height-in" class="bmi-input" min="0" max="11" step="1" placeholder="10" />
              <span class="bmi-unit-tag">in</span>
            </div>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-lb">Weight</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-weight-lb" class="bmi-input" min="1" max="1100" step="0.5" placeholder="176" />
            <span class="bmi-unit-tag">lbs</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bf-waist-in">Waist</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bf-waist-in" class="bmi-input" min="10" max="80" step="0.25" placeholder="33.5" />
            <span class="bmi-unit-tag">in</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bf-neck-in">Neck</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bf-neck-in" class="bmi-input" min="8" max="28" step="0.25" placeholder="15" />
            <span class="bmi-unit-tag">in</span>
          </div>
        </div>
        <div class="bmi-field bf-female-only hidden">
          <label class="bmi-label" for="bf-hip-in">Hip</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bf-hip-in" class="bmi-input" min="15" max="80" step="0.25" placeholder="37.5" />
            <span class="bmi-unit-tag">in</span>
          </div>
        </div>
      </div>

      <div class="bmi-shared-fields" style="margin-top:0.75rem">
        <div class="bmi-field">
          <label class="bmi-label" for="bf-age">Age <span class="bmi-optional">(optional)</span></label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bf-age" class="bmi-input" min="18" max="100" step="1" placeholder="30" />
            <span class="bmi-unit-tag">yrs</span>
          </div>
        </div>
      </div>

      <div id="bf-result" class="lbm-result hidden">
        <div class="lbm-primary">
          <span class="lbm-primary-val" id="bf-val">-</span>
          <span class="lbm-primary-unit">%</span>
        </div>
        <div class="ffmi-badge-center">
          <span class="lbm-card-badge" id="bf-badge">-</span>
        </div>
        <div class="lbm-primary-lbl">Body Fat - Navy Method</div>
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="bf-fat-mass">-</div>
            <div class="lbm-card-lbl">Fat mass</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="bf-lbm">-</div>
            <div class="lbm-card-lbl">Lean body mass</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="bf-bmi">-</div>
            <div class="lbm-card-lbl">BMI</div>
          </div>
          <div class="lbm-card hidden" id="bf-deurenberg-row">
            <div class="lbm-card-val" id="bf-deurenberg-val">-</div>
            <div class="lbm-card-lbl">BMI estimate (Deurenberg)</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <script src="/js/body-fat-calculator.js" is:inline></script>
</EmbedLayout>
