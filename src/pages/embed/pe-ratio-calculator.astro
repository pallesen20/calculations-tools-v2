---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="P/E Ratio Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>P/E Ratio Calculator</h2>
        <p>Price-to-Earnings multiple, earnings yield, and implied fair value</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="pe-price">Stock Price</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="pe-price" class="bmi-input" placeholder="e.g. 150" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="pe-eps">Earnings Per Share - EPS (trailing / LTM)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="pe-eps" class="bmi-input" placeholder="e.g. 7.50" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="pe-forward-eps">Forward EPS (optional)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="pe-forward-eps" class="bmi-input" placeholder="e.g. 9.00" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="pe-target-pe">Target P/E Multiple (optional)</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="pe-target-pe" class="bmi-input" placeholder="e.g. 18" />
        </div>
      </div>

      <div id="pe-result" class="lbm-result hidden">
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="pe-val">-</div>
            <div class="lbm-card-lbl">Trailing P/E</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="pe-earnings-yield">-</div>
            <div class="lbm-card-lbl">Earnings Yield</div>
          </div>
        </div>

        <div id="pe-forward-row" class="lbm-cards hidden" style="margin-top:0.5rem;">
          <div class="lbm-card">
            <div class="lbm-card-val" id="pe-forward-val">-</div>
            <div class="lbm-card-lbl">Forward P/E</div>
          </div>
        </div>

        <div id="pe-implied-row" class="lbm-cards hidden" style="margin-top:0.5rem;">
          <div class="lbm-card">
            <div class="lbm-card-val" id="pe-implied-price">-</div>
            <div class="lbm-card-lbl">Implied Fair Value</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="pe-updownside">-</div>
            <div class="lbm-card-lbl">Upside / Downside</div>
          </div>
        </div>

        <div class="pi-steps" style="margin-top:0.75rem;">
          <div class="pi-steps-title">Calculation</div>
          <div class="pi-step">
            <span class="pi-step-label">Price / EPS = Trailing P/E</span>
            <span class="pi-step-val" id="pe-step1">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">EPS / Price × 100 = Earnings Yield</span>
            <span class="pi-step-val" id="pe-step2">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Price / Forward EPS = Forward P/E</span>
            <span class="pi-step-val" id="pe-step3">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">EPS × Target P/E = Implied Price</span>
            <span class="pi-step-val" id="pe-step4">-</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/pe-ratio-calculator.js" is:inline></script>
</EmbedLayout>
