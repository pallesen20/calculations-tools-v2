---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="FFMI Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Fat-Free Mass Index</h2>
        <p>Muscle mass relative to height - with natural limit check</p>
      </div>

      <div class="bmi-unit-toggle">
        <button class="bmi-unit-btn active" data-unit="metric">Metric</button>
        <button class="bmi-unit-btn" data-unit="imperial">Imperial</button>
      </div>

      <div class="bmi-shared-fields">
        <div class="bmi-field">
          <label class="bmi-label">Sex</label>
          <div class="bmi-sex-toggle">
            <button class="bmi-sex-btn active" data-sex="male">Male</button>
            <button class="bmi-sex-btn" data-sex="female">Female</button>
          </div>
        </div>
      </div>

      <div id="bmi-metric" class="bmi-inputs active">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-kg">Weight</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-weight-kg" class="bmi-input" min="1" max="500" step="0.1" placeholder="80" />
            <span class="bmi-unit-tag">kg</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-height-cm">Height</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-height-cm" class="bmi-input" min="50" max="280" step="1" placeholder="178" />
            <span class="bmi-unit-tag">cm</span>
          </div>
        </div>
      </div>

      <div id="bmi-imperial" class="bmi-inputs">
        <div class="bmi-field">
          <label class="bmi-label" for="bmi-weight-lb">Weight</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="bmi-weight-lb" class="bmi-input" min="1" max="1100" step="0.5" placeholder="176" />
            <span class="bmi-unit-tag">lbs</span>
          </div>
        </div>
        <div class="bmi-field">
          <label class="bmi-label">Height</label>
          <div class="bmi-height-imperial">
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="bmi-height-ft" class="bmi-input" min="1" max="8" step="1" placeholder="5" />
              <span class="bmi-unit-tag">ft</span>
            </div>
            <div class="bmi-input-wrap">
              <input type="text" inputmode="decimal" id="bmi-height-in" class="bmi-input" min="0" max="11" step="1" placeholder="10" />
              <span class="bmi-unit-tag">in</span>
            </div>
          </div>
        </div>
      </div>

      <div class="bmi-shared-fields" style="margin-top:0.75rem">
        <div class="bmi-field">
          <label class="bmi-label" for="ffmi-bf-pct">Body fat %</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="ffmi-bf-pct" class="bmi-input" min="1" max="60" step="0.1" placeholder="15" />
            <span class="bmi-unit-tag">%</span>
          </div>
        </div>
      </div>

      <div id="ffmi-result" class="lbm-result hidden">
        <div class="lbm-primary">
          <span class="lbm-primary-val" id="ffmi-val">-</span>
          <span class="lbm-primary-unit">FFMI</span>
        </div>
        <div class="ffmi-badge-center">
          <span class="lbm-card-badge" id="ffmi-badge">-</span>
        </div>
        <div class="lbm-primary-lbl">Normalised Fat-Free Mass Index</div>
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="ffmi-raw-val">-</div>
            <div class="lbm-card-lbl">Raw FFMI</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="ffmi-lbm">-</div>
            <div class="lbm-card-lbl">Lean body mass</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="ffmi-fat">-</div>
            <div class="lbm-card-lbl">Fat mass</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="ffmi-bmi">-</div>
            <div class="lbm-card-lbl">BMI</div>
          </div>
        </div>
        <div class="ffmi-limit-note hidden" id="ffmi-limit-note"></div>
      </div>

    </div>
  </section>

  <script src="/js/ffmi-calculator.js" is:inline></script>
</EmbedLayout>
