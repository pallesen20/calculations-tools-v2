---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout title="Working Capital Calculator - calculations.tools">
  <section class="calculator-interface">
    <div class="calculator-container bmi-container">
      <div class="calculator-header">
        <h2>Working Capital Calculator</h2>
        <p>Measure short-term liquidity from the balance sheet</p>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="wc-assets">Total Current Assets</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="wc-assets" class="bmi-input" placeholder="e.g. 500000" />
        </div>
      </div>

      <div class="bmi-field">
        <label class="bmi-label" for="wc-liabilities">Total Current Liabilities</label>
        <div class="bmi-input-wrap">
          <input type="text" inputmode="decimal" id="wc-liabilities" class="bmi-input" placeholder="e.g. 300000" />
        </div>
      </div>

      <div id="wc-result" class="lbm-result hidden">
        <div class="lbm-cards">
          <div class="lbm-card">
            <div class="lbm-card-val" id="wc-val">-</div>
            <div class="lbm-card-lbl">Working Capital</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="wc-ratio-val">-</div>
            <div class="lbm-card-lbl">Current Ratio</div>
          </div>
        </div>

        <div class="lbm-cards" style="margin-top:0.5rem;">
          <div class="lbm-card">
            <div class="lbm-card-val" id="wc-assets-out">-</div>
            <div class="lbm-card-lbl">Current Assets</div>
          </div>
          <div class="lbm-card">
            <div class="lbm-card-val" id="wc-liabilities-out">-</div>
            <div class="lbm-card-lbl">Current Liabilities</div>
          </div>
        </div>

        <div id="wc-status" class="wc-status" style="margin-top:0.75rem;text-align:center;font-weight:600;padding:0.5rem;border-radius:0.5rem;"></div>

        <div class="pi-steps" style="margin-top:0.75rem;">
          <div class="pi-steps-title">Calculation</div>
          <div class="pi-step">
            <span class="pi-step-label">Assets − Liabilities = Working Capital</span>
            <span class="pi-step-val" id="wc-step1">-</span>
          </div>
          <div class="pi-step">
            <span class="pi-step-label">Assets / Liabilities = Current Ratio</span>
            <span class="pi-step-val" id="wc-step2">-</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/working-capital-calculator.js" is:inline></script>
</EmbedLayout>
