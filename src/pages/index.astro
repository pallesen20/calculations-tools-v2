---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCategoryCards, getFeaturedTools, siteToolCount } from '../utils/getPages';

const categoryCards  = getCategoryCards();
const featuredTools  = getFeaturedTools();
const totalCategories = categoryCards.length;

const features = [
  { icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>', title: 'Lightning Fast', description: 'All calculations happen instantly in your browser. No waiting, no delays.' },
  { icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>', title: 'Accurate Results', description: 'Precision-tested algorithms ensure you get the right answer every time.' },
  { icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18" stroke-width="2"/></svg>', title: 'Mobile Friendly', description: 'Fully responsive design works perfectly on phones, tablets, and desktops.' },
  { icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7" stroke-width="2.5"/></svg>', title: 'Completely Free', description: 'No subscriptions, no hidden fees. All tools are 100% free to use.' },
  { icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>', title: 'Privacy First', description: "All calculations happen locally in your browser. Your data never leaves your device." },
  { icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.8 5.5 5.7 0-4.6 3.3 1.8 5.5L12 14l-4.7 3.3 1.8-5.5L4.5 8.5l5.7 0z"/><path d="M19 3l.75 2.25L22 6l-2.25.75L19 9l-.75-2.25L16 6l2.25-.75z"/><path d="M5 17l.5 1.5 1.5.5-1.5.5L5 21l-.5-1.5L3 19l1.5-.5z"/></svg>', title: 'Beautiful Design', description: 'Modern, clean interface with smooth animations and intuitive controls.' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Calculations.tools",
    "url": "https://calculations.tools/",
    "description": "Free online calculators and converters for health, percentages, unit conversion, text analysis, currency, and more.",
    "publishingPrinciples": "https://calculations.tools/editorial-standards"
  }
];
---

<BaseLayout
  title="Free Online Calculators & Conversion Tools"
  metaTitle="Calculations.tools - Free Online Calculators & Converters"
  description="Free online calculators and converters for health, math, unit conversion, text, and date calculations. BMI, body composition, percentages, length, weight, temperature, currency, and more."
  schema={schema}
>
  <div class="text-center mb-12">
    <h1 class="main-title" style="margin-top: 1rem;">Free Online Calculators & Tools</h1>
    <p class="subtitle">Health calculators, unit converters, and everyday math tools - instant, free, no login</p>
  </div>

  <main class="main-content">
    <div class="container">

      <section style="margin-bottom: 3rem;">

        <div class="hi-stats">
          <div class="hi-stat">
            <div class="hi-stat-val">{siteToolCount}</div>
            <div class="hi-stat-lbl">Tools</div>
          </div>
          <div class="hi-stat">
            <div class="hi-stat-val">{totalCategories}</div>
            <div class="hi-stat-lbl">Categories</div>
          </div>
          <div class="hi-stat hi-stat-wide">
            <div class="hi-stat-val hi-stat-free">Free</div>
            <div class="hi-stat-lbl">No login · runs in browser</div>
          </div>
        </div>

        <div class="ch-grid">
          {categoryCards.map(cat => (
            <a href={cat.hubPath} class="ch-card">
              <div class="ch-icon">{cat.icon}</div>
              <div class="ch-name">{cat.name}</div>
              <div class="ch-count">{cat.toolCount} tools</div>
            </a>
          ))}
        </div>

        <div class="hi-group">
          <div class="hi-group-header">
            <span class="hi-group-label">Featured tools</span>
          </div>
          <div class="hi-grid hi-grid--3col">
            {featuredTools.map(tool => (
              <a href={tool.path} class="hi-card">
                <div class="hi-icon">{tool.icon}</div>
                <div class="hi-body">
                  <div class="hi-title">{tool.title}</div>
                  {tool.short && <div class="hi-short">{tool.short}</div>}
                </div>
                <div class="hi-arrow">→</div>
              </a>
            ))}
          </div>
        </div>

      </section>

      <section class="features">
        <h2>Why Choose Calculations.tools?</h2>
        <div class="frontpage-grid">
          {features.map(f => (
            <div class="feature-card">
              <div class="feature-icon" set:html={f.icon} />
              <h3>{f.title}</h3>
              <p>{f.description}</p>
            </div>
          ))}
        </div>
      </section>

      <div class="seo-container">
        <h2>Free Online Calculators for Health, Math & Conversions</h2>
        <p>Calculations.tools is a free collection of {siteToolCount} calculators and converters across {totalCategories} categories. Every tool runs entirely in your browser - no registration, no data sent to any server, instant results as you type.</p>

        <h3>Health Calculators</h3>
        <p>The <a href="/health">health section</a> covers BMI, body composition, and fitness metrics. The <a href="/health/bmi-calculator">BMI Calculator</a> adds age and sex context, estimated body fat %, and a healthy weight range. Specialist variants cover <a href="/health/bmi-calculator/men">men</a>, <a href="/health/bmi-calculator/women">women</a>, <a href="/health/bmi-calculator/kids">children</a>, <a href="/health/bmi-calculator/teens">teenagers</a>, <a href="/health/bmi-calculator/seniors">seniors</a>, and <a href="/health/bmi-calculator/pregnancy">pregnancy</a>. Body composition tools include the <a href="/health/lean-body-mass-calculator">Lean Body Mass Calculator</a>, the <a href="/health/ffmi-calculator">FFMI Calculator</a>, the <a href="/health/body-fat-calculator">Body Fat Calculator</a>, and the <a href="/health/ideal-weight-calculator">Ideal Weight Calculator</a>.</p>

        <h3>Finance Calculators</h3>
        <p>The <a href="/finance">finance section</a> covers earnings metrics, profit margins, valuation, and loans. Tools include <a href="/finance/ebitda-calculator">EBITDA</a>, <a href="/finance/ebit-calculator">EBIT</a>, <a href="/finance/roi-calculator">ROI</a>, <a href="/finance/compound-interest-calculator">compound interest</a>, and <a href="/finance/loan-payment-calculator">loan payment</a> calculators. Every tool shows step-by-step workings and industry benchmarks.</p>

        <h3>Unit Converters</h3>
        <p>The <a href="/conversion">conversion section</a> covers the most commonly needed unit types: <a href="/conversion/length-converter">length</a> (km, miles, feet, inches), <a href="/conversion/weight-converter">weight</a> (kg, lbs, stone, oz), <a href="/conversion/temperature-converter">temperature</a> (Celsius, Fahrenheit, Kelvin), <a href="/conversion/height-converter">height</a> (cm to feet and inches), a <a href="/conversion/speed-converter">speed converter</a> (mph, km/h, knots, m/s), and a <a href="/conversion/currency-converter">live currency converter</a> covering 150+ currencies.</p>

        <h3>Math & Text Tools</h3>
        <p>The <a href="/math/percentage-calculator">Percentage Calculator</a> handles all percentage modes: basic percentages, percentage increase and decrease, percentage difference, and percentage of a total. The <a href="/word-counter">Word Counter</a> gives instant word, character, sentence, paragraph, and reading time counts. The <a href="/compare/text">Text Diff Checker</a> compares two texts side by side with color-coded additions and removals.</p>

        <h3>Date & Time Tools</h3>
        <p>The <a href="/week-number">Week Number</a> tool shows the current ISO 8601 week number with a full year calendar and code snippets for 20+ programming languages. The <a href="/date-calculator">Date Calculator</a> computes the number of days, workdays, weeks, and years-months-days between any two dates.</p>

        <h2>Frequently Asked Questions</h2>

        <h3>Are all tools really free?</h3>
        <p>Yes. Every tool on Calculations.tools is completely free - no subscriptions, no usage limits, no premium features.</p>

        <h3>Do I need to create an account?</h3>
        <p>No. All tools are immediately accessible without registration. Visit the tool you need and start calculating.</p>

        <h3>Are my calculations private?</h3>
        <p>Yes. All calculations run locally in your web browser. No input data is transmitted to any server.</p>

        <h3>Do the tools work on mobile?</h3>
        <p>Yes. Every tool is fully responsive and works on any phone, tablet, or desktop. No app required.</p>

        <h3>Can I embed these tools on my website?</h3>
        <p>Several tools offer embeddable widgets - check individual tool pages for the embed option in the sidebar.</p>
      </div>

    </div>
  </main>
</BaseLayout>
