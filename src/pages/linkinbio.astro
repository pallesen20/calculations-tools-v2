---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFrontPageGroups } from '../utils/getPages';

const groups = getFrontPageGroups();

function hubLabel(category: string): string {
  return category.replace(' Calculators', '').replace(' Tools', '');
}
---

<BaseLayout
  title="calculations.tools"
  metaTitle="Link-in-bio - calculations.tools"
  description="Free online calculators for math, health, conversions and more."
  noindex={true}
>
  <main class="lib-main">
    <div class="lib-container">

      <div class="lib-header">
        <div class="lib-logo">🧮</div>
        <div class="lib-wordmark">Links Shortcut</div>
        <p class="lib-tagline">Free online calculators and conversions - instant results, no login</p>
      </div>

      {groups.map(group => (
        <div class="lib-section">
          {group.indexPath ? (
            <a href={group.indexPath} class="lib-card lib-card--hub no-underline">
              <span class="lib-icon">{group.tools[0]?.icon}</span>
              <span class="lib-label">{hubLabel(group.category)}</span>
              <span class="lib-arrow">→</span>
            </a>
          ) : (
            <>
              <div class="lib-group-label">{group.category}</div>
              {group.tools.map(tool => (
                <a href={tool.path} class="lib-card no-underline">
                  <span class="lib-icon">{tool.icon}</span>
                  <span class="lib-label">{tool.title}</span>
                  <span class="lib-arrow">→</span>
                </a>
              ))}
            </>
          )}
        </div>
      ))}

    </div>
  </main>
</BaseLayout>

<style>
  .lib-main {
    min-height: 100vh;
    padding: 1rem;
    display: flex;
    justify-content: center;
  }
  .lib-container {
    width: 100%;
    max-width: 460px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .lib-header {
    text-align: center;
    padding-bottom: 1.5rem;
  }
  .lib-logo {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .lib-wordmark {
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.4rem;
  }
  .lib-tagline {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }
  .lib-section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .lib-group-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    padding: 0.75rem 0 0.1rem 0.25rem;
  }
  .lib-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    min-height: 56px;
    padding: 0 1.25rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    color: white;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.15s;
    cursor: pointer;
  }
  .lib-card:hover,
  .lib-card:active {
    background: rgba(255,255,255,0.11);
  }
  .lib-card--hub {
    min-height: 64px;
    font-size: 1.05rem;
    font-weight: 600;
    background: rgba(255,255,255,0.08);
  }
  .lib-icon {
    font-size: 1.25rem;
    width: 1.5rem;
    text-align: center;
    flex-shrink: 0;
  }
  .lib-label {
    flex: 1;
  }
  .lib-arrow {
    color: rgba(255,255,255,0.35);
    font-size: 1rem;
    flex-shrink: 0;
  }
</style>
