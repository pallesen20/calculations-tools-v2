---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';

const tocItems = [
  { id: 'how-to-use',    label: 'How to use this tool' },
  { id: 'css-diff',      label: 'CSS diff considerations' },
  { id: 'use-cases',     label: 'Use cases' },
  { id: 'faq',           label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CSS Diff Checker",
    "url": "https://calculations.tools/compare/css",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "description": "Compare two CSS or SCSS files online and find every changed selector, property, and value. Color-coded line-by-line diff. Free, private, runs entirely in your browser.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How do I compare two CSS files online?", "acceptedAnswer": { "@type": "Answer", "text": "Paste your original CSS in the left panel and the updated version in the right panel, then click Find Differences. Added lines appear in green, removed lines in red. Upload .css, .scss, .sass, or .less files directly." } },
      { "@type": "Question", "name": "Can I compare SCSS files?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. SCSS, Sass, and Less files are plain text. The tool compares them line by line exactly like plain CSS. The file upload dialog accepts .css, .scss, .sass, and .less files." } }
    ]
  }
];
---

<CalculatorLayout
  title="Compare CSS Files"
  metaTitle="Compare CSS Files Online Free | CSS Code Diff Checker ᐅ"
  description="Compare two CSS or SCSS files online and find every changed selector, property, and value. Line-by-line color-coded diff. Free, private, runs in your browser."
  canonical="https://calculations.tools/compare/css"
  tocItems={tocItems}
  schema={schema}
  embedSlug="compare-css"
  ogFormula="CSS LCS diff"
  ogExample="Find every changed selector, property & value"
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container ct-container">

        <div class="calculator-header">
          <h2>CSS Code Diff Checker</h2>
          <p>Paste or upload two .css, .scss, .sass, or .less files to compare them line by line</p>
          <div class="cc-lang-row">
            <label for="cc-lang" class="cc-lang-label">Language</label>
            <select id="cc-lang" class="cc-lang-select" onchange="updateLanguage()">
              <option value="any">Any / All languages</option>
              <option value="python">Python</option>
              <option value="javascript">JavaScript / TypeScript</option>
              <option value="css" selected>CSS / SCSS</option>
              <option value="html">HTML</option>
            </select>
          </div>
        </div>

        <div class="ct-editors">

          <div class="diff-panel">
            <div class="diff-toolbar">
              <h3>Original CSS</h3>
              <div class="diff-toolbar-btns">
                <button class="diff-tbtn" onclick="uploadFile('ct-original')" title="Upload file"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></button>
                <button class="diff-tbtn" onclick="downloadText('ct-original')" title="Download"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>
                <button class="diff-tbtn" onclick="copyText('ct-original')" title="Copy"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
                <button class="diff-tbtn" onclick="clearText('ct-original')" title="Clear">✕</button>
              </div>
            </div>
            <div class="ct-editor-wrap" id="ct-original-wrap">
              <div class="ct-gutter" id="ct-original-gutter"><div>1</div></div>
              <div class="ct-hl" id="ct-original-hl" style="top:0.75rem"></div>
              <textarea id="ct-original" class="ct-textarea" wrap="off" placeholder="Paste your original CSS here..." spellcheck="false" oninput="updateEditor('ct-original')" onfocus="document.getElementById('ct-original-wrap').classList.add('focused')" onblur="document.getElementById('ct-original-wrap').classList.remove('focused')" onkeyup="updateActiveLine('ct-original')" onclick="updateActiveLine('ct-original')" onscroll="syncScroll('ct-original')"></textarea>
            </div>
            <div class="ct-stats">
              <span id="ct-original-lines">Lines: 0</span>
              <span id="ct-original-chars">Characters: 0</span>
            </div>
          </div>

          <div class="diff-panel">
            <div class="diff-toolbar">
              <h3>Changed CSS</h3>
              <div class="diff-toolbar-btns">
                <button class="diff-tbtn" onclick="uploadFile('ct-changed')" title="Upload file"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></button>
                <button class="diff-tbtn" onclick="downloadText('ct-changed')" title="Download"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>
                <button class="diff-tbtn" onclick="copyText('ct-changed')" title="Copy"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
                <button class="diff-tbtn" onclick="clearText('ct-changed')" title="Clear">✕</button>
              </div>
            </div>
            <div class="ct-editor-wrap" id="ct-changed-wrap">
              <div class="ct-gutter" id="ct-changed-gutter"><div>1</div></div>
              <div class="ct-hl" id="ct-changed-hl" style="top:0.75rem"></div>
              <textarea id="ct-changed" class="ct-textarea" wrap="off" placeholder="Paste your changed CSS here..." spellcheck="false" oninput="updateEditor('ct-changed')" onfocus="document.getElementById('ct-changed-wrap').classList.add('focused')" onblur="document.getElementById('ct-changed-wrap').classList.remove('focused')" onkeyup="updateActiveLine('ct-changed')" onclick="updateActiveLine('ct-changed')" onscroll="syncScroll('ct-changed')"></textarea>
            </div>
            <div class="ct-stats">
              <span id="ct-changed-lines">Lines: 0</span>
              <span id="ct-changed-chars">Characters: 0</span>
            </div>
          </div>

        </div>

        <div class="diff-actions">
          <button class="diff-btn-primary" onclick="findDifferences()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Find Differences</button>
          <button class="diff-btn-secondary" onclick="swapTexts()">⇄ Swap</button>
          <button class="diff-btn-secondary" onclick="loadSample()"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg> Sample</button>
        </div>

        <div id="diff-output" class="diff-output">
          <div class="diff-header">
            <div class="diff-stats">
              <span class="diff-added"   id="ct-stat-added">+0 added</span>
              <span class="diff-removed" id="ct-stat-removed">−0 removed</span>
              <span class="diff-unchanged" id="ct-stat-unchanged">0 unchanged</span>
            </div>
            <div class="ct-diff-controls">
              <div class="ct-view-toggle">
                <button id="ct-btn-unified" onclick="setView('unified')">Unified</button>
                <button id="ct-btn-sbs"     onclick="setView('sbs')">Side-by-Side</button>
              </div>
              <button class="diff-tbtn" onclick="copyDiff()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy Diff</button>
            </div>
          </div>
          <div class="ct-diff-container" id="ct-diff-container"></div>
        </div>

      </div>
    </section>

    <input type="file" id="ct-file-input" style="display:none" accept=".css,.scss,.sass,.less" />
    <div class="diff-toast"></div>
    <script src="/js/compare-code.js" is:inline></script>
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>Paste your original CSS in the left panel and the updated version in the right panel, then click <strong>Find Differences</strong>. Added lines appear in green, removed in red. Upload .css, .scss, .sass, or .less files directly. All processing runs in your browser - nothing is sent to a server.</p>
      </div>

      <h2 id="how-to-use">How to use this tool</h2>
      <p>Paste or upload your original stylesheet on the left and the changed version on the right. Click "Find Differences." The diff shows every added and removed line with line numbers. Toggle Unified or Side-by-Side view. Uploads filter to .css, .scss, .sass, and .less files.</p>

      <h2 id="css-diff">CSS diff considerations</h2>
      <h3>Formatter-driven changes</h3>
      <p>A CSS formatter or linter (Prettier, Stylelint) can change many lines at once - property order, whitespace, brace placement, or semicolons. If you are looking for logical changes only, run both files through the same formatter before diffing.</p>
      <h3>Vendor prefix additions</h3>
      <p>Adding or removing <code>-webkit-</code>, <code>-moz-</code>, or <code>-ms-</code> prefixes shows each prefix line as added or removed. A single property change with autoprefixer can expand to three or four diff lines.</p>
      <h3>SCSS nesting and variables</h3>
      <p>SCSS nesting means a single selector change can affect many indented child rules. A renamed SCSS variable will appear as one removed line and one added line at the variable declaration, plus a change on every line that uses it.</p>

      <h2 id="use-cases">Use cases</h2>
      <h3>Design system token changes</h3>
      <p>Compare two versions of a design token stylesheet to see exactly which color, spacing, or typography values changed between design releases.</p>
      <h3>Cross-browser stylesheet debugging</h3>
      <p>Compare the CSS applied in two different browsers by copying the computed styles from DevTools and diffing them to find which properties differ.</p>
      <h3>Theme overrides</h3>
      <p>When updating a third-party component library, compare the old and new override stylesheets to ensure all custom overrides still apply correctly after the update.</p>

      <h2 id="faq">FAQs</h2>
      <h3>Can I compare SCSS or Sass files?</h3>
      <p>Yes. SCSS, Sass, and Less files are plain text. The file upload accepts .css, .scss, .sass, and .less.</p>
      <h3>Does this compare computed CSS?</h3>
      <p>No. The tool compares the raw CSS source text. Paste computed styles from browser DevTools if you want to compare what the browser actually applies.</p>
      <h3>Is my CSS private?</h3>
      <p>Yes. All processing runs in your browser. No code is sent to any server.</p>

      <h2 id="related-tools">Related tools</h2>
      <ul class="related-tools-list">
        <li>
          <span class="tool-icon">&lt;/&gt;</span>
          <div>
            <a href="/compare/html">Compare HTML</a>
            <p>Diff checker pre-configured for .html and .htm files.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon">JS</span>
          <div>
            <a href="/compare/javascript">Compare JavaScript</a>
            <p>Diff checker pre-configured for .js, .ts, .jsx, and .tsx files.</p>
          </div>
        </li>
        <li>
          <span class="tool-icon"></></span>
          <div>
            <a href="/compare/code">Compare Code</a>
            <p>Code diff with language selector for all text-based languages.</p>
          </div>
        </li>
      </ul>

    </div>
  </div>

</CalculatorLayout>

<style is:global>
  .ct-container { max-width: 100% !important; }
  .ct-editors { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 0.25rem; }
  @media (max-width: 640px) { .ct-editors { grid-template-columns: 1fr; } }
  .ct-editor-wrap { position: relative; display: flex; width: 100%; min-height: 260px; max-height: 460px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; overflow: hidden; transition: border-color 0.2s, box-shadow 0.2s; }
  .ct-editor-wrap.focused { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.15); }
  .ct-gutter { min-width: 2.75rem; padding: 0.75rem 0.4rem 0.75rem 0; text-align: right; font-family: 'Courier New', monospace; font-size: 0.8125rem; line-height: 1.6; color: #4a5568; user-select: none; overflow: hidden; background: rgba(255,255,255,0.02); border-right: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; }
  .ct-gutter div { padding: 0 0.2rem; }
  .ct-gutter div.active-ln { color: #94a3b8; }
  .ct-hl { position: absolute; left: 0; right: 0; pointer-events: none; background: rgba(255,255,255,0.035); transition: top 0.05s; }
  .ct-textarea { flex: 1; min-height: 260px; max-height: 460px; background: transparent; border: none; color: #e2e8f0; font-family: 'Courier New', monospace; font-size: 0.8125rem; padding: 0.75rem 0.75rem 0.75rem 0.5rem; resize: none; line-height: 1.6; outline: none; overflow-y: auto; white-space: pre; tab-size: 4; -moz-tab-size: 4; overflow-x: auto; }
  .ct-textarea::placeholder { color: #94a3b8; }
  .ct-stats { display: flex; gap: 1rem; margin-top: 0.35rem; font-size: 0.72rem; color: #94a3b8; }
  .ct-diff-controls { display: flex; align-items: center; gap: 0.5rem; }
  .ct-view-toggle { display: flex; background: rgba(255,255,255,0.08); border-radius: 6px; overflow: hidden; }
  .ct-view-toggle button { background: none; border: none; color: #94a3b8; padding: 0.35rem 0.8rem; font-size: 0.78rem; cursor: pointer; transition: background 0.2s, color 0.2s; }
  .ct-view-toggle button.active { background: rgba(255,255,255,0.18); color: white; }
  .ct-diff-container { background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; overflow: auto; max-height: 480px; font-family: 'Courier New', monospace; font-size: 0.8rem; }
  .ct-diff-line { display: flex; line-height: 1.6; min-height: 1.6em; }
  .ct-line-num { min-width: 2.75rem; text-align: right; padding: 0 0.5rem; color: #4a5568; user-select: none; flex-shrink: 0; }
  .ct-line-content { padding: 0 0.75rem; white-space: pre-wrap; word-break: break-all; flex: 1; color: #94a3b8; }
  .ct-diff-line.added { background: rgba(74,222,128,0.08); }
  .ct-diff-line.added .ct-line-content { color: #4ade80; }
  .ct-diff-line.removed { background: rgba(248,113,113,0.08); }
  .ct-diff-line.removed .ct-line-content { color: #f87171; }
  .ct-sbs { display: grid; grid-template-columns: 1fr 1fr; }
  .ct-sbs-panel + .ct-sbs-panel { border-left: 1px solid rgba(255,255,255,0.08); }
  @media (max-width: 640px) { .ct-sbs { grid-template-columns: 1fr; } .ct-sbs-panel + .ct-sbs-panel { border-left: none; border-top: 1px solid rgba(255,255,255,0.08); } }
  .cc-lang-row { display: flex; align-items: center; gap: 0.6rem; margin-top: 0.75rem; }
  .cc-lang-label { font-size: 0.82rem; color: rgba(255,255,255,0.5); white-space: nowrap; }
  .cc-lang-select { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 6px; color: #e2e8f0; font-size: 0.82rem; padding: 0.3rem 0.6rem; cursor: pointer; outline: none; }
  .cc-lang-select:focus { border-color: #3b82f6; }
</style>
