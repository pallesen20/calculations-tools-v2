---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const tocItems = [
  { id: 'mission',    label: 'Our mission' },
  { id: 'what-we-offer', label: 'What we offer' },
  { id: 'commitment', label: 'Our commitment' },
  { id: 'who-we-are', label: 'Who we are' },
  { id: 'future',     label: 'Future plans' },
];
---

<CalculatorLayout
  title="About Us"
  description="Learn about calculations.tools — your free resource for accurate percentage calculators, unit converters, and text analysis tools designed to simplify everyday calculations."
  canonical="https://calculations.tools/about-us"
  tocItems={tocItems}
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container about-container">

        <!-- Hero -->
        <div class="about-hero">
          <h2 class="about-title">About calculations.tools</h2>
          <p class="about-tagline">Free, Fast, and Accurate Calculation Tools for Everyone</p>
        </div>

        <!-- Why choose us cards -->
        <div class="about-features">
          <div class="about-feature">
            <div class="about-feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7" stroke-width="2.5"/></svg></div>
            <h3>100% Free</h3>
            <p>All our tools are completely free to use with no hidden fees or subscriptions.</p>
          </div>
          <div class="about-feature">
            <div class="about-feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg></div>
            <h3>No Registration Required</h3>
            <p>Start calculating immediately without creating an account or signing up.</p>
          </div>
          <div class="about-feature">
            <div class="about-feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
            <h3>Fast &amp; Accurate</h3>
            <p>Get instant, precise results with our optimised calculation algorithms.</p>
          </div>
          <div class="about-feature">
            <div class="about-feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18" stroke-width="2.5"/></svg></div>
            <h3>Mobile-Friendly</h3>
            <p>Use our tools on any device — desktop, tablet, or smartphone.</p>
          </div>
        </div>

        <!-- CTA -->
        <div class="about-cta">
          <h3>Get Started</h3>
          <p>Ready to simplify your calculations? Explore our tools and experience the convenience of fast, accurate, and free online calculators.</p>
          <a href="/" class="about-cta-btn">Try Our Tools</a>
        </div>

      </div>
    </section>
  </div>

  <div slot="content">
    <div class="seo-container">

      <h2 id="mission">Our mission</h2>
      <p>At calculations.tools, we believe that everyone should have access to simple, accurate, and free calculation tools. Whether you're a student working on homework, a professional managing business metrics, or someone who just needs to quickly convert units or count words, we're here to help.</p>

      <h2 id="what-we-offer">What we offer</h2>
      <p>Our suite of free online tools is designed to simplify your everyday calculations. We currently offer a percentage calculator for working out increases, decreases, and differences; length and weight converters covering both metric and imperial units; a word counter for tracking words, characters, sentences, and paragraphs; temperature and currency converters; a text case converter; a text difference checker; an Excel and spreadsheet comparison tool; and a week number calculator.</p>
      <p>We're adding new tools regularly based on what people actually need.</p>

      <h2 id="commitment">Our commitment</h2>
      <p>We are committed to maintaining the highest standards of accuracy and usability in all our tools. We continuously work to improve our calculators and converters based on user feedback and emerging needs.</p>
      <p>Your privacy matters to us. We use minimal tracking to improve our service and do not sell your personal information. You can read the full details in our <a href="/privacy-policy">Privacy Policy</a>.</p>

      <h2 id="who-we-are">Who we are</h2>
      <p>calculations.tools is built and maintained by <a href="https://www.linkedin.com/in/jesperpallesen20/" target="_blank" rel="noopener noreferrer">Jesper Pallesen</a>, a developer passionate about creating useful, accessible web tools that make everyday tasks easier.</p>
      <p>What started as a simple project to help people with percentage calculations has grown into a comprehensive suite of tools used by thousands of people every month.</p>

      <h2 id="future">Future plans</h2>
      <p>We're constantly working on adding new tools and features. Have a suggestion for a calculator or converter you'd like to see? We'd love to hear from you — use the contact link in the footer.</p>

    </div>
  </div>

</CalculatorLayout>

<style>
  .about-container { max-width: 100% !important; }
  /* ── Hero ── */
  .about-hero {
    text-align: center;
    padding: 1.75rem 1rem 1.5rem;
  }
  .about-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.4rem;
  }
  .about-tagline {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.5);
  }
  /* ── Feature cards ── */
  .about-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 480px) {
    .about-features { grid-template-columns: 1fr; }
  }
  .about-feature {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
  }
  .about-feature-icon {
    font-size: 2rem;
    margin-bottom: 0.6rem;
  }
  .about-feature h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.4rem;
  }
  .about-feature p {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
    margin: 0;
  }
  /* ── CTA ── */
  .about-cta {
    background: var(--brand-gradient);
    border-radius: 1rem;
    padding: 2rem 1.5rem;
    text-align: center;
  }
  .about-cta h3 {
    color: white;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .about-cta p {
    color: rgba(255,255,255,0.85);
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }
  .about-cta-btn {
    display: inline-block;
    background: rgba(255,255,255,0.92);
    color: var(--brand-from) !important;
    padding: 0.7rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .about-cta-btn:hover {
    background: white;
    transform: translateY(-1px);
    text-decoration: none;
    color: var(--brand-from);
  }
</style>