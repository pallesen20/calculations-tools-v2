---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Calculations.tools",
    "url": "https://calculations.tools",
    "logo": "https://calculations.tools/open-graph.webp",
    "description": "Free online calculators and converters for health, math, unit conversion, text, and date calculations. Built by a human, free forever.",
    "founder": {
      "@type": "Person",
      "name": "Jesper Pallesen",
      "url": "https://www.linkedin.com/in/jesperpallesen20/",
      "jobTitle": "Founder & Developer",
      "knowsAbout": ["SEO", "Software Development", "Data Analytics", "Technical SEO", "Web Development"]
    },
    "areaServed": "Worldwide"
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Jesper Pallesen",
    "url": "https://calculations.tools/about-us",
    "sameAs": ["https://www.linkedin.com/in/jesperpallesen20/"],
    "jobTitle": "Founder & Developer",
    "worksFor": {
      "@type": "Organization",
      "name": "Calculations.tools",
      "url": "https://calculations.tools"
    },
    "description": "SEO strategist, software developer, and former professional hockey player. Founder of calculations.tools.",
    "knowsAbout": ["SEO", "Software Development", "Data Analytics", "Technical SEO", "Content Strategy"]
  }
];
---

<BaseLayout
  title="About Us"
  metaTitle="About Calculations.tools - Who We Are & Our Mission"
  description="Calculations.tools is built by Jesper Pallesen - SEO strategist and developer since 2017. Learn about our mission to provide free, accurate calculation tools for everyone."
  canonical="https://calculations.tools/about-us"
  schema={schema}
>
  <div class="au-page">
    <div class="au-container">

      <header class="au-hero">
        <p class="au-eyebrow">About calculations.tools</p>
        <h1 class="au-headline">Built by a human.<br />Free for everyone. Forever.</h1>
        <p class="au-subline">Every tool on this site is built, tested, and maintained by one person with a clear goal: make everyday calculations simple, accurate, and accessible - with no login, no paywall, and no nonsense.</p>
        <div class="au-stats">
          <div class="au-stat">
            <span class="au-stat-val">2017</span>
            <span class="au-stat-lbl">SEO &amp; dev since</span>
          </div>
          <div class="au-stat">
            <span class="au-stat-val">100%</span>
            <span class="au-stat-lbl">Free forever</span>
          </div>
          <div class="au-stat">
            <span class="au-stat-val">0</span>
            <span class="au-stat-lbl">Logins required</span>
          </div>
        </div>
      </header>

      <section class="au-section">
        <div class="au-section-inner">
          <h2>Our mission</h2>
          <p>The internet is full of calculator sites that wrap a simple formula in pop-ups, mandatory sign-ups, and paywalled results. We built calculations.tools because people deserve better: a fast, clean, accurate tool that just works - on any device, in any country, for free.</p>
          <p>Our mission is to build genuinely useful tools that help people with daily tasks. Not to collect data, not to upsell a subscription, and not to obscure the answer behind a registration wall. Every tool we publish is the version we would want to use ourselves.</p>
        </div>
        <div class="au-section-inner">
          <h2>Our vision</h2>
          <p>We want calculations.tools to become the most trusted free calculator resource on the web - where every result is accurate, every explanation is clear, and every tool works as well on a phone as it does on a desktop.</p>
          <p>We measure success not by revenue, but by whether the tools actually help the people who use them.</p>
        </div>
      </section>

      <section class="au-founder" id="founder">
        <div class="au-founder-photo-col">
          <img
            src="/jesper.webp"
            alt="Jesper Pallesen - Founder of calculations.tools"
            class="au-founder-img"
            width="80"
            height="80"
          />
          <div class="au-founder-identity">
            <span class="au-founder-name">Jesper Pallesen</span>
            <span class="au-founder-role">Founder &amp; Developer</span>
            <a
              href="https://www.linkedin.com/in/jesperpallesen20/"
              target="_blank"
              rel="noopener noreferrer"
              class="au-linkedin"
              aria-label="Jesper Pallesen on LinkedIn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Connect on LinkedIn
            </a>
          </div>
        </div>

        <div class="au-founder-bio">
          <h2>About the founder</h2>
          <p>Jesper Pallesen has worked with SEO and software development since 2017, helping businesses grow their online visibility across multiple markets and languages. His expertise sits at the intersection of technical SEO and data analytics - building systems that are both measurable and durable.</p>
          <p>Calculations.tools grew out of a personal frustration: too many online tools are engineered to extract value from users rather than provide it. Jesper built this site to be the opposite - a resource that genuinely helps people with everyday tasks and stays free for users indefinitely. The motivation is simple: tools should serve the people who use them.</p>
          <p>Before his career in digital, Jesper was a professional hockey player competing in Denmark and Germany. The discipline and focus that come with professional sport translate directly into how he approaches development and SEO - methodical, detail-oriented, and built for the long game. His work covers the full scope: technical audits, content strategy, and domain networks that strengthen SERP equity.</p>
          <p>Outside of work, Jesper travels with his family, hikes in the mountains, and explores the Scandinavian nature with his wife.</p>
        </div>
      </section>

      <section class="au-principles">
        <h2>How we build</h2>
        <div class="au-principles-grid">
          <div class="au-principle">
            <div class="au-principle-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Accuracy first</h3>
            <p>Every formula is verified against established mathematical and scientific references before publication. We show the workings so you can check for yourself.</p>
          </div>
          <div class="au-principle">
            <div class="au-principle-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3>Privacy by design</h3>
            <p>All calculations run locally in your browser. No input data is transmitted to any server. Your numbers stay your business.</p>
          </div>
          <div class="au-principle">
            <div class="au-principle-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7" stroke-width="2.5"/></svg>
            </div>
            <h3>Free forever</h3>
            <p>No subscriptions, no feature tiers, no premium results. Every tool on this site is fully accessible to everyone - now and permanently.</p>
          </div>
          <div class="au-principle">
            <div class="au-principle-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
            <h3>Maintained &amp; updated</h3>
            <p>Tools are reviewed and updated when standards change. Accuracy degrades when content is left static - we keep ours current.</p>
          </div>
          <div class="au-principle">
            <div class="au-principle-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <h3>Fast on every device</h3>
            <p>No frameworks, no bloat. Tools are built with vanilla JavaScript and load instantly on any connection, from desktops to older mobile phones.</p>
          </div>
          <div class="au-principle">
            <div class="au-principle-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3>Built for real people</h3>
            <p>Tools are designed around actual use cases - not invented scenarios. If a calculation is genuinely useful in daily life, it belongs here.</p>
          </div>
        </div>
      </section>

      <section class="au-cta">
        <h2>Start calculating</h2>
        <p>Every tool is ready to use - no account, no download, no waiting.</p>
        <a href="/" class="au-cta-btn">Browse all tools →</a>
      </section>

    </div>
  </div>
</BaseLayout>

<style is:global>
  .au-page {
    /* background: var(--bg, #1a0533); */
    min-height: 100vh;
    padding: 3rem 1rem 5rem;
  }
  .au-container {
    max-width: 820px;
    margin: 0 auto;
  }

  .au-hero {
    text-align: center;
    padding: 0 0 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 3.5rem;
  }
  .au-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1rem;
  }
  .au-headline {
    font-size: clamp(1.9rem, 5vw, 3rem);
    font-weight: 800;
    color: white;
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }
  .au-subline {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 2.5rem;
  }
  .au-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .au-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .au-stat-val {
    font-size: 1.75rem;
    font-weight: 800;
    color: white;
  }
  .au-stat-lbl {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .au-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .au-section-inner {
    padding: 1.5rem;
    border-radius: 0.5rem;
    background: var(--glass-bg-md);
    border: 1px solid var(--glass-border-strong);
  }
  @media (max-width: 600px) {
    .au-section { grid-template-columns: 1fr; gap: 2rem; }
  }
  .au-section-inner h2, .au-founder-bio h2 {
    color: white;
    margin-bottom: 1rem;
  }
  .au-section-inner p {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }
  .au-founder {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 3.5rem;
    padding: 1.5rem;
    border-radius: 0.5rem;
    background: var(--glass-bg-md);
    border: 1px solid var(--glass-border-strong);
  }
  @media (max-width: 640px) {
    .au-founder { grid-template-columns: 1fr; gap: 2rem; }
    .au-founder-photo-col { display: flex; flex-direction: column; }
  }
  .au-founder-img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    border: 3px solid rgba(255,255,255,0.15);
    display: block;
    margin-bottom: 1.25rem;
    -webkit-user-drag: none;
  }
  .au-founder-identity {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .au-founder-name {
    font-size: 1rem;
    font-weight: 700;
    color: white;
  }
  .au-founder-role {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
  }
  .au-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.65rem;
    color: #a78bfa;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.15s;
  }
  .au-linkedin:hover { color: white; text-decoration: none; }
  .au-founder-bio p {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .au-principles {
    margin-bottom: 3.5rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .au-principles > h2 {
    color: white;
    margin-bottom: 1.75rem;
    text-align: center;
  }
  .au-principles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  @media (max-width: 700px) {
    .au-principles-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 440px) {
    .au-principles-grid { grid-template-columns: 1fr; }
  }
  .au-principle {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 1.35rem 1.15rem;
  }
  .au-principle-icon {
    color: #a78bfa;
    margin-bottom: 0.7rem;
  }
  .au-principle h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.45rem;
  }
  .au-principle p {
    font-size: 0.81rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    margin: 0;
  }

  .au-cta {
    text-align: center;
    padding: 2.5rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
  }
  .au-cta h2 {
    color: white;
    margin-bottom: 0.5rem;
  }
  .au-cta p {
    color: rgba(255,255,255,0.5);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .au-cta-btn {
    display: inline-block;
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    color: white !important;
    padding: 0.75rem 2.25rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .au-cta-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    text-decoration: none;
    color: white;
  }
</style>
