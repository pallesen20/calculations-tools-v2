---
import CalculatorLayout from '../../../../layouts/CalculatorLayout.astro';
import FinanceDisclaimer from '../../../../components/FinanceDisclaimer.astro';
import { EU_INCOME_TAX } from '../../../../data/eu-income-tax';
import type { Source } from '../../../../components/Sources.astro';

export function getStaticPaths() {
  return EU_INCOME_TAX.map(c => ({
    params: { country: c.slug },
    props: { country: c },
  }));
}

const { country } = Astro.props;
const isGermany = country.slug === 'germany';
const isNetherlands = country.slug === 'netherlands';
const g = country.germanZones;
const ex = country.exampleIncome;
const nlB = country.nlBrackets;
const nlH = country.nlHeffingskorting;
const nlA = country.nlArbeidskorting;

const fmtEur = (n: number) => '€' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });

function calcGermanTax(zvE: number): number {
  if (!g) return 0;
  const yTop = (g.z2t - g.gf) / 10000;
  const c3 = (g.a2 * yTop + g.b2) * yTop;
  const zTop = (g.z3t - g.z2t) / 10000;
  const c4 = 0.42 * g.z3t - ((g.a3 * zTop + g.b3) * zTop + c3);
  const c5 = c4 + 0.03 * g.z4t;
  zvE = Math.floor(zvE);
  if (zvE <= g.gf) return 0;
  if (zvE <= g.z2t) {
    const y = (zvE - g.gf) / 10000;
    return Math.floor((g.a2 * y + g.b2) * y);
  }
  if (zvE <= g.z3t) {
    const z = (zvE - g.z2t) / 10000;
    return Math.floor((g.a3 * z + g.b3) * z + c3);
  }
  if (zvE <= g.z4t) return Math.floor(0.42 * zvE - c4);
  return Math.floor(0.45 * zvE - c5);
}

function calcNLTax(gross: number): number {
  if (!nlB) return 0;
  const t1 = Math.min(gross, nlB.b1Top) * nlB.b1Rate;
  const t2 = gross > nlB.b1Top ? Math.min(gross - nlB.b1Top, nlB.b2Top - nlB.b1Top) * nlB.b2Rate : 0;
  const t3 = gross > nlB.b2Top ? (gross - nlB.b2Top) * nlB.b3Rate : 0;
  return Math.round(t1 + t2 + t3);
}

function calcNLAhk(gross: number): number {
  if (!nlH) return 0;
  if (gross <= nlH.phaseFrom) return nlH.max;
  if (gross >= nlH.phaseTo) return 0;
  return Math.max(0, Math.round(nlH.max - (gross - nlH.phaseFrom) * nlH.phaseRate));
}

function calcNLAk(gross: number): number {
  if (!nlA) return 0;
  if (gross <= nlA.s1Top) return Math.round(gross * nlA.s1Rate);
  if (gross <= nlA.s2Top) return Math.round(nlA.s2Base + (gross - nlA.s1Top) * nlA.s2Rate);
  if (gross <= nlA.s3Top) return Math.round(nlA.s3Base + (gross - nlA.s2Top) * nlA.s3Rate);
  if (gross <= nlA.s4Top) return Math.max(0, Math.round(nlA.s4Base - (gross - nlA.s3Top) * nlA.s4Rate));
  return 0;
}

const exZvE = (isGermany && g) ? Math.max(0, ex - country.werbungskosten) : 0;
const exEst = isGermany ? calcGermanTax(exZvE) : 0;
const exRV = isGermany ? Math.round(country.rvRate * Math.min(ex, country.rvCeiling)) : 0;
const exKV = isGermany ? Math.round(country.kvPublicRate * Math.min(ex, country.kvCeiling)) : 0;
const exPV = isGermany ? Math.round(country.pvRateWith * Math.min(ex, country.kvCeiling)) : 0;
const exAV = isGermany ? Math.round(country.avRate * Math.min(ex, country.avCeiling)) : 0;
const exTotal = exEst + exRV + exKV + exPV + exAV;
const exNet = ex - exTotal;
const exNetMonthly = Math.round(exNet / 12);
const exEff = (exTotal / ex * 100).toFixed(1);
const exEstEff = (exEst / ex * 100).toFixed(1);

const nlExTax = isNetherlands ? calcNLTax(ex) : 0;
const nlExAhk = isNetherlands ? calcNLAhk(ex) : 0;
const nlExAk = isNetherlands ? calcNLAk(ex) : 0;
const nlExNetTax = Math.max(0, nlExTax - nlExAhk - nlExAk);
const nlExNet = ex - nlExNetTax;
const nlExNetMonthly = Math.round(nlExNet / 12);
const nlExEff = ex > 0 ? (nlExNetTax / ex * 100).toFixed(1) : '0.0';

const zoneData = g ? JSON.stringify(g) : '{}';
const socialData = JSON.stringify({
  rvRate: country.rvRate,
  rvCeiling: country.rvCeiling,
  kvPublicRate: country.kvPublicRate,
  kvCeiling: country.kvCeiling,
  pvRateWith: country.pvRateWith,
  pvRateChildless: country.pvRateChildless,
  pvRateSnWith: country.pvRateSnWith || 0,
  pvRateSnChildless: country.pvRateSnChildless || 0,
  avRate: country.avRate,
  avCeiling: country.avCeiling,
});
const soliData = JSON.stringify({
  threshSingle: country.soliThreshSingle || 0,
  threshMarried: country.soliThreshMarried || 0,
});
const nlBracketsData = nlB ? JSON.stringify(nlB) : '{}';
const nlHeffingData = nlH ? JSON.stringify(nlH) : '{}';
const nlArbeidData = nlA ? JSON.stringify(nlA) : '{}';

const deSources: Source[] = isGermany ? [
  {
    author: 'Bundesministerium der Finanzen',
    title: 'Einkommensteuergesetz (EStG) - § 32a EStG Einkommensteuertarif 2026',
    year: 2026,
    url: 'https://www.gesetze-im-internet.de/estg/__32a.html',
  },
  {
    author: 'Bundesministerium der Finanzen',
    title: 'Sozialversicherungsrechengrossen 2026',
    year: 2026,
    url: 'https://www.bundesregierung.de/breg-de/aktuelles/beitragsgemessungsgrenzen-2386514',
  },
  {
    author: 'Bundeszentralamt fur Steuern',
    title: 'Solidaritatszuschlaggesetz (SolZG) 2026',
    year: 2026,
    url: 'https://www.bundesfinanzministerium.de/Content/DE/FAQ/2020-06-17-solidaritaetszuschlag.html',
  },
] : [];

const nlSources: Source[] = isNetherlands ? [
  {
    author: 'Belastingdienst',
    title: 'Tabel algemene heffingskorting 2026',
    year: 2026,
    url: 'https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/heffingskortingen/algemene_heffingskorting/tabel-algemene-heffingskorting-2026',
  },
  {
    author: 'Belastingdienst',
    title: 'Tabel arbeidskorting 2026',
    year: 2026,
    url: 'https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/heffingskortingen/arbeidskorting/tabel-arbeidskorting-2026',
  },
  {
    author: 'Business.gov.nl',
    title: 'Tax brackets for income tax will change in 2026',
    year: 2026,
    url: 'https://business.gov.nl/amendments/income-tax-brackets-change-in-2026/',
  },
] : [];

const sources = isGermany ? deSources : nlSources;

const deTocItems = [
  { id: 'how-to-use', label: 'How to calculate German income tax' },
  { id: 'zones', label: 'Income tax zones 2026' },
  { id: 'social', label: 'Social security contributions 2026' },
  { id: 'tax-classes', label: 'Tax classes (Steuerklassen)' },
  { id: 'soli', label: 'Solidarity surcharge (Solidaritatszuschlag)' },
  { id: 'church', label: 'Church tax (Kirchensteuer)' },
  { id: 'compare', label: 'How Germany compares' },
  { id: 'faq', label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const nlTocItems = [
  { id: 'how-it-works', label: 'How Dutch income tax works' },
  { id: 'brackets', label: 'Box 1 tax brackets 2026' },
  { id: 'credits', label: 'Tax credits (heffingskortingen)' },
  { id: 'step-by-step', label: 'Step-by-step calculation' },
  { id: 'healthcare', label: 'Healthcare insurance (ZVW)' },
  { id: 'compare', label: 'How Netherlands compares' },
  { id: 'faq', label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const tocItems = isGermany ? deTocItems : nlTocItems;

const deSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Germany Income Tax Calculator 2026",
    "url": "https://calculations.tools/tax/income-tax-calculator/eu/germany",
    "description": "Calculate German income tax (Lohnsteuer) for 2026. Includes §32a EStG progressive formula, solidarity surcharge, church tax, all social security contributions, and full net salary breakdown.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the income tax rate in Germany in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Germany uses a progressive formula (§32a EStG) rather than fixed brackets. The marginal income tax rate starts at 14% on income above the €12,348 basic allowance (Grundfreibetrag) and rises continuously to 42% on income above €69,878. A 45% top rate (Reichensteuer) applies above €277,825. On top of income tax, employees pay a solidarity surcharge (if applicable) and social security contributions totalling approximately 21.35% of gross income up to the relevant ceilings.`,
        },
      },
      {
        "@type": "Question",
        "name": `How much tax will I pay in Germany on a €${ex.toLocaleString()} gross salary?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `A single employee (Tax Class I) earning €${ex.toLocaleString()} per year in Germany in 2026 would pay approximately ${fmtEur(exEst)} in income tax (${exEstEff}% effective rate), €0 solidarity surcharge, ${fmtEur(exRV)} pension insurance, ${fmtEur(exKV)} health insurance, ${fmtEur(exPV)} long-term care, and ${fmtEur(exAV)} unemployment insurance. Total deductions: ${fmtEur(exTotal)}. Net annual take-home: approximately ${fmtEur(exNet)} (${fmtEur(exNetMonthly)}/month). Overall effective deduction rate: ${exEff}%.`,
        },
      },
      {
        "@type": "Question",
        "name": "What is the solidarity surcharge (Solidaritatszuschlag) in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `The solidarity surcharge (Soli) is 5.5% of income tax, but is fully exempt for most employees in 2026. Single filers pay no Soli if their annual income tax is €20,350 or less. Married couples filing jointly (Tax Class III/V) have a threshold of €40,700. Above the threshold, Soli is phased in gradually - it only reaches the full 5.5% when income tax exceeds approximately €28,000 (single). In practice, only high earners with income tax above ~€28,000 pay the full Soli.`,
        },
      },
      {
        "@type": "Question",
        "name": "What are the German social security contribution rates in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `German employees pay four social security contributions: pension insurance (Rentenversicherung) 9.3% of gross up to €101,400; health insurance (Krankenversicherung) 8.75% of gross up to €69,750 (for statutory insurance); long-term care insurance (Pflegeversicherung) 1.8% with children or 2.4% if childless, up to €69,750; unemployment insurance (Arbeitslosenversicherung) 1.3% of gross up to €101,400. Employers pay matching contributions. The total employee social security burden is approximately 21.35% of gross income (within ceilings).`,
        },
      },
      {
        "@type": "Question",
        "name": "What tax class should I choose in Germany?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Tax Class I applies to single, divorced, or widowed employees. Tax Class II is for single parents eligible for the lone-parent allowance (€4,260). Married couples typically use Class III/V (one higher earner in III, lower earner in V) or Class IV/IV. Class III gives the most favourable withholding using the splitting method. Class VI applies to second jobs with no allowances. Tax class affects payroll withholding only - your actual annual liability is the same regardless of class.`,
        },
      },
    ],
  },
];

const nlSchema = isNetherlands ? [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Netherlands Income Tax Calculator 2026",
    "url": "https://calculations.tools/tax/income-tax-calculator/eu/netherlands",
    "description": "Calculate Dutch income tax (Box 1) for 2026. Includes all three tax brackets, algemene heffingskorting, arbeidskorting credits, AOW pension age toggle, and full net salary breakdown.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the income tax rate in the Netherlands in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Netherlands Box 1 income tax has three brackets in 2026. Income up to €38,883 is taxed at 35.75% - a combined rate that includes income tax plus social insurance (AOW pension 17.90%, ANW 0.10%, WLZ long-term care 9.65%). Income between €38,883 and €78,426 is taxed at 37.56%. Income above €78,426 is taxed at 49.50%. Tax credits (heffingskortingen) reduce the final tax owed, cutting the effective rate significantly below these headline rates.`,
        },
      },
      {
        "@type": "Question",
        "name": `How much will I take home on a €${ex.toLocaleString()} salary in the Netherlands in 2026?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `On a €${ex.toLocaleString()} gross salary in 2026, a Dutch employee pays approximately ${fmtEur(nlExTax)} in Box 1 income tax before credits. After the general tax credit (algemene heffingskorting: ${fmtEur(nlExAhk)}) and employment credit (arbeidskorting: ${fmtEur(nlExAk)}), net income tax is approximately ${fmtEur(nlExNetTax)}. Take-home: approximately ${fmtEur(nlExNet)}/year (${fmtEur(nlExNetMonthly)}/month) - an effective deduction rate of ${nlExEff}%.`,
        },
      },
      {
        "@type": "Question",
        "name": "What is the algemene heffingskorting in the Netherlands?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `The algemene heffingskorting (general tax credit) reduces Dutch income tax directly. In 2026, the maximum credit is €3,115 for taxpayers below state pension age. It phases out at 6.398% for every euro above €29,736, reaching zero at €78,426. AOW recipients receive a maximum of €1,556, phased out at 3.195%. The credit is non-refundable - it reduces tax to zero but cannot produce a refund on its own.`,
        },
      },
      {
        "@type": "Question",
        "name": "What is the arbeidskorting in the Netherlands in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `The arbeidskorting (employment tax credit) rewards work income. For 2026 it builds to a maximum of €5,685 at €45,592 employment income, then phases out at 6.51% until it reaches zero at €132,920. The credit is calculated in four income steps. It's non-refundable and available only to employees - self-employed workers use the zelfstandigenaftrek instead. Only the arbeidskorting and the algemene heffingskorting are included in this calculator.`,
        },
      },
      {
        "@type": "Question",
        "name": "Are Dutch social security contributions included in the income tax rate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Yes. The Netherlands embeds social insurance premiums inside the first Box 1 bracket. The 35.75% first-bracket rate consists of 8.10% income tax plus 27.65% social insurance (AOW 17.90%, ANW 0.10%, WLZ 9.65%). Above €38,883, no further social insurance is charged - brackets 2 and 3 are pure income tax. Health insurance (ZVW) is handled separately: employees pay a nominal premium directly to their insurer, and employers pay the income-related ZVW contribution as a separate wage cost.`,
        },
      },
    ],
  },
] : [];

const schema = isGermany ? deSchema : nlSchema;

const deTitle = 'Germany Income Tax Calculator 2026 (Lohnsteuer)';
const nlTitle = 'Netherlands Income Tax Calculator 2026 (Box 1)';
const deMetaTitle = 'Germany Income Tax Calculator 2026 | German Salary Calculator';
const nlMetaTitle = 'Netherlands Income Tax Calculator 2026 | NL Salary Calculator';
const deDescription = `Germany income tax calculator 2026. Includes Lohnsteuer (§32a EStG), solidarity surcharge, church tax, and all social contributions. See exact net salary for any gross income and tax class.`;
const nlDescription = `Dutch income tax calculator 2026. Calculate Box 1 tax, algemene heffingskorting and arbeidskorting credits, and net salary for any gross income. Official 2026 rates from Belastingdienst.`;
const deFormula = 'Germany: 14% - 45% progressive (§32a)';
const nlFormula = 'Netherlands Box 1: 35.75% / 37.56% / 49.50% - credits';
const deExample = `€${ex.toLocaleString()} gross - ~€${exTotal.toLocaleString()} taxes = ~€${exNet.toLocaleString()} net`;
const nlExample = `€${ex.toLocaleString()} gross - €${nlExNetTax.toLocaleString()} net tax = €${nlExNet.toLocaleString()} net`;
---

<CalculatorLayout
  title={isGermany ? deTitle : nlTitle}
  metaTitle={isGermany ? deMetaTitle : nlMetaTitle}
  description={isGermany ? deDescription : nlDescription}
  canonical={`https://calculations.tools/tax/income-tax-calculator/eu/${country.slug}`}
  tocItems={tocItems}
  schema={schema}
  sources={sources}
  embedSlug={`income-tax-calculator/eu/${country.slug}`}
  ogFormula={isGermany ? deFormula : nlFormula}
  ogExample={isGermany ? deExample : nlExample}
>

  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container">
        <div class="itax-card" id="eutax-calculator"
          data-country={country.abbr.toLowerCase()}
          data-zones={zoneData}
          data-social={socialData}
          data-soli={soliData}
          data-werbungskosten={country.werbungskosten}
          data-entlastungsbetrag={country.taxClass2Deduction || 0}
          data-currency-symbol={country.currencySymbol}
          data-nl-brackets={nlBracketsData}
          data-nl-heffingskorting={nlHeffingData}
          data-nl-arbeidskorting={nlArbeidData}
        >

          <div class="itax-header">
            <div class="itax-state-badge">{country.abbr}</div>
            <div class="itax-header-info">
              <div class="itax-state-name"><h2>Calculate Income Tax in {country.name}</h2></div>
              <div class="itax-rate-line">
                {isGermany && (
                  <>
                    <span class="itax-rate-pill">14% - 45% progressive</span>
                    <span class="itax-rate-pill itax-pill-alt">§32a EStG formula</span>
                  </>
                )}
                {isNetherlands && (
                  <>
                    <span class="itax-rate-pill">35.75% - 49.5% progressive</span>
                    <span class="itax-rate-pill itax-pill-alt">Box 1 + heffingskortingen</span>
                  </>
                )}
              </div>
            </div>
          </div>

          <div class="updated-live">
            <span class="cc-dot"></span>
            <span>Tax rates and contribution ceilings updated for 2026</span>
          </div>

          <div class="eutax-period-row">
            <label class="bmi-label">Salary period</label>
            <div class="eutax-period-btns">
              <label class="eutax-period-btn">
                <input type="radio" name="eutax-period" value="monthly" />
                <span>Monthly</span>
              </label>
              <label class="eutax-period-btn">
                <input type="radio" name="eutax-period" value="annual" checked />
                <span>Annual</span>
              </label>
            </div>
          </div>

          <div class="bmi-field">
            <label class="bmi-label" for="eutax-gross">Gross salary ({country.currency})</label>
            <div class="bmi-input-wrap">
              <input id="eutax-gross" class="amount-input eutax-input" type="text" inputmode="decimal" placeholder="60,000" style="border: none;border-radius: 0;" />
              <span class="bmi-unit-tag">{country.currencySymbol}</span>
            </div>
          </div>

          {country.hasHealthSelection && country.healthOptions && (
            <>
              <div class="bmi-field">
                <label class="bmi-label" for="eutax-health">Health insurance</label>
                <div class="bmi-input-wrap">
                  <select id="eutax-health" class="bmi-input">
                    {country.healthOptions.map(h => (
                      <option value={h.value}>{h.label}</option>
                    ))}
                  </select>
                </div>
                <span class="stax-rate-hint">Statutory (GKV): 8.75% employee share up to €69,750. Private: enter your annual premium below.</span>
              </div>

              <div class="bmi-field" id="eutax-private-field" style="display:none">
                <label class="bmi-label" for="eutax-private-contrib">Private health premium (annual {country.currency})</label>
                <div class="bmi-input-wrap">
                  <input id="eutax-private-contrib" class="bmi-input eutax-input" type="text" inputmode="decimal" placeholder="e.g. 6,000" />
                  <span class="bmi-unit-tag">{country.currencySymbol}</span>
                </div>
                <span class="stax-rate-hint">Enter your total annual premium. If employer contribution applies, the calculator deducts up to 50% (max 7.3% x capped gross) automatically.</span>
              </div>
            </>
          )}

          {country.hasTaxClass && country.taxClasses && (
            <div class="bmi-field">
              <label class="bmi-label" for="eutax-tax-class">Tax class (Steuerklasse)</label>
              <div class="bmi-input-wrap">
                <select id="eutax-tax-class" class="bmi-input">
                  {country.taxClasses.map(tc => (
                    <option value={tc.value}>{tc.label} - {tc.description}</option>
                  ))}
                </select>
              </div>
            </div>
          )}

          {country.hasStateSelection && country.states && (
            <div class="bmi-field">
              <label class="bmi-label" for="eutax-state">Federal state (Bundesland)</label>
              <div class="bmi-input-wrap">
                <select id="eutax-state" class="bmi-input">
                  {country.states.map(s => (
                    <option value={s.value} data-ks={s.ks || 0.09}>{s.label}</option>
                  ))}
                </select>
              </div>
              <span class="stax-rate-hint">Affects church tax rate (Bayern/Baden-Wurttemberg: 8%; all others: 9%) and Saxony long-term care rate.</span>
            </div>
          )}

          {country.hasChurchTax && (
            <div class="bmi-field eutax-toggle-field">
              <label class="bmi-label">Church member (Kirchenmitglied)</label>
              <label class="eutax-toggle">
                <input type="checkbox" id="eutax-church" />
                <span class="eutax-toggle-track"></span>
                <span class="eutax-toggle-label">Add church tax</span>
              </label>
              <span class="stax-rate-hint">Church tax is 8% or 9% of your income tax depending on state. Only applies if you are a registered church member in Germany.</span>
            </div>
          )}

          {country.hasChildlessField && (
            <div class="bmi-field eutax-toggle-field">
              <label class="bmi-label">No children (under 23)</label>
              <label class="eutax-toggle">
                <input type="checkbox" id="eutax-childless" />
                <span class="eutax-toggle-track"></span>
                <span class="eutax-toggle-label">Childless surcharge (+0.6% PV)</span>
              </label>
              <span class="stax-rate-hint">Employees aged 23+ with no children pay a 0.6% long-term care surcharge (Kinderlosenzuschlag). In Saxony the employee rate differs - select your state above.</span>
            </div>
          )}

          {country.hasAowToggle && (
            <div class="bmi-field eutax-toggle-field">
              <label class="bmi-label">State pension age (AOW)</label>
              <label class="eutax-toggle">
                <input type="checkbox" id="nl-aow" />
                <span class="eutax-toggle-track"></span>
                <span class="eutax-toggle-label">Receiving AOW throughout 2026</span>
              </label>
