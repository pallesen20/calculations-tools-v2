                <tr><th>Credit</th><th>Max (under AOW)</th><th>Max (AOW)</th><th>Phase-out starts</th><th>Phase-out rate</th><th>Zero at</th></tr>
              </thead>
              <tbody>
                <tr>
                  <td>Algemene heffingskorting</td>
