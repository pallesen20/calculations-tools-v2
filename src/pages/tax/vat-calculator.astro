            <tr><td>Spain / Mexico / Italy</td><td>Impuesto / Imposta sul Valore Aggiunto</td><td>IVA</td></tr>
            <tr><td>Turkey</td><td>Katma Değer Vergisi</td><td>KDV</td></tr>
            <tr><td>United Kingdom</td><td>Value Added Tax</td><td>VAT</td></tr>
          </tbody>
