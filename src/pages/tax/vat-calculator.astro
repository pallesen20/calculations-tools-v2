---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import Formula from '../../components/Formula.astro';
import FinanceDisclaimer from '../../components/FinanceDisclaimer.astro';
import type { Source } from '../../components/Sources.astro';

const f = {
  forward:  "$$\\text{VAT Amount} = \\text{Net Price} \\times \\frac{\\text{VAT Rate}}{100}$$",
  gross:    "$$\\text{Gross Price} = \\text{Net Price} + \\text{VAT Amount}$$",
  reverse:  "$$\\text{Net Price} = \\frac{\\text{Gross Price}}{1 + \\text{VAT Rate} / 100}$$",
};

const sources: Source[] = [
  {
    author: 'Tax Foundation',
    title: '2026 VAT Rates in Europe',
    journal: 'Tax Foundation',
    year: 2026,
    url: 'https://taxfoundation.org/data/all/eu/value-added-tax-vat-rates-europe/',
  },
];

const tocItems = [
  { id: 'how-to-use',          label: 'How to use this calculator' },
  { id: 'how-to-calculate',    label: 'How to calculate VAT' },
  { id: 'reverse-vat',         label: 'Reverse VAT calculation' },
  { id: 'vat-rates-by-country',label: 'VAT rates by country (2026)' },
  { id: 'vat-vs-gst',          label: 'VAT vs GST vs sales tax' },
  { id: 'local-names',         label: 'Local names for VAT' },
  { id: 'mistakes',            label: 'Common mistakes' },
  { id: 'faq',                 label: 'FAQs' },
  { id: 'related-tools',       label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "VAT Calculator",
    "url": "https://calculations.tools/tax/vat-calculator",
    "description": "Calculate VAT on any net price or remove VAT from a gross total. Enter the price and VAT rate to see the VAT amount, net price, and gross price. Add or reverse mode. Auto-detects your currency.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I calculate VAT on a price?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply the net price by the VAT rate divided by 100 to get the VAT amount, then add it to the net price for the gross total. At 20% VAT on a £100 net price: £100 x 0.20 = £20 VAT, giving a gross of £120. This calculator does the multiplication instantly for any price and rate." }
      },
      {
        "@type": "Question",
        "name": "How do I remove VAT from a price?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide the gross price by (1 + VAT Rate / 100) to get the net price. For a £120 gross at 20% VAT: £120 / 1.20 = £100 net price. The VAT amount is £120 - £100 = £20. Never subtract 20% directly from the gross total; that method overstates the tax and gives the wrong net price." }
      },
      {
        "@type": "Question",
        "name": "What is the difference between VAT and GST?",
        "acceptedAnswer": { "@type": "Answer", "text": "VAT and GST are the same type of tax with different names. Both are multi-stage consumption taxes collected at each step of production, with businesses reclaiming what they paid on inputs. Europe and most of Africa and Asia use the term VAT; Australia, New Zealand, Canada, Singapore, and India use GST." }
      },
      {
        "@type": "Question",
        "name": "What is the difference between VAT and sales tax?",
        "acceptedAnswer": { "@type": "Answer", "text": "VAT is collected at every stage of production and distribution, with each business reclaiming its input tax from the government. Sales tax is collected only at the final point of sale by the retailer. Both reach the same economic outcome for consumers, but VAT is self-policing across the supply chain while sales tax relies on the final retailer." }
      },
      {
        "@type": "Question",
        "name": "Which country has the highest VAT rate?",
        "acceptedAnswer": { "@type": "Answer", "text": "Hungary has the highest standard VAT rate in the world at 27%, according to the Tax Foundation (2026). In Europe, the next highest rates are Finland at 25.5% and Croatia, Denmark, Norway, and Sweden each at 25%. The EU average standard rate is 21.9%, well above the EU minimum requirement of 15%." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="VAT Calculator"
  metaTitle="Instant VAT Calculator | Add & Remove Value Added Tax ᐅ"
  description="Calculate VAT on any net price or remove VAT from a gross total. Enter price and VAT rate to see the VAT amount, net, and gross. Covers Europe and world rates."
  canonical="https://calculations.tools/tax/vat-calculator"
  tocItems={tocItems}
  embedSlug="vat-calculator"
  schema={schema}
  sources={sources}
  ogFormula="VAT Amount = Net Price x VAT Rate / 100"
  ogExample="€100 x 20% = €20 VAT - Gross: €120"
>
  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container bmi-container">
        <div class="calculator-header">
          <h2>Instantly Add or Remove Value Added Tax</h2>
          <p>Add VAT to a net price or remove it from a gross total</p>
        </div>

        <div class="vat-mode-toggle">
          <button id="vat-mode-add" class="vat-mode-btn vat-mode-active">Add VAT</button>
          <button id="vat-mode-remove" class="vat-mode-btn">Remove VAT</button>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" id="vat-price-label" for="vat-price">Net price (excl. VAT)</label>
          <div class="vat-price-row">
            <div class="vat-currency-wrap">
              <select id="vat-currency" class="vat-currency-select" aria-label="Currency"></select>
              <svg class="vat-currency-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 4 6 8 10 4"/></svg>
            </div>
            <input type="text" inputmode="decimal" id="vat-price" class="bmi-input vat-price-input" placeholder="e.g. 100.00" />
          </div>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="vat-rate">VAT rate (%)</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="vat-rate" class="bmi-input" placeholder="e.g. 20" />
          </div>
        </div>

        <div id="vat-result" class="lbm-result hidden">
          <div class="vat-results-grid">
            <div class="vat-result-row" id="vat-row-net">
              <span class="vat-period-label">Net price (excl. VAT)</span>
              <span class="vat-period-val" id="vat-res-net">-</span>
            </div>
            <div class="vat-result-row vat-row-tax">
              <span class="vat-period-label">VAT amount</span>
              <span class="vat-period-val" id="vat-res-vat">-</span>
            </div>
            <div class="vat-result-row vat-row-highlight" id="vat-row-gross">
              <span class="vat-period-label">Gross price (incl. VAT)</span>
              <span class="vat-period-val" id="vat-res-gross">-</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script src="/js/vat-calculator.js" is:inline></script>
    <FinanceDisclaimer />
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <div class="answer-box-label">Quick answer</div>
        <p>A VAT calculator takes a net price and a VAT rate and returns the VAT amount plus the gross total. Use it when creating invoices, checking a receipt, or shopping in a country where prices are shown without tax. Switch to "Remove VAT" mode to work backwards from a tax-inclusive price to the net amount.</p>
      </div>

      <div class="answer-box">
        <div class="answer-box-label">Key takeaways</div>
        <ul>
          <li>175 of 193 UN member states use <a href="/glossary/value-added-tax">VAT</a> or <a href="/glossary/gst">GST</a>; the US is the only major economy that does not (Tax Foundation, 2026).</li>
          <li>Hungary has the world's highest standard rate at 27%; the EU average is 21.9% (Tax Foundation, 2026).</li>
          <li>Forward formula: VAT = Net x (Rate / 100). Reverse formula: Net = Gross / (1 + Rate / 100).</li>
          <li>VAT and GST are the same tax type with different names. Australia, Canada, India, New Zealand, and Singapore use "GST"; Europe uses "VAT".</li>
        </ul>
      </div>

      <h2 id="how-to-use">How to Use This VAT Calculator</h2>
      <p>Enter your price and VAT rate, then choose your mode. "Add VAT" takes a net (excl. VAT) price and shows you the VAT amount and gross total. "Remove VAT" takes a gross (incl. VAT) price and works backwards to the net amount and the tax charged. The currency selector auto-detects your location and defaults to EUR for European visitors.</p>
      <p>The calculator updates as you type. Not sure of your country's rate? The table below lists standard VAT rates for all major countries in 2026.</p>

      <h2 id="how-to-calculate">How Do You Calculate VAT?</h2>
      <p>Multiply the net price by the VAT rate divided by 100 to get the VAT amount, then add it to the net price. For a £100 net price at 20% UK VAT: £100 x 0.20 = £20 VAT, giving a gross price of £120. Over 175 countries use VAT as their primary consumption tax, with the EU average standard rate at 21.9% in 2026 (Tax Foundation).</p>
      <p>The forward formula in two steps:</p>
      <Formula expr={f.forward} />
      <Formula expr={f.gross} />
      <p>Example: a €500 net price at Germany's 19% standard rate. VAT = €500 x 0.19 = €95. Gross = €500 + €95 = €595. Most EU countries apply reduced rates to essentials like food, books, and medicines, so always confirm whether the standard or a reduced rate applies to your specific product.</p>

      <h2 id="reverse-vat">How Do You Remove VAT from a Price?</h2>
      <p>Divide the gross (tax-inclusive) price by (1 + VAT Rate / 100). This is the correct reverse calculation, and it's needed whenever a price is quoted with VAT already included. For a £120 gross price at 20% UK VAT: £120 / 1.20 = £100 net, and the VAT was £20.</p>
      <p>The reverse formula:</p>
      <Formula expr={f.reverse} />
      <p>A very common mistake is subtracting the percentage directly from the gross: £120 x 0.20 = £24, giving £96 net. This is wrong. The correct net is £100, and the difference of £4 matters on large invoices. Always use the division method, or use the "Remove VAT" mode in this calculator to avoid the error.</p>

