---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import Formula from '../../components/Formula.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import RelatedGlossaryTerms from '../../components/RelatedGlossaryTerms.astro';
import FinanceDisclaimer from '../../components/FinanceDisclaimer.astro';

const f = {
  ev:        "$$\\text{EV} = \\text{Market Cap} + \\text{Total Debt} - \\text{Cash \\& Equivalents}$$",
  evEbitda:  "$$\\text{EV/EBITDA} = \\frac{\\text{Enterprise Value}}{\\text{EBITDA}}$$",
  evRev:     "$$\\text{EV/Revenue} = \\frac{\\text{Enterprise Value}}{\\text{Revenue}}$$",
  implied:   "$$\\text{Implied EV} = \\text{EBITDA} \\times \\text{Industry Multiple}$$",
};

const tocItems = [
  { id: 'how-to-use',    label: 'How to use' },
  { id: 'formula',       label: 'Enterprise Value formula' },
  { id: 'ev-vs-mktcap',  label: 'EV vs. market cap' },
  { id: 'multiples',     label: 'EV/EBITDA & EV/Revenue' },
  { id: 'examples',      label: 'Worked examples' },
  { id: 'benchmarks',    label: 'Industry multiples' },
  { id: 'faq',           label: 'FAQs' },
  { id: 'related-tools', label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Enterprise Value Calculator",
    "url": "https://calculations.tools/finance/enterprise-value-calculator",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "description": "Calculate Enterprise Value (EV) from market capitalisation, total debt, and cash. Optionally calculate EV/EBITDA and EV/Revenue multiples.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Enterprise Value (EV)?",
        "acceptedAnswer": { "@type": "Answer", "text": "Enterprise Value (EV) is the total value of a business - what it would cost to acquire the entire company, paying off all its debt and keeping all its cash. The formula is: EV = Market Cap + Total Debt − Cash & Equivalents. Unlike market capitalisation, EV reflects the company's capital structure and is therefore the preferred basis for cross-company valuation comparisons." }
      },
      {
        "@type": "Question",
        "name": "What is the Enterprise Value formula?",
        "acceptedAnswer": { "@type": "Answer", "text": "EV = Market Capitalisation + Total Debt − Cash & Equivalents. Market cap is share price × shares outstanding. Total debt includes short-term and long-term debt, finance leases, and other interest-bearing liabilities. Cash includes cash, cash equivalents, and short-term investments. In a full acquisition, the buyer pays the market cap (to equity holders) and assumes the debt, but benefits from the cash balance - so EV represents the net acquisition cost." }
      },
      {
        "@type": "Question",
        "name": "What is a good EV/EBITDA multiple?",
        "acceptedAnswer": { "@type": "Answer", "text": "EV/EBITDA multiples vary widely by industry. SaaS and software companies trade at 15x–30x+. Healthcare at 10x–16x. Manufacturing at 6x–10x. Retail at 5x–8x. Oil & gas at 4x–8x. A multiple below the industry average suggests a potential discount; above average suggests premium growth expectations or overvaluation. Always compare against direct peers, not cross-industry." }
      },
      {
        "@type": "Question",
        "name": "Why is Enterprise Value used instead of market cap for valuation?",
        "acceptedAnswer": { "@type": "Answer", "text": "Market cap only reflects the equity value - it ignores debt and cash, which vary widely between otherwise comparable businesses. Enterprise Value is capital-structure-neutral: a company with $100M market cap and $50M net debt has EV = $150M, while a debt-free company with $100M market cap has EV = $100M. Using EV/EBITDA instead of P/E allows fair comparison between these two companies regardless of how they are financed." }
      },
      {
        "@type": "Question",
        "name": "Can Enterprise Value be negative?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes - when a company's cash exceeds its market cap plus debt (i.e., the company is trading below its net cash balance). This is rare and typically indicates severe distress, accounting issues, or a market mispricing. It can also occur temporarily during market panics. A negative EV company is theoretically cheap on paper - you'd be buying the business for less than the cash it holds - but this often signals fundamental problems the market is pricing in." }
      }
    ]
  }
];
---

<CalculatorLayout
  title="Enterprise Value Calculator"
  metaTitle="Enterprise Value Calculator - EV/EBITDA & EV/Revenue"
  description="Calculate Enterprise Value (EV) from market cap, total debt, and cash. Instantly see EV/EBITDA and EV/Revenue multiples with industry benchmarks."
  canonical="https://calculations.tools/finance/enterprise-value-calculator"
  tocItems={tocItems}
  schema={schema}
  embedSlug="enterprise-value-calculator"
  ogFormula="EV = Market Cap + Total Debt − Cash"
  ogExample="$500M market cap + $100M debt − $50M cash = $550M EV"
>
  <div slot="calculator">
    <section class="calculator-interface">
      <div class="calculator-container bmi-container">
        <div class="calculator-header">
          <h2>Calculate Enterprise Value (EV)</h2>
          <p>Total acquisition cost - equity plus net debt</p>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="ev-market-cap">Market Capitalisation</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="ev-market-cap" class="bmi-input" placeholder="e.g. 500000000" />
          </div>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="ev-debt">+ Total Debt (short-term + long-term)</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="ev-debt" class="bmi-input" placeholder="e.g. 100000000" />
          </div>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="ev-cash">− Cash &amp; Equivalents</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="ev-cash" class="bmi-input" placeholder="e.g. 50000000" />
          </div>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="ev-ebitda">EBITDA (optional - for EV/EBITDA multiple)</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="ev-ebitda" class="bmi-input" placeholder="e.g. 40000000" />
          </div>
        </div>

        <div class="bmi-field">
          <label class="bmi-label" for="ev-revenue">Revenue (optional - for EV/Revenue multiple)</label>
          <div class="bmi-input-wrap">
            <input type="text" inputmode="decimal" id="ev-revenue" class="bmi-input" placeholder="e.g. 200000000" />
          </div>
        </div>

        <div id="ev-result" class="lbm-result hidden">
          <div class="lbm-cards">
            <div class="lbm-card">
              <div class="lbm-card-val" id="ev-val">-</div>
              <div class="lbm-card-lbl">Enterprise Value</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="ev-mktcap-out">-</div>
              <div class="lbm-card-lbl">Market Cap</div>
            </div>
          </div>

          <div class="lbm-cards" style="margin-top:0.5rem;">
            <div class="lbm-card">
              <div class="lbm-card-val" id="ev-debt-out">-</div>
              <div class="lbm-card-lbl">Total Debt</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="ev-cash-out">-</div>
              <div class="lbm-card-lbl">Cash</div>
            </div>
          </div>

          <div id="ev-multiples-row" class="lbm-cards" style="margin-top:0.5rem;">
            <div class="lbm-card">
              <div class="lbm-card-val" id="ev-ebitda-multiple">-</div>
              <div class="lbm-card-lbl">EV/EBITDA</div>
            </div>
            <div class="lbm-card">
              <div class="lbm-card-val" id="ev-rev-multiple">-</div>
              <div class="lbm-card-lbl">EV/Revenue</div>
            </div>
          </div>

          <div class="pi-steps" style="margin-top:0.75rem;">
            <div class="pi-steps-title">Calculation</div>
            <div class="pi-step">
              <span class="pi-step-label">Market Cap + Debt − Cash = EV</span>
              <span class="pi-step-val" id="ev-step1">-</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">EV / EBITDA</span>
              <span class="pi-step-val" id="ev-step2">-</span>
            </div>
            <div class="pi-step">
              <span class="pi-step-label">EV / Revenue</span>
              <span class="pi-step-val" id="ev-step3">-</span>
            </div>
          </div>
        </div>
      </div>
    </section>
    <script src="/js/enterprise-value-calculator.js" is:inline></script>
  <FinanceDisclaimer />
  </div>

  <div slot="content">
    <div class="seo-container">

      <div class="answer-box">
        <p class="answer-box-label">Quick answer</p>
        <p>Enterprise Value = <strong>Market Cap + Total Debt − Cash &amp; Equivalents</strong>. Example: $500M market cap + $100M debt − $50M cash = <strong>EV $550M</strong>. At $40M EBITDA: <strong>EV/EBITDA = 13.8x</strong>.</p>
      </div>

      <h2 id="how-to-use">How to use this calculator</h2>
      <p>Enter <strong>Market Capitalisation</strong> (share price × shares outstanding - find on any financial data site), <strong>Total Debt</strong> (short-term + long-term debt from the balance sheet), and <strong>Cash &amp; Equivalents</strong> (cash + short-term investments). Optionally enter <strong>EBITDA</strong> and <strong>Revenue</strong> to calculate the EV/EBITDA and EV/Revenue valuation multiples.</p>
      <p>Use figures from the same date. For a valuation context, use the latest reported balance sheet data paired with last twelve months (LTM) EBITDA and revenue.</p>

      <h2 id="formula">Enterprise Value formula</h2>
      <p>Enterprise Value represents the theoretical total acquisition cost of a business - what an acquirer would pay to own 100% of the company, assuming they take on all debt but receive all cash:</p>
      <Formula expr={f.ev} />
      <p>The logic: an acquirer must pay market cap to equity holders, assume responsibility for all debt, but gains immediate access to the cash balance. Net debt (Total Debt − Cash) therefore adjusts the equity price to the true cost of taking over the business.</p>
      <p>EV multiples are derived by dividing enterprise value by an earnings or revenue metric:</p>
      <Formula expr={f.evEbitda} />
      <Formula expr={f.evRev} />
      <p>EV/EBITDA is the most widely used valuation multiple in M&amp;A and private equity because it is capital-structure-neutral and comparable across different geographies and tax jurisdictions.</p>

      <h2 id="ev-vs-mktcap">Enterprise Value vs. market capitalisation</h2>
      <p>Market cap is the value of a company's equity - shares outstanding × share price. Enterprise Value is the total value of the business including all sources of capital:</p>
      <div class="responsive-table">
        <table>
          <thead>
            <tr><th></th><th>Market Cap</th><th>Enterprise Value</th></tr>
          </thead>
          <tbody>
            <tr><td>What it measures</td><td>Equity value only</td><td>Total business value (equity + net debt)</td></tr>
            <tr><td>Affected by capital structure</td><td>Yes</td><td>No - capital-structure-neutral</td></tr>
            <tr><td>Use case</td><td>P/E ratio, shareholder returns</td><td>M&amp;A, LBO, cross-company comparisons</td></tr>
            <tr><td>Paired metric</td><td>Earnings (EPS, net income)</td><td>EBITDA, Revenue, EBIT</td></tr>
            <tr><td>Affected by leverage</td><td>Yes - debt raises risk, affects P/E</td><td>No - debt/cash is already in EV</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="multiples">EV/EBITDA and EV/Revenue multiples</h2>
      <p>EV multiples answer the question: "how many times earnings (or revenue) is the market valuing this business?" A lower multiple indicates a cheaper valuation relative to earnings; a higher multiple implies growth expectations are priced in.</p>
      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Multiple</th><th>Measures</th><th>Best for</th><th>Limitation</th></tr>
          </thead>
          <tbody>
            <tr><td>EV/EBITDA</td><td>Earnings-based valuation</td><td>Profitable businesses; M&amp;A; LBO screening</td><td>Ignores CapEx; unsuitable for loss-makers</td></tr>
            <tr><td>EV/Revenue</td><td>Revenue-based valuation</td><td>High-growth, pre-profit companies (SaaS, biotech)</td><td>Doesn't account for profitability differences</td></tr>
            <tr><td>EV/EBIT</td><td>Operating income valuation</td><td>Capital-intensive businesses (D&amp;A is real cost)</td><td>More volatile than EBITDA</td></tr>
            <tr><td>EV/FCF</td><td>Cash-flow-based valuation</td><td>Cash-generative mature businesses</td><td>FCF can be distorted by CapEx timing</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="examples">Worked examples</h2>
      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Company</th><th>Market Cap</th><th>Debt</th><th>Cash</th><th>EV</th><th>EBITDA</th><th>EV/EBITDA</th></tr>
          </thead>
          <tbody>
            <tr><td>SaaS startup</td><td>$200M</td><td>$10M</td><td>$30M</td><td>$180M</td><td>$8M</td><td>22.5x</td></tr>
            <tr><td>Manufacturing co</td><td>$500M</td><td>$200M</td><td>$50M</td><td>$650M</td><td>$90M</td><td>7.2x</td></tr>
            <tr><td>Retail chain</td><td>$1,000M</td><td>$300M</td><td>$100M</td><td>$1,200M</td><td>$160M</td><td>7.5x</td></tr>
            <tr><td>Cash-heavy tech</td><td>$800M</td><td>$0M</td><td>$400M</td><td>$400M</td><td>$60M</td><td>6.7x</td></tr>
          </tbody>
        </table>
      </div>
      <p>Note the cash-heavy tech company: its market cap is $800M but EV is only $400M because $400M of the share price is just cash. The EV/EBITDA of 6.7x reflects the value of the operating business alone.</p>

      <h2 id="benchmarks">EV/EBITDA benchmarks by industry</h2>
      <div class="responsive-table">
        <table>
          <thead>
            <tr><th>Industry</th><th>EV/EBITDA range</th><th>EV/Revenue range</th></tr>
          </thead>
          <tbody>
            <tr><td>SaaS / Software</td><td>15x – 30x+</td><td>5x – 15x</td></tr>
            <tr><td>Healthcare / Pharma</td><td>10x – 18x</td><td>3x – 8x</td></tr>
            <tr><td>Consumer Staples</td><td>10x – 15x</td><td>1x – 3x</td></tr>
            <tr><td>Industrial / Manufacturing</td><td>6x – 12x</td><td>0.5x – 2x</td></tr>
            <tr><td>Telecom</td><td>5x – 9x</td><td>1x – 3x</td></tr>
            <tr><td>Retail</td><td>4x – 8x</td><td>0.3x – 1x</td></tr>
            <tr><td>Oil &amp; Gas</td><td>4x – 8x</td><td>0.5x – 2x</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="faq">Frequently asked questions</h2>

      <h3>What is Enterprise Value?</h3>
      <p>Enterprise Value (EV) is the total value of a business including both equity and net debt. It represents what an acquirer would theoretically pay to own 100% of the company: EV = Market Cap + Total Debt − Cash. It is the preferred starting point for valuation because it is capital-structure-neutral.</p>

      <h3>Why subtract cash from Enterprise Value?</h3>
      <p>In an acquisition, the buyer gains ownership of all the company's cash, which reduces their net cost. If you buy a company for its market cap but the company holds $50M in cash, your effective outlay for the operating business is market cap minus $50M. Enterprise Value normalises for this by treating net debt (debt minus cash) as the adjustment to equity value.</p>

      <h3>What is a good EV/EBITDA multiple?</h3>
      <p>Depends entirely on the industry and growth profile. SaaS companies: 15x–30x+. Healthcare: 10x–18x. Manufacturing: 6x–12x. Retail: 4x–8x. Compare against direct industry peers and historical averages, not cross-sector benchmarks.</p>

      <h3>Can Enterprise Value be negative?</h3>
      <p>Yes, when cash exceeds market cap plus debt. This means the stock trades below its net cash value - theoretically cheap, but usually signals the market is pricing in significant operational losses or risks that will consume the cash balance.</p>

      <h3>What debt should I include in the EV calculation?</h3>
      <p>Include all interest-bearing financial debt: short-term bank debt, long-term bonds, term loans, revolving credit facilities, finance/capital leases, and the current portion of long-term debt. Exclude non-financial liabilities like accounts payable, deferred revenue, and accrued expenses - these are already captured in the EBITDA or cash flow metrics used alongside EV.</p>

      <h2 id="related-tools">Related tools</h2>
      <RelatedTools tools={[
        { path: '/finance/ebitda-calculator',          blurb: 'Calculate EBITDA - the most common denominator for EV multiples.' },
        { path: '/finance/free-cash-flow-calculator',  blurb: 'Free Cash Flow from Operating Cash Flow and CapEx.' },
        { path: '/finance/pe-ratio-calculator',        blurb: 'Price-to-Earnings ratio from stock price and EPS.' },
        { path: '/finance/working-capital-calculator', blurb: 'Working Capital and Current Ratio from balance sheet data.' },
      ]} />

      <RelatedGlossaryTerms toolPath="/finance/enterprise-value-calculator" />

    </div>
  </div>

</CalculatorLayout>
