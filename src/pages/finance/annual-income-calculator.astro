    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }
  .aic-currency-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .aic-currency-select {
    width: 92px;
    height: 100%;
    padding: 0 2rem 0 0.75rem;
    background: rgba(167,139,250,0.15);
    border: 1px solid rgba(167,139,250,0.45);
    border-radius: 8px;
    color: white;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    letter-spacing: 0.03em;
  }
  .aic-currency-select:focus { outline: none; border-color: rgba(167,139,250,0.8); background: rgba(167,139,250,0.22); }
  .aic-currency-chevron { pointer-events: none; position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); color: rgba(167,139,250,0.9); }
  .aic-amount-input { flex: 1; min-width: 0; border-color: rgba(255,255,255,0.25) !important; font-size: 1rem !important; }
  .aic-amount-input:focus { border-color: rgba(167,139,250,0.6) !important; }
  .aic-bonus-toggle-row { padding: 0.1rem 0; }
  .aic-toggle-label { display: flex; align-items: center; gap: 0.6rem; cursor: pointer; }
  .aic-toggle-checkbox { width: 16px; height: 16px; cursor: pointer; accent-color: #a78bfa; }
  .aic-toggle-text { font-size: 0.85rem; color: rgba(255,255,255,0.65); user-select: none; }
  .aic-results-grid {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    overflow: hidden;
    margin-top: 0.25rem;
  }
  .aic-result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.1rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .aic-result-row:last-child { border-bottom: none; }
  .aic-result-row:nth-child(odd) { background: rgba(255,255,255,0.025); }
  .aic-row-highlight { background: rgba(167,139,250,0.08) !important; border-bottom-color: rgba(167,139,250,0.15) !important; }
  .aic-row-hourly { border-top: 1px solid rgba(255,255,255,0.12); }
