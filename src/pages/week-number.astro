    background: var(--brand-gradient);
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    margin-left: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    vertical-align: middle;
  }
  /* ── Code section ── */
  .wn-code-card {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 1rem;
    padding: 1.75rem;
  }
  .wn-code-title {
    text-align: center;
    font-size: 1.35rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.25rem;
  }
  .wn-code-sub {
    text-align: center;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .wn-snippet { margin-bottom: 1.5rem; }
  .wn-snippet-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.4rem;
  }
  .wn-lang {
    background: rgba(59,130,246,0.25);
    color: #93c5fd;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }
  .wn-code-block {
    position: relative;
    background: rgba(0,0,0,0.38);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.65rem;
    padding: 1.1rem 1rem;
    overflow-x: auto;
  }
  .wn-code-block code {
    font-family: 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
    font-size: 0.82rem;
    color: #93c5fd;
    line-height: 1.6;
    white-space: pre;
    display: block;
  }
  .wn-copy-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    padding: 0.25rem 0.55rem;
    font-size: 0.68rem;
    color: var(--text-muted);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .wn-copy-btn:hover { background: rgba(255,255,255,0.18); color: white; }
  .wn-note {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 0.4rem;
    line-height: 1.55;
  }
  .wn-note code {
    background: rgba(255,255,255,0.1);
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-size: 0.78rem;
    color: var(--text-secondary);
  }
  @media (max-width: 640px) {
    .wn-hero       { padding: 1.75rem 1rem; border-radius: 1rem; }
    .wn-table th,
    .wn-table td   { padding: 0.5rem 0.75rem; font-size: 0.8rem; }
    .wn-code-block { font-size: 0.75rem; }
    .wn-badge      { display: none; }
  }
</style>