---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const tocItems = [
  { id: 'what-is-iso',    label: 'How ISO week numbers work' },
  { id: 'iso-vs-us',      label: 'ISO vs US week numbering' },
  { id: 'week-53',        label: 'Years with 53 weeks' },
  { id: 'use-cases',      label: 'When week numbers are used' },
  { id: 'common-mistakes', label: 'Common mistakes' },
  { id: 'faq',            label: 'FAQs' },
  { id: 'related-tools',  label: 'Related tools' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Week Number Tool",
    "url": "https://calculations.tools/week-number",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "description": "Instantly see the current ISO 8601 week number. Full calendar of all weeks in the year with start and end dates, plus code snippets for 20+ programming languages.",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to calculate the ISO 8601 week number for any date",
    "description": "The ISO 8601 standard defines week numbers using the first-Thursday rule.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Find the first Thursday of the year", "text": "Identify which day of the week January 1 falls on. Count forward to find the first Thursday of the year." },
      { "@type": "HowToStep", "position": 2, "name": "Identify week 1", "text": "Week 1 is the calendar week that contains the first Thursday. This is always the week with at least 4 days in the new year." },
      { "@type": "HowToStep", "position": 3, "name": "Count weeks to your target date", "text": "Count how many complete weeks have passed since the Monday that started week 1. The result is the ISO week number for your date." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is the current week number?", "acceptedAnswer": { "@type": "Answer", "text": "The current ISO 8601 week number is shown at the top of this page and updates automatically every week." } },
      { "@type": "Question", "name": "How is the ISO 8601 week number calculated?", "acceptedAnswer": { "@type": "Answer", "text": "Week 1 is the week containing the first Thursday of the year. Weeks start on Monday and end on Sunday. A year can have 52 or 53 weeks depending on what day of the week January 1 falls on." } },
