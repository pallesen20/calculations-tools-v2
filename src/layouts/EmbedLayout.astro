---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/base.css" />
    <style>
      body { margin: 0; padding: 1rem; background: transparent; }
    </style>
  </head>
  <body>
    <slot />
    <p style="text-align:center;font-size:0.75rem;margin-top:1rem;opacity:0.5;">
      Powered by <a href="https://calculations.tools" target="_blank" style="color:inherit;">calculations.tools</a>
    </p>
  </body>
</html>