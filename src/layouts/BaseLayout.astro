---
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import { socials } from '../data/socials';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Calculations.tools",
  "url": "https://calculations.tools",
  "logo": "https://calculations.tools/open-graph.webp",
  "description": "Free online calculators and converters for health, math, unit conversion, text, and date calculations. Built by a human, free forever.",
  "foundingDate": "2025",
  "email": "info@calculations.tools",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "info@calculations.tools",
    "contactType": "customer support"
  },
  "knowsAbout": ["mathematics", "unit conversion", "health calculators", "finance calculators", "percentage calculations", "temperature conversion", "weight conversion"],
  "sameAs": socials.map(s => s.href),
  "publishingPrinciples": "https://calculations.tools/editorial-standards",
  "founder": {
    "@type": "Person",
    "name": "Jesper Pallesen",
    "url": "https://calculations.tools/about-us/jesper-pallesen",
    "jobTitle": "Founder & Developer",
    "knowsAbout": ["SEO", "Software Development", "Data Analytics", "Technical SEO", "Web Development"],
    "sameAs": ["https://www.linkedin.com/in/jesperpallesen20/", "https://gamesevenmarketing.com/", "https://dutix.io/"]
  },
  "areaServed": "Worldwide"
};


interface Props {
  title: string;
  metaTitle?: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  metaTitle,
  description,
  canonical = Astro.url.href,
  ogImage = 'https://calculations.tools/open-graph.webp',
  schema,
  noindex,
} = Astro.props;

const fullTitle = metaTitle ?? `${title} | Calculations.tools`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Calculations.tools" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/webp" sizes="32x32" href="/favicon-512x512.webp" />
    <link rel="icon" type="image/webp" sizes="16x16" href="/favicon-512x512.webp" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="stylesheet" href="/base.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" crossorigin="anonymous">

    <!-- GTM -->
    <script>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
      var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
      j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
      f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-599FWKZL');
    </script>

    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />
    {schema && <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />}
    <script type="speculationrules" is:inline>
    {
      "prefetch": [{
        "where": {
          "and": [
            { "href_matches": "/*" },
            { "not": { "href_matches": "/embed/*" } },
            { "not": { "href_matches": "/search-index.json" } },
            { "not": { "href_matches": "/sitemap.xml" } },
            { "not": { "href_matches": "/llms.txt" } }
          ]
        },
        "eagerness": "conservative"
      }]
    }
    </script>
  </head>
  <body>
    <!-- GTM noscript -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-599FWKZL"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <Header />
    <Breadcrumbs />
    <slot />
    <Footer />

    <script is:inline>
    (function(){
      document.addEventListener('input', function(e){
        var el = e.target;
        if (el.tagName !== 'INPUT') return;
        var im = (el.inputMode || el.getAttribute('inputmode') || '').toLowerCase();
        if (im !== 'decimal' && im !== 'numeric') return;
        if (el.value.indexOf(',') === -1) return;
        var pos = el.selectionStart;
        el.value = el.value.replace(/,/g, '.');
        try { el.setSelectionRange(pos, pos); } catch(x) {}
      }, true);
    })();
    </script>
    <!-- KaTeX JS - loads only on pages that contain .formula elements -->
    <script is:inline>
      (function () {
        if (!document.querySelector('.formula')) return;
        function loadScript(src, cb) {
          var s = document.createElement('script');
          s.src = src;
          s.crossOrigin = 'anonymous';
          s.onload = cb;
          document.body.appendChild(s);
        }
        function renderMath() {
          if (typeof renderMathInElement === 'undefined') return;
          renderMathInElement(document.body, {
            delimiters: [
              { left: '$$', right: '$$', display: true },
            ],
            throwOnError: false
          });
        }
        loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js', function () {
          loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js', renderMath);
        });
      })();
    </script>
  </body>
</html>